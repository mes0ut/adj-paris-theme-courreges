{%- if block.settings.display_type == 'accordion' -%}
  <accordion-item
    class="
      accordion
      accordion--detailed
      accordion--no-border-top
    "
    {{ block.shopify_attributes }}
  >
    <details
      id="Details-{{ block.id }}-{{ section.id }}"
      {% if block.settings.faq_open %}
        open
      {% endif %}
    >
      <summary>
        <div class="summary__title p">
          <div class="accordion__title">
            <div
              class="
                accordion__title-inner
                {% if block.settings.question_image %}accordion__title-inner--with-image{% endif %}
              "
            >
              {% if block.settings.question_image %}
                <div class="accordion__title-inner__image">
                  {{
                    block.settings.question_image
                    | image_url: width: 60, height: 60
                    | image_tag:
                      loading: 'lazy',
                      width: 60,
                      height: 60,
                      alt: block.settings.question_image.alt
                    | escape
                  }}
                </div>
              {% endif %}
              <div class="accordion__title-inner__content left rte">
                {% if block.settings.large_heading != blank %}
                  <h3 class="accordion__title__heading">
                    {{ block.settings.large_heading }}
                  </h3>
                {% endif %}
                {% if block.settings.faqs_question != blank %}
                  <p>
                    {{- block.settings.faqs_question -}}
                  </p>
                {% endif %}
              </div>
            </div>
          </div>
        </div>
        <div class="accordion__icon-caret">
          {% render 'icon-caret' %}
        </div>
      </summary>
      <div
        class="accordion__content rte"
        id="ProductAccordion-{{ block.id }}-{{ section.id }}"
      >
        {{ block.settings.faqs_answer }}
      </div>
    </details>
  </accordion-item>
{%- else -%}
  <div
    class="accordion accordion--detailed accordion--drawer accordion--no-border-top"
    {{ block.shopify_attributes }}
  >
    <button
      is="custom-drawer-trigger"
      class="button-reset button--full-width"
      aria-haspopup="dialog"
      data-drawer-target="#CustomDrawer-{{ block.id }}"
    >
      <div class="summary__title p">
        <div class="accordion__title">
          <div
            class="
              accordion__title-inner
              {% if block.settings.question_image %}accordion__title-inner--with-image{% endif %}
            "
          >
            {% if block.settings.question_image %}
              <div class="accordion__title-inner__image">
                {{
                  block.settings.question_image
                  | image_url: width: 60, height: 60
                  | image_tag:
                    loading: 'lazy',
                    width: 60,
                    height: 60,
                    alt: block.settings.question_image.alt
                  | escape
                }}
              </div>
            {% endif %}
            <div class="accordion__title-inner__content left rte">
              {% if block.settings.large_heading != blank %}
                <h3 class="accordion__title__heading">
                  {{ block.settings.large_heading }}
                </h3>
              {% endif %}
              {% if block.settings.faqs_question != blank %}
                <p>
                  {{- block.settings.faqs_question -}}
                </p>
              {% endif %}
            </div>
          </div>
        </div>
      </div>

      <div class="accordion__icon-caret">
        {% render 'icon-caret' %}
      </div>
    </button>
  </div>

  {%- render 'custom-drawer',
    id: block.id,
    heading: block.settings.large_heading,
    content: block.settings.faqs_answer
  -%}
{%- endif -%}

{% schema %}
{
  "name": "t:sections.collapsible-content.blocks.collapsible-row.name",
  "settings": [
    {
      "type": "select",
      "id": "display_type",
      "label": "t:sections.collapsible-content.blocks.collapsible-row.settings.display_type.label",
      "options": [
        {
          "value": "accordion",
          "label": "t:sections.collapsible-content.blocks.collapsible-row.settings.display_type.options_1.label"
        },
        {
          "value": "drawer",
          "label": "t:sections.collapsible-content.blocks.collapsible-row.settings.display_type.options_2.label"
        }
      ],
      "default": "accordion"
    },
    {
      "type": "checkbox",
      "id": "faq_open",
      "label": "t:sections.collapsible-content.blocks.collapsible-row.settings.open_row.label",
      "visible_if": "{{ block.settings.display_type == 'accordion' }}"
    },
    {
      "type": "image_picker",
      "id": "question_image",
      "label": "t:sections.collapsible-content.blocks.collapsible-row.title.settings.image.label"
    },
    {
      "type": "text",
      "id": "large_heading",
      "label": "t:sections.collapsible-content.blocks.collapsible-row.title.settings.heading.label",
      "default": "Add your title here"
    },
    {
      "type": "text",
      "id": "faqs_question",
      "label": "t:sections.collapsible-content.blocks.collapsible-row.title.settings.subtitle.label"
    },
    {
      "type": "header",
      "content": "t:sections.collapsible-content.blocks.collapsible-row.title.settings.content_header.content"
    },
    {
      "type": "richtext",
      "id": "faqs_answer",
      "label": "t:sections.collapsible-content.blocks.collapsible-row.title.settings.content.label",
      "default": "<p>Add your content here</p>"
    }
  ],
  "presets": [
    {
      "name": "t:sections.collapsible-content.blocks.collapsible-row.name"
    }
  ]
}
{% endschema %}
