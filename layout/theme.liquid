<!doctype html>
<html class="no-js" lang="{{ request.locale.iso_code }}">
  <head>
    {% liquid
      render 'meta-tags'
      render 'preconnect'
    %}

    <meta name="apple-itunes-app" content="app-id=6776702478">

    {{ content_for_header }}

    {% liquid
      render 'color-schemes'
      render 'theme-css'
      render 'preload'
      render 'javascript'
    %}
  </head>

  <body
    class="
      template-{{ template.name | handleize }}
      {%- if settings.enable_global_animations == false -%}animate--none{%- endif -%}
    "
  >
    <a
      class="skip-to-content-link button visually-hidden"
      href="#MainContent"
    >
      {{ 'accessibility.skip_to_text' | t }}
    </a>

    {% liquid
      if settings.cart_type == 'drawer' and template.name != 'cart'
        render 'cart-drawer'
      endif
      sections 'header-group'
    %}

    <main
      id="MainContent"
      class="content-for-layout focus-none"
      role="main"
      tabindex="-1"
    >
      {{ content_for_layout }}

      {% liquid
        render 'product-popup'
        if request.page_type == 'product'
          section 'main-product-fixed-cart'
        endif
      %}
    </main>

    {% liquid
      sections 'footer-group'
      section 'sign-up-modal'
    %}

    <ul hidden>
      <li id="a11y-refresh-page-message">
        {{ 'accessibility.refresh_page' | t }}
      </li>
    </ul>

    {% liquid
      render 'javascript-variables'
      render 'javascript-footer'
    %}

    {% render 'adj-android-app-banner' %}
  </body>
</html>
