{{ 'section-rich-text.css' | asset_url | stylesheet_tag }}

{% liquid
  render 'section-spacing', id: section.id, type: 'split'

  if section.settings.enable_animation
    assign animate_class = 'animate'
  else
    assign animate_class = ''
  endif

  assign content_width_range = section.settings.content_width_range | append: '%'
  assign content_position = section.settings.content_position
  if content_position == 'start'
    assign content_position = 'margin: 0 auto 0 0;'
  elsif content_position == 'middle'
    assign content_position = 'margin: 0 auto;'
  elsif content_position == 'end'
    assign content_position = 'margin: 0 0 0 auto;'
  endif
%}

{% style %}
  @media only screen and (min-width: 750px) {
    .rich-text .rich-text__container--{{ section.id }} {
      max-width: {{ content_width_range }};
      {{ content_position }}
    }
  }
{% endstyle %}

<div
  class="
    section-{{ section.id }}-margin
    rich-text
    {% if section.settings.full_width == false %} page-width {% endif %}
  "
>
  <div
    class="
      gradient
      color-{{ section.settings.color_scheme }}
      section-{{ section.id }}-padding
      {% if section.settings.show_border_bottom %}section-border-bottom{% endif %}
    "
  >
    <div class="page-width">
      <div class="rich-text__container rich-text__container--{{ section.id }}">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'tags' -%}
              <div
                class="rich-text__tags {{ block.settings.tag_alignment }}"
                {{ block.shopify_attributes }}
              >
                <ul class="rich-text__tags-list {{ animate_class }}">
                  {% for i in (1..3) %}
                    {% assign tag_link = 'tag_link_' | append: i %}
                    {% assign tag_text = 'tag_text_' | append: i %}
                    <li>
                      {% if block.settings[tag_text] != blank %}
                        {%- if block.settings[tag_link] != blank -%}
                          <a
                            href="{{ block.settings[tag_link] }}"
                            class="tag"
                          >
                            {{- block.settings[tag_text] | strip -}}
                          </a>
                        {%- else -%}
                          <span class="tag">
                            {{- block.settings[tag_text] | strip -}}
                          </span>
                        {%- endif -%}
                      {% endif %}
                    </li>
                  {% endfor %}
                </ul>
              </div>
            {%- when 'heading' -%}
              {% if block.settings.heading != blank %}
                {% liquid
                  assign title_style = block.settings.title_style
                  if title_style == 'uppercase'
                    assign title_style = 'uppercase'
                  endif
                %}

                <{{ block.settings.heading_size }}
                  {{ block.shopify_attributes }}
                  class="
                    rich-text__heading
                    {{ title_style }}
                    {{ block.settings.heading_alignment }}
                    {{ animate_class }}
                  "
                >
                  {{ block.settings.heading }}

                  {% if block.settings.decorative_icon %}
                    <div class="rich-text__heading-icon {{ block.settings.icon_position }}">
                      {% render 'icon-star-cluster-two' %}
                    </div>
                  {% endif %}
                </{{ block.settings.heading_size }}>
              {% endif %}
            {%- when 'paragraph' -%}
              {% if block.settings.rich_text != blank %}
                <div
                  {{ block.shopify_attributes }}
                  class="
                    rich-text__paragraph
                    rte
                    {{ block.settings.text_alignment }} {{ animate_class }}
                  "
                >
                  {{ block.settings.rich_text }}
                </div>
              {% endif %}
            {%- when 'link' -%}
              {% if block.settings.link != blank %}
                <div
                  {{ block.shopify_attributes }}
                  class="
                    rich-text__link-wrapper
                    {{ block.settings.link_alignment }}
                    {{ animate_class }}
                  "
                >
                  <a
                    href="{{ block.settings.link }}"
                    class="
                      link
                      link-with-icon
                      rich-text__link
                      {{ block.settings.button_color_scheme }}
                    "
                  >
                    <span>{{ block.settings.link_text }}</span>
                    {% render 'icon-arrow' %}
                  </a>
                </div>
              {% endif %}
          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.rich-text.name",
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "background-1"
    },
    {
      "type": "checkbox",
      "id": "show_border_bottom",
      "label": "t:sections.all.border.show_border_bottom.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "t:sections.rich-text.settings.full_width.label",
      "default": false
    },
    {
      "type": "range",
      "id": "content_width_range",
      "label": "t:sections.rich-text.settings.content_width_range.label",
      "min": 30,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 70
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "t:sections.rich-text.settings.content_position.label",
      "options": [
        {
          "value": "start",
          "label": "t:sections.rich-text.settings.content_position.options_1.label"
        },
        {
          "value": "middle",
          "label": "t:sections.rich-text.settings.content_position.options_2.label"
        },
        {
          "value": "end",
          "label": "t:sections.rich-text.settings.content_position.options_3.label"
        }
      ],
      "default": "middle"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.desktop_padding_header"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 120
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 120
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.mobile_padding_header"
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.mobile_padding_top",
      "default": 72
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.mobile_padding_bottom",
      "default": 72
    },
    {
      "type": "header",
      "content": "t:sections.all.margin.desktop_margin_header"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.margin.margin_bottom",
      "default": 120
    },
    {
      "type": "header",
      "content": "t:sections.all.margin.mobile_margin_header"
    },
    {
      "type": "range",
      "id": "mobile_margin_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.margin.mobile_margin_bottom",
      "default": 60
    },
    {
      "type": "header",
      "content": "t:sections.all.animations.section_animation.header",
      "visible_if": "{{ settings.enable_global_animations }}"
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "t:sections.all.animations.section_animation.label",
      "default": true,
      "visible_if": "{{ settings.enable_global_animations }}"
    }
  ],
  "blocks": [
    {
      "name": "t:sections.rich-text.blocks.heading.name",
      "type": "heading",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.rich-text.blocks.heading.settings.heading.label",
          "default": "Rich text title"
        },
        {
          "type": "select",
          "id": "title_style",
          "label": "t:sections.all.text.style.label",
          "options": [
            {
              "value": "normal",
              "label": "t:sections.all.text.style.option_1"
            },
            {
              "value": "uppercase",
              "label": "t:sections.all.text.style.option_2"
            }
          ],
          "default": "normal"
        },
        {
          "type": "select",
          "id": "heading_size",
          "options": [
            {
              "value": "h3",
              "label": "t:sections.all.heading_size.options_1.label"
            },
            {
              "value": "h2",
              "label": "t:sections.all.heading_size.options_2.label"
            },
            {
              "value": "h1",
              "label": "t:sections.all.heading_size.options_3.label"
            }
          ],
          "default": "h3",
          "label": "t:sections.all.heading_size.heading.label"
        },
        {
          "type": "select",
          "id": "heading_alignment",
          "options": [
            {
              "value": "rich-text--left-alignment",
              "label": "t:settings_schema.global.settings.text_alignment.option_1.label"
            },
            {
              "value": "rich-text--central-alignment",
              "label": "t:settings_schema.global.settings.text_alignment.option_2.label"
            },
            {
              "value": "rich-text--right-alignment",
              "label": "t:settings_schema.global.settings.text_alignment.option_3.label"
            }
          ],
          "default": "rich-text--left-alignment",
          "label": "t:settings_schema.global.settings.text_alignment.label_alignment"
        },
        {
          "type": "checkbox",
          "id": "decorative_icon",
          "label": "t:sections.rich-text.blocks.heading.settings.heading_icon.label",
          "default": false
        },
        {
          "type": "select",
          "id": "icon_position",
          "options": [
            {
              "value": "rich-text__heading-icon--left",
              "label": "t:sections.rich-text.blocks.heading.settings.heading_icon_position.option_1.label"
            },
            {
              "value": "rich-text__heading-icon--right",
              "label": "t:sections.rich-text.blocks.heading.settings.heading_icon_position.option_2.label"
            }
          ],
          "default": "rich-text__heading-icon--left",
          "label": "t:sections.rich-text.blocks.heading.settings.heading_icon_position.label"
        }
      ]
    },
    {
      "name": "t:sections.rich-text.blocks.paragraph.name",
      "type": "paragraph",
      "settings": [
        {
          "type": "richtext",
          "id": "rich_text",
          "label": "t:sections.rich-text.blocks.paragraph.settings.rich_text.label",
          "default": "<p>Give customers details about your store content on the template.</p>"
        },
        {
          "type": "select",
          "id": "text_alignment",
          "label": "t:settings_schema.global.settings.text_alignment.label_alignment",
          "options": [
            {
              "value": "rich-text--left-alignment",
              "label": "t:settings_schema.global.settings.text_alignment.option_1.label"
            },
            {
              "value": "rich-text--central-alignment",
              "label": "t:settings_schema.global.settings.text_alignment.option_2.label"
            },
            {
              "value": "rich-text--right-alignment",
              "label": "t:settings_schema.global.settings.text_alignment.option_3.label"
            }
          ],
          "default": "rich-text--left-alignment"
        }
      ]
    },
    {
      "name": "t:sections.rich-text.blocks.link.name",
      "type": "link",
      "settings": [
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.rich-text.blocks.link.settings.link.label",
          "default": "/"
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "t:sections.rich-text.blocks.link.settings.link_text.label",
          "default": "Learn more"
        },
        {
          "type": "select",
          "id": "link_alignment",
          "options": [
            {
              "value": "rich-text--left-alignment",
              "label": "t:settings_schema.global.settings.text_alignment.option_1.label"
            },
            {
              "value": "rich-text--central-alignment",
              "label": "t:settings_schema.global.settings.text_alignment.option_2.label"
            },
            {
              "value": "rich-text--right-alignment",
              "label": "t:settings_schema.global.settings.text_alignment.option_3.label"
            }
          ],
          "default": "rich-text--left-alignment",
          "label": "t:settings_schema.global.settings.text_alignment.label_alignment"
        },
        {
          "type": "select",
          "id": "button_color_scheme",
          "options": [
            {
              "value": "button",
              "label": "t:sections.all.buttons.primary.label"
            },
            {
              "value": "button button--secondary",
              "label": "t:sections.all.buttons.secondary.label"
            },
            {
              "value": "link link-with-icon",
              "label": "t:sections.all.buttons.text_link.label"
            }
          ],
          "default": "button",
          "label": "t:sections.all.buttons.label"
        }
      ]
    },
    {
      "name": "t:sections.rich-text.blocks.tags.name",
      "type": "tags",
      "settings": [
        {
          "type": "select",
          "id": "tag_alignment",
          "options": [
            {
              "value": "rich-text__tags--left-alignment",
              "label": "t:settings_schema.global.settings.text_alignment.option_1.label"
            },
            {
              "value": "rich-text__tags--central-alignment",
              "label": "t:settings_schema.global.settings.text_alignment.option_2.label"
            },
            {
              "value": "rich-text__tags--right-alignment",
              "label": "t:settings_schema.global.settings.text_alignment.option_3.label"
            }
          ],
          "default": "rich-text__tags--left-alignment",
          "label": "t:settings_schema.global.settings.text_alignment.label_alignment"
        },
        {
          "type": "header",
          "content": "t:sections.rich-text.blocks.tags.settings.tag_1.label"
        },
        {
          "type": "text",
          "id": "tag_text_1",
          "label": "t:sections.rich-text.blocks.tags.settings.tag_text.label"
        },
        {
          "type": "url",
          "id": "tag_link_1",
          "label": "t:sections.rich-text.blocks.tags.settings.tag_link.label"
        },
        {
          "type": "header",
          "content": "t:sections.rich-text.blocks.tags.settings.tag_2.label"
        },
        {
          "type": "text",
          "id": "tag_text_2",
          "label": "t:sections.rich-text.blocks.tags.settings.tag_text.label"
        },
        {
          "type": "url",
          "id": "tag_link_2",
          "label": "t:sections.rich-text.blocks.tags.settings.tag_link.label"
        },
        {
          "type": "header",
          "content": "t:sections.rich-text.blocks.tags.settings.tag_3.label"
        },
        {
          "type": "text",
          "id": "tag_text_3",
          "label": "t:sections.rich-text.blocks.tags.settings.tag_text.label"
        },
        {
          "type": "url",
          "id": "tag_link_3",
          "label": "t:sections.rich-text.blocks.tags.settings.tag_link.label"
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "presets": [
    {
      "name": "t:sections.rich-text.name",
      "category": "t:categories.storytelling",
      "blocks": [
        {
          "type": "heading"
        },
        {
          "type": "paragraph"
        },
        {
          "type": "link"
        }
      ]
    }
  ]
}
{% endschema %}
