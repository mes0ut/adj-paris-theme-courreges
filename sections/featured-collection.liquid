{% liquid
  render 'css-delay', css_file: 'component-card-slider.css'
  render 'css-delay', css_file: 'component-card-slider-with-image.css'
  render 'section-spacing', id: section.id

  if section.settings.enable_animation
    assign animate_class = 'animate'
  else
    assign animate_class = ''
  endif

  for block in section.blocks
    if block.type == 'image'
      assign main_image = block.settings.image
      assign mobile_image = block.settings.image_mobile
      assign primary_video = block.settings.primary_video
      assign image_style = block.settings.image_style
      assign show_decorative_icon = block.settings.show_decorative_icon
      assign section_layout = block.settings.section_layout
      assign side_text = block.settings.side_text
    endif
  endfor

  assign has_media = false
  if main_image != blank or primary_video != blank
    assign has_media = true
  endif

  if main_image == blank
    assign layout_class = 'card-slider-image--no-featured-image'
  endif

  if main_image != blank and section_layout == 'text_first'
    assign layout_class = layout_class | append: 'card-slider-image--reverse'
  endif
%}

<div
  class="
    gradient
    color-{{ section.settings.color_scheme }}
    section-{{ section.id }}
    card-slider-image
    {{ layout_class }}
    {% if section.settings.show_border_bottom %}section-border-bottom{% endif %}
  "
>
  {% if has_media == false %}
    {% render 'component-section-header',
      type: 'header',
      animate_class: animate_class,
      heading: section.settings.heading,
      title_style: section.settings.title_style,
      heading_size: section.settings.heading_size,
      subheading: section.settings.subheading,
      show_decorative_icon: section.settings.heading_icon,
      link: section.settings.link,
      link_text: section.settings.link_text,
      button_color_scheme: section.settings.button_color_scheme
    %}
  {% endif %}

  <div class="page-width">
    <div class="card-slider-image__grid">
      {% if has_media == true and side_text != blank %}
        <span class="card-slider-image__side-text">
          <div class="vertical-title">
            <span class="vertical-title__dash"></span>
            {{ side_text }}
          </div>
        </span>
      {% endif %}

      <div class="card-slider-image__column">
        {% if has_media == true %}
          {% if show_decorative_icon %}
            <span class="card-slider-image__decorative-icon">
              {% render 'icon-star-cluster-three' %}
            </span>
          {% endif %}

          <div class="card-slider-image__image-wrapper card-slider-image__image-wrapper--desktop">
            {% if primary_video != blank %}
              <div
                class="
                  card-slider-image__image
                  image-aspect-ratio
                  image-aspect-ratio--6-9
                  {{ image_style }}
                  {{ animate_class }}
                "
              >
                {{
                  primary_video
                  | video_tag:
                    image_size: '600x',
                    autoplay: true,
                    loop: true,
                    muted: true,
                    class: 'js-autoplay'
                }}
              </div>
            {% elsif main_image != blank %}
              <div
                class="
                  card-slider-image__image
                  image-aspect-ratio
                  image-aspect-ratio--6-9
                  {{ image_style }}
                  {{ animate_class }}
                "
              >
                {% liquid
                  assign image_height = main_image.width | divided_by: main_image.aspect_ratio
                  assign sizes = '(min-width: 1100px) 600px, (min-width: 750px) 40vw, 60vw'
                  assign widths = '375, 550, 720, 1100, 1200'
                  if main_image.aspect_ratio > 1.2
                    assign sizes = '(min-width: 1100px) 1000px, (min-width: 750px) 40vw, 100vw'
                    assign widths = '375, 550, 720, 1100, 1200'
                  endif
                  assign fetch_priority = 'auto'
                  if section.index == 1
                    assign fetch_priority = 'high'
                  endif
                %}

                {{
                  main_image
                  | image_url: width: 1900
                  | image_tag:
                    width: main_image.width,
                    height: image_height,
                    fetch_priority: fetch_priority,
                    sizes: sizes,
                    widths: widths,
                    alt: main_image.alt
                  | escape
                }}

                {{
                  main_image
                  | image_url: width: 1100
                  | image_tag:
                    loading: 'lazy',
                    width: main_image.width,
                    height: main_image.height,
                    sizes: '(min-width: 1100px) 535px, (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)',
                    widths: '535, 720, 940, 1100',
                    alt: main_image.alt
                  | escape
                }}
              </div>
            {%- endif -%}
            {% if section.settings.link != blank %}
              <a
                href="{{ section.settings.link }}"
                class="
                  link
                  link-with-icon
                  card-slider__link
                  {{ animate_class }}
                  {{ section.settings.button_color_scheme }}
                "
              >
                {{- section.settings.link_text }}
                {% render 'icon-arrow' %}
              </a>
            {% endif %}
          </div>
        {% endif %}

        <div class="card-slider {{ animate_class }}" data-animate-delay="400">
          {% if has_media == true %}
            <div class="card-slider__intro-wrapper">
              <div class="card-slider__headings-wrapper {{ animate_class }}">
                {% if section.settings.heading != blank %}
                  <{{ section.settings.heading_size }} class="card-slider__heading {{ section.settings.title_style }}">
                    {% liquid
                      if section.settings.heading_icon == true
                        render 'icon-star-cluster-two'
                      endif
                    %}
                    {{ section.settings.heading }}
                  </{{ section.settings.heading_size }}>
                {% endif %}

                {% if section.settings.subheading != blank %}
                  <p class="p-large card-slider__subheading">
                    {{ section.settings.subheading }}
                  </p>
                {% endif %}
              </div>
            </div>
          {% endif %}

          {%- if mobile_image != blank -%}
            <div
              class="
                card-slider-image__image-wrapper
                card-slider-image__image-wrapper--mobile
              "
            >
              {% if show_decorative_icon %}
                <span
                  class="
                    card-slider-image__decorative-icon
                    card-slider-image__decorative-icon--mobile
                  "
                >
                  {% render 'icon-star-cluster-three' %}
                </span>
              {% endif %}
              <div
                class="
                  card-slider-image__image
                  image-aspect-ratio
                  {{ image_style }}
                  {{ animate_class }}
                "
              >
                {{
                  mobile_image
                  | image_url: width: 533
                  | image_tag:
                    loading: 'lazy',
                    width: mobile_image.width,
                    height: mobile_image.height,
                    sizes: '(min-width: 1100px) 535px, (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)',
                    widths: '165, 360, 535, 720, 940, 1070',
                    alt: mobile_image.alt
                  | escape
                }}
              </div>
            </div>
          {%- endif -%}

          {% liquid
            assign chosen_products = '1,2,3,4,5' | split: ','
            if section.settings.collection != blank
              assign chosen_products = section.settings.collection.products
            endif
          %}

          <embla-component class="featured-collection__carousel embla-carousel">
            <div
              class="embla"
              data-align="start"
              data-slides-to-scroll="1"
              data-duration="20"
            >
              <div class="embla__viewport">
                <ul class="embla__container">
                  {% for product in chosen_products %}
                    {% liquid
                      if forloop.index0 > 7
                        break
                      endif
                    %}
                    <li
                      class="embla__slide"
                      data-slide-index="{{ forloop.index0 }}"
                    >
                      {% render 'product-card',
                        card_product: product,
                        section_id: section.id
                      %}
                    </li>
                  {% endfor %}
                </ul>
                <button
                  class="embla__button embla__button--prev"
                  disabled=""
                  aria-label="{{ 'general.pagination.previous' | t }}"
                >
                  {% render 'icon-arrow-left-large' %}
                </button>
                <button
                  class="embla__button embla__button--next"
                  disabled=""
                  aria-label="{{ 'general.pagination.next' | t }}"
                >
                  {% render 'icon-arrow-right-large' %}
                </button>
                <span class="embla__button-gradient"></span>
              </div>
            </div>
          </embla-component>
        </div>
      </div>
    </div>
  </div>

  {% render 'component-section-header',
    type: 'footer',
    animate_class: animate_class,
    link: section.settings.link,
    link_text: section.settings.link_text,
    button_color_scheme: section.settings.button_color_scheme
  %}
</div>

{% schema %}
{
  "name": "t:sections.featured-collection.name",
  "tag": "section",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "t:sections.featured-collection.settings.collection.label",
      "info": "t:sections.featured-collection.settings.collection.info"
    },
    {
      "type": "header",
      "content": "t:sections.featured-collection.settings.content-header.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "background-1"
    },
    {
      "type": "checkbox",
      "id": "show_border_bottom",
      "label": "t:sections.all.border.show_border_bottom.label",
      "default": false
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.featured-collection.settings.heading.label",
      "default": "Title and a collection"
    },
    {
      "type": "select",
      "id": "title_style",
      "label": "t:sections.all.text.style.label",
      "options": [
        {
          "value": "normal",
          "label": "t:sections.all.text.style.option_1"
        },
        {
          "value": "uppercase",
          "label": "t:sections.all.text.style.option_2"
        }
      ],
      "default": "uppercase"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h3",
          "label": "t:sections.all.heading_size.options_2.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options_3.label"
        }
      ],
      "default": "h3",
      "label": "t:sections.all.heading_size.heading.label"
    },
    {
      "type": "checkbox",
      "id": "heading_icon",
      "default": false,
      "label": "t:sections.featured-collection.settings.heading-icon.label"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:sections.featured-collection.settings.subheading.label",
      "default": "Secondary heading"
    },
    {
      "type": "url",
      "id": "link",
      "label": "t:sections.featured-collection.settings.link.label",
      "default": "/"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "t:sections.featured-collection.settings.link-text.label",
      "default": "View collection"
    },
    {
      "type": "select",
      "id": "button_color_scheme",
      "options": [
        {
          "value": "button",
          "label": "t:sections.all.buttons.primary.label"
        },
        {
          "value": "button button--secondary",
          "label": "t:sections.all.buttons.secondary.label"
        },
        {
          "value": "link link-with-icon",
          "label": "t:sections.all.buttons.text_link.label"
        }
      ],
      "default": "link link-with-icon",
      "label": "t:sections.all.buttons.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.desktop_padding_header"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.mobile_padding_header"
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.mobile_padding_top",
      "default": 0
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.mobile_padding_bottom",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:sections.all.margin.desktop_margin_header"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.margin.margin_bottom",
      "default": 120
    },
    {
      "type": "header",
      "content": "t:sections.all.margin.mobile_margin_header"
    },
    {
      "type": "range",
      "id": "mobile_margin_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.margin.mobile_margin_bottom",
      "default": 60
    },
    {
      "type": "header",
      "content": "t:sections.all.animations.section_animation.header",
      "visible_if": "{{ settings.enable_global_animations }}"
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "t:sections.all.animations.section_animation.label",
      "default": true,
      "visible_if": "{{ settings.enable_global_animations }}"
    }
  ],
  "blocks": [
    {
      "name": "Image",
      "type": "image",
      "limit": 1,
      "settings": [
        {
          "type": "header",
          "content": "t:sections.featured-collection.settings.image-header.label",
          "info": "t:sections.featured-collection.settings.image-header.info"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.featured-collection.settings.image.label",
          "info": "t:sections.all.images_tips.portrait_medium.info"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "t:sections.featured-collection.settings.image-mobile.label",
          "info": "t:sections.featured-collection.settings.image-mobile.info"
        },
        {
          "type": "video",
          "id": "primary_video",
          "label": "t:sections.all.videos_tips.general.label",
          "info": "t:sections.all.videos_tips.portrait.info"
        },
        {
          "type": "select",
          "id": "image_style",
          "options": [
            {
              "value": "image-border-radius--none",
              "label": "t:sections.all.radius.none.label"
            },
            {
              "value": "image-border-radius--rounded-xxs",
              "label": "t:sections.all.radius.xxs.label"
            },
            {
              "value": "image-border-radius--rounded-xs",
              "label": "t:sections.all.radius.xs.label"
            },
            {
              "value": "image-border-radius--rounded-small",
              "label": "t:sections.all.radius.small.label"
            },
            {
              "value": "image-border-radius--rounded",
              "label": "t:sections.all.radius.standard.label"
            },
            {
              "value": "image-border-radius--rounded-extra",
              "label": "t:sections.all.radius.extra.label"
            },
            {
              "value": "image-border-radius--curved-top",
              "label": "t:sections.all.radius.curved.label"
            }
          ],
          "default": "image-border-radius--curved-top",
          "label": "t:sections.all.radius.label"
        },
        {
          "type": "checkbox",
          "id": "show_decorative_icon",
          "label": "t:sections.featured-collection.settings.decorative_icon.label",
          "default": false
        },
        {
          "type": "select",
          "id": "section_layout",
          "options": [
            {
              "value": "image_first",
              "label": "t:sections.featured-collection.settings.layout.option_1.label"
            },
            {
              "value": "text_first",
              "label": "t:sections.featured-collection.settings.layout.option_2.label"
            }
          ],
          "default": "image_first",
          "label": "t:sections.featured-collection.settings.layout.label"
        },
        {
          "type": "text",
          "id": "side_text",
          "label": "t:sections.featured-collection.settings.side-text.label",
          "default": "Optional side text"
        }
      ]
    }
  ],
  "disabled_on": {
    "templates": ["password"],
    "groups": ["header", "footer"]
  },
  "presets": [
    {
      "name": "t:sections.featured-collection.name",
      "category": "t:categories.collections",
      "blocks": [
        {
          "type": "image"
        }
      ]
    }
  ]
}
{% endschema %}
