{% comment %}
  Store Locator Premium (No API Key required)
  - Desktop: list (left) + map (right)
  - Mobile: list + bottom-sheet store details
  - Uses Google Maps embed iframe (stable, no API key)
{% endcomment %}

<section
  id="store-locator-{{ section.id }}"
  class="slp"
  data-section-id="{{ section.id }}"
  data-default-lat="{{ section.settings.default_lat }}"
  data-default-lng="{{ section.settings.default_lng }}"
  data-default-zoom="{{ section.settings.default_zoom }}"
>
  <div class="slp__container page-width">
    <header class="slp__header">
      <div class="slp__titleWrap">
        <h1 class="slp__title">{{ section.settings.heading | escape }}</h1>
        {% if section.settings.subheading != blank %}
          <div class="slp__subtitle rte">{{ section.settings.subheading }}</div>
        {% endif %}
      </div>

      <div class="slp__tools" role="region" aria-label="Store search and filters">
        <div class="slp__search">
          <input
            type="search"
            class="slp__input"
            placeholder="{{ section.settings.search_placeholder | escape }}"
            aria-label="Search stores"
            data-slp-search
          >
          <button class="slp__clear" type="button" aria-label="Clear search" data-slp-clear hidden>×</button>
        </div>

        <div class="slp__filters">
          <select class="slp__select" data-slp-city aria-label="Filter by city">
            <option value="">{{ section.settings.city_all_label | escape }}</option>
          </select>

          <select class="slp__select" data-slp-type aria-label="Filter by type">
            <option value="">{{ section.settings.type_all_label | escape }}</option>
            <option value="flagship">{{ section.settings.type_flagship_label | escape }}</option>
            <option value="outlet">{{ section.settings.type_outlet_label | escape }}</option>
            <option value="mall">{{ section.settings.type_mall_label | escape }}</option>
          </select>
        </div>
      </div>
    </header>

    <div class="slp__layout">
      <aside class="slp__list" aria-label="Store list">
        <div class="slp__listInner" data-slp-list>
          {% if section.blocks.size == 0 %}
            <div class="slp__empty">
              <p><strong>No stores yet.</strong> Add “Store” blocks in the section settings.</p>
            </div>
          {% else %}
            {% for block in section.blocks %}
              {% assign b = block.settings %}
              <article
                class="slp__card"
                data-slp-card
                data-id="{{ block.id }}"
                data-name="{{ b.name | escape }}"
                data-city="{{ b.city | downcase | escape }}"
                data-type="{{ b.type }}"
                data-phone="{{ b.phone | escape }}"
                data-address="{{ b.address | strip_newlines | escape }}"
                data-hours="{{ b.hours | strip_newlines | escape }}"
                data-lat="{{ b.lat | escape }}"
                data-lng="{{ b.lng | escape }}"
                data-gmaps="{{ b.google_maps_url | escape }}"
                {{ block.shopify_attributes }}
                tabindex="0"
                role="button"
                aria-label="Select store {{ b.name | escape }}"
              >
                <div class="slp__cardMedia">
                  {% if b.image != blank %}
                    {{ b.image | image_url: width: 520 | image_tag: class: 'slp__img', loading: 'lazy', alt: b.name }}
                  {% else %}
                    <div class="slp__imgPlaceholder" aria-hidden="true"></div>
                  {% endif %}
                </div>

                <div class="slp__cardBody">
                  <div class="slp__cardTop">
                    <h3 class="slp__cardTitle">{{ b.name | escape }}</h3>
                    <span class="slp__chip">
                      {{ b.city | escape }}
                      {% if b.type != blank %}
                        •
                        {% case b.type %}
                          {% when 'flagship' %}{{ section.settings.type_flagship_label | escape }}
                          {% when 'outlet' %}{{ section.settings.type_outlet_label | escape }}
                          {% when 'mall' %}{{ section.settings.type_mall_label | escape }}
                          {% else %}{{ b.type | escape }}
                        {% endcase %}
                      {% endif %}
                    </span>
                  </div>

                  {% if b.address != blank %}
                    <p class="slp__meta">{{ b.address }}</p>
                  {% endif %}

                  <div class="slp__actions">
                    <a class="slp__btn slp__btn--primary" href="#" target="_blank" rel="noopener" data-slp-card-directions>
                      {{ section.settings.cta_directions | escape }}
                    </a>

                    {% if b.phone != blank %}
                      <a class="slp__btn slp__btn--ghost" href="tel:{{ b.phone | replace: ' ', '' }}">
                        {{ section.settings.cta_call | escape }}
                      </a>
                    {% else %}
                      <span class="slp__btn slp__btn--ghost slp__btn--disabled">{{ section.settings.cta_call | escape }}</span>
                    {% endif %}

                    <button class="slp__btn slp__btn--ghost" type="button" data-slp-hours>
                      {{ section.settings.cta_hours | escape }}
                    </button>
                  </div>

                  {% if b.hours != blank %}
                    <div class="slp__hours" data-slp-hours-panel hidden>
                      <p class="slp__hoursTitle">{{ section.settings.hours_title | escape }}</p>
                      <div class="slp__hoursText">{{ b.hours }}</div>
                    </div>
                  {% endif %}
                </div>
              </article>
            {% endfor %}
          {% endif %}
        </div>
      </aside>

      <div class="slp__mapWrap" aria-label="Map and store details">
        <div class="slp__map" data-slp-map>
          <div class="slp__mapFallback" data-slp-map-fallback>
            <iframe
              title="Store map"
              width="100%"
              height="100%"
              style="border:0;"
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              src="https://www.google.com/maps?q={{ section.settings.default_lat | escape }},{{ section.settings.default_lng | escape }}&z={{ section.settings.default_zoom }}&output=embed">
            </iframe>
          </div>
        </div>

        <div class="slp__detail" data-slp-detail>
          <div class="slp__detailInner">
            <div class="slp__detailHeader">
              <div>
                <p class="slp__detailKicker">{{ section.settings.detail_kicker | escape }}</p>
                <h2 class="slp__detailTitle" data-slp-detail-title>{{ section.settings.detail_default_title | escape }}</h2>
              </div>
              <button class="slp__detailClose" type="button" aria-label="Close details" data-slp-detail-close>×</button>
            </div>

            <p class="slp__detailMeta" data-slp-detail-address>{{ section.settings.detail_default_meta | escape }}</p>

            <div class="slp__detailRow">
              <a class="slp__btn slp__btn--primary" href="#" target="_blank" rel="noopener" data-slp-detail-directions>
                {{ section.settings.cta_directions | escape }}
              </a>
              <a class="slp__btn slp__btn--ghost" href="#" data-slp-detail-call>
                {{ section.settings.cta_call | escape }}
              </a>
            </div>

            <div class="slp__detailHours" data-slp-detail-hours hidden></div>
          </div>
        </div>
      </div>
    </div>

    <div class="slp__mobileSheet" data-slp-sheet hidden>
      <div class="slp__sheetHandle" aria-hidden="true"></div>
      <div class="slp__sheetBody">
        <div class="slp__sheetHeader">
          <h3 class="slp__sheetTitle" data-slp-sheet-title></h3>
          <button class="slp__detailClose" type="button" aria-label="Close details" data-slp-sheet-close>×</button>
        </div>
        <p class="slp__detailMeta" data-slp-sheet-address></p>

        <div class="slp__detailRow">
          <a class="slp__btn slp__btn--primary" href="#" target="_blank" rel="noopener" data-slp-sheet-directions>
            {{ section.settings.cta_directions | escape }}
          </a>
          <a class="slp__btn slp__btn--ghost" href="#" data-slp-sheet-call>
            {{ section.settings.cta_call | escape }}
          </a>
        </div>

        <div class="slp__detailHours" data-slp-sheet-hours hidden></div>
      </div>
    </div>
  </div>
</section>

<style>
  .slp { padding: 28px 0; }
  .slp__header { display: grid; grid-template-columns: 1fr; gap: 16px; margin-bottom: 18px; }
  .slp__title { margin: 0; font-size: 28px; letter-spacing: -0.02em; }
  .slp__subtitle { margin-top: 6px; opacity: .75; max-width: 60ch; }

  .slp__tools { display: grid; gap: 10px; }
  .slp__search { position: relative; }
  .slp__input {
    width: 100%; padding: 12px 40px 12px 12px; border-radius: 14px;
    border: 1px solid rgba(0,0,0,.12); background: rgba(255,255,255,.9);
    outline: none;
  }
  .slp__clear {
    position: absolute; right: 10px; top: 50%; transform: translateY(-50%);
    width: 28px; height: 28px; border-radius: 999px;
    border: 1px solid rgba(0,0,0,.12); background: #fff; cursor: pointer;
  }

  .slp__filters { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .slp__select {
    width: 100%; padding: 12px; border-radius: 14px;
    border: 1px solid rgba(0,0,0,.12); background: rgba(255,255,255,.9);
  }

  .slp__layout { display: grid; grid-template-columns: 1fr; gap: 14px; }
  .slp__list { border-radius: 18px; overflow: hidden; border: 1px solid rgba(0,0,0,.08); background: rgba(255,255,255,.8); }
  .slp__listInner { max-height: 520px; overflow: auto; padding: 10px; display: grid; gap: 10px; }

  .slp__card {
    display: grid; grid-template-columns: 92px 1fr; gap: 12px;
    padding: 10px; border-radius: 16px; border: 1px solid rgba(0,0,0,.08);
    background: #fff; cursor: pointer;
    transition: transform .15s ease, box-shadow .15s ease, border-color .15s ease;
    outline: none;
  }
  .slp__card:hover { transform: translateY(-1px); box-shadow: 0 10px 30px rgba(0,0,0,.08); }
  .slp__card[aria-selected="true"] { border-color: rgba(0,0,0,.28); box-shadow: 0 10px 30px rgba(0,0,0,.10); }

  .slp__cardMedia { width: 92px; height: 92px; border-radius: 14px; overflow: hidden; background: rgba(0,0,0,.04); }
  .slp__img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .slp__imgPlaceholder { width: 100%; height: 100%; }

  .slp__cardTitle { margin: 0; font-size: 15px; letter-spacing: -0.01em; }
  .slp__chip { display: inline-flex; margin-top: 4px; font-size: 12px; opacity: .7; }
  .slp__meta { margin: 8px 0 0; font-size: 12px; opacity: .75; }

  .slp__actions { display: flex; gap: 8px; margin-top: 10px; flex-wrap: wrap; }
  .slp__btn {
    display: inline-flex; align-items: center; justify-content: center;
    padding: 10px 12px; border-radius: 999px; text-decoration: none;
    border: 1px solid rgba(0,0,0,.12); background: #fff;
    font-size: 12px; cursor: pointer;
  }
  .slp__btn--primary { border-color: rgba(0,0,0,.75); }
  .slp__btn--ghost { background: rgba(255,255,255,.6); }
  .slp__btn--disabled { opacity: .5; pointer-events: none; }

  .slp__hours { margin-top: 10px; padding: 10px; border-radius: 14px; background: rgba(0,0,0,.03); border: 1px solid rgba(0,0,0,.06); }
  .slp__hoursTitle { margin: 0 0 6px; font-size: 12px; opacity: .8; }
  .slp__hoursText { font-size: 12px; opacity: .8; white-space: pre-line; }

  .slp__mapWrap { position: relative; border-radius: 18px; overflow: hidden; border: 1px solid rgba(0,0,0,.08); background: rgba(255,255,255,.8); }
  .slp__map { height: 520px; }
  .slp__mapFallback, .slp__mapFallback iframe { width: 100%; height: 100%; }

  .slp__detail {
    position: absolute; left: 12px; bottom: 12px;
    width: min(420px, calc(100% - 24px));
    border-radius: 18px; background: rgba(255,255,255,.92);
    border: 1px solid rgba(0,0,0,.10);
    box-shadow: 0 18px 50px rgba(0,0,0,.12);
    backdrop-filter: blur(10px);
  }
  .slp__detailInner { padding: 14px; }
  .slp__detailHeader { display: flex; justify-content: space-between; gap: 10px; align-items: start; }
  .slp__detailKicker { margin: 0; font-size: 11px; opacity: .7; text-transform: uppercase; letter-spacing: .08em; }
  .slp__detailTitle { margin: 4px 0 0; font-size: 16px; }
  .slp__detailClose {
    width: 34px; height: 34px; border-radius: 999px;
    border: 1px solid rgba(0,0,0,.12); background: #fff; cursor: pointer;
  }
  .slp__detailMeta { margin: 10px 0 0; font-size: 12px; opacity: .8; }
  .slp__detailRow { margin-top: 12px; display: flex; gap: 10px; flex-wrap: wrap; }
  .slp__detailHours { margin-top: 12px; padding: 10px; border-radius: 14px; background: rgba(0,0,0,.03); border: 1px solid rgba(0,0,0,.06); font-size: 12px; opacity: .85; white-space: pre-line; }

  .slp__mobileSheet {
    position: fixed; left: 0; right: 0; bottom: 0;
    border-radius: 18px 18px 0 0;
    background: rgba(255,255,255,.96);
    border: 1px solid rgba(0,0,0,.10);
    box-shadow: 0 -18px 50px rgba(0,0,0,.16);
    backdrop-filter: blur(12px);
    padding: 10px 14px 16px;
    z-index: 60;
  }
  .slp__sheetHandle { width: 48px; height: 5px; border-radius: 99px; background: rgba(0,0,0,.18); margin: 6px auto 10px; }
  .slp__sheetHeader { display: flex; justify-content: space-between; align-items: center; gap: 10px; }
  .slp__sheetTitle { margin: 0; font-size: 16px; }
  .slp__sheetBody { max-width: 980px; margin: 0 auto; }

  @media (min-width: 990px) {
    .slp { padding: 40px 0; }
    .slp__header { grid-template-columns: 1.1fr .9fr; align-items: end; }
    .slp__layout { grid-template-columns: minmax(360px, 420px) 1fr; gap: 16px; }
    .slp__listInner { max-height: 660px; }
    .slp__map { height: 660px; }
    .slp__mobileSheet { display: none !important; }
  }
  /* --- SLP Mobile Premium Patch --- */
@media (max-width: 989px) {
  /* Mobilde map yerine liste-first */
  .slp__mapWrap { display: none !important; }

  /* Liste alanı daha ferah */
  .slp__listInner { max-height: none !important; padding: 12px !important; gap: 12px !important; }

  /* Kart: daha kompakt ve premium */
  .slp__card { grid-template-columns: 76px 1fr !important; padding: 12px !important; }
  .slp__cardMedia { width: 76px !important; height: 76px !important; border-radius: 16px !important; }

  /* Butonlar: Itinéraire tam genişlik primary */
  .slp__actions { display: grid !important; grid-template-columns: 1fr 1fr !important; gap: 10px !important; }
  .slp__actions a[data-slp-card-directions]{
    grid-column: 1 / -1 !important;
    border-color: rgba(0,0,0,.85) !important;
    background: rgba(0,0,0,.92) !important;
    color: #fff !important;
  }
  .slp__actions a[href^="tel:"], .slp__actions button[data-slp-hours]{
    background: rgba(255,255,255,.7) !important;
  }

  /* Bottom sheet: daha büyük, daha premium */
  .slp__mobileSheet{
    padding-bottom: calc(16px + env(safe-area-inset-bottom)) !important;
  }
  .slp__sheetBody{
    max-height: 70vh !important;
    overflow: auto !important;
  }

  /* Sheet içi CTA */
  .slp__detailRow { display: grid !important; grid-template-columns: 1fr 1fr !important; gap: 10px !important; }
  .slp__detailRow .slp__btn--primary{
    grid-column: 1 / -1 !important;
    border-color: rgba(0,0,0,.85) !important;
    background: rgba(0,0,0,.92) !important;
    color: #fff !important;
  }

  /* Saat bloğu okunaklı */
  .slp__detailHours, .slp__hoursText { line-height: 1.5 !important; }
}
</style>

<script>
    function formatHours(hoursRaw){
  const h = (hoursRaw || '').toString().trim();
  if (!h) return '';

  // Fransızca gün başlıklarını satır kır
  // (Sen tek satır bile girsen, otomatik daha okunur yapar)
  return h
    .replace(/\s+(Lundi|Mardi|Mercredi|Jeudi|Vendredi|Samedi|Dimanche)\s*:/g, '\n$1 :')
    .replace(/\s+(Lun|Mar|Mer|Jeu|Ven|Sam|Dim)\s*:/g, '\n$1 :')
    .replace(/\s+Samedi\s*:/g, '\nSamedi :')
    .replace(/\s+Dimanche\s*:/g, '\nDimanche :')
    .replace(/\s+\*/g, '\n*')
    .trim();
}
(() => {
  const root = document.querySelector('#store-locator-{{ section.id }}');
  if (!root) return;

  const searchEl = root.querySelector('[data-slp-search]');
  const clearBtn = root.querySelector('[data-slp-clear]');
  const citySel = root.querySelector('[data-slp-city]');
  const typeSel = root.querySelector('[data-slp-type]');
  const cards = Array.from(root.querySelectorAll('[data-slp-card]'));

  const detailTitle = root.querySelector('[data-slp-detail-title]');
  const detailAddr = root.querySelector('[data-slp-detail-address]');
  const detailDir = root.querySelector('[data-slp-detail-directions]');
  const detailCall = root.querySelector('[data-slp-detail-call]');
  const detailHours = root.querySelector('[data-slp-detail-hours]');
  const detailClose = root.querySelector('[data-slp-detail-close]');

  const sheet = root.querySelector('[data-slp-sheet]');
  const sheetTitle = root.querySelector('[data-slp-sheet-title]');
  const sheetAddr = root.querySelector('[data-slp-sheet-address]');
  const sheetDir = root.querySelector('[data-slp-sheet-directions]');
  const sheetCall = root.querySelector('[data-slp-sheet-call]');
  const sheetHours = root.querySelector('[data-slp-sheet-hours]');
  const sheetClose = root.querySelector('[data-slp-sheet-close]');

  const iframe = root.querySelector('[data-slp-map-fallback] iframe');

  const isDesktop = () => window.matchMedia('(min-width: 990px)').matches;
  const norm = (s) => (s || '').toString().toLowerCase().trim();

  // Build city options
  const cities = Array.from(new Set(cards.map(c => norm(c.dataset.city)).filter(Boolean))).sort();
  cities.forEach(city => {
    const opt = document.createElement('option');
    opt.value = city;
    opt.textContent = city.charAt(0).toUpperCase() + city.slice(1);
    citySel.appendChild(opt);
  });

  function mapSrcFrom(card) {
    const gmaps = (card.dataset.gmaps || '').trim();
    const lat = (card.dataset.lat || '').trim();
    const lng = (card.dataset.lng || '').trim();
    const addr = (card.dataset.address || '').trim();

    if (gmaps) {
      // Use a query based on URL/address (embed-safe)
      return `https://www.google.com/maps?q=${encodeURIComponent(gmaps)}&output=embed`;
    }
    if (lat && lng) {
      return `https://www.google.com/maps?q=${encodeURIComponent(lat)},${encodeURIComponent(lng)}&z=18&output=embed`;
    }
    return `https://www.google.com/maps?q=${encodeURIComponent(addr)}&z=18&output=embed`;
  }

  function directionsHrefFrom(card) {
    const gmaps = (card.dataset.gmaps || '').trim();
    const lat = (card.dataset.lat || '').trim();
    const lng = (card.dataset.lng || '').trim();
    const addr = (card.dataset.address || '').trim();

    if (gmaps) return gmaps;
    if (lat && lng) return `https://www.google.com/maps?q=${encodeURIComponent(lat)},${encodeURIComponent(lng)}`;
    return `https://www.google.com/maps?q=${encodeURIComponent(addr)}`;
  }

  function applyFilters() {
    const q = norm(searchEl.value);
    const city = norm(citySel.value);
    const type = norm(typeSel.value);

    let anyVisible = false;

    cards.forEach(card => {
      const name = norm(card.dataset.name);
      const address = norm(card.dataset.address);
      const ccity = norm(card.dataset.city);
      const ctype = norm(card.dataset.type);

      const matchQ = !q || name.includes(q) || address.includes(q);
      const matchCity = !city || ccity === city;
      const matchType = !type || ctype === type;

      const show = matchQ && matchCity && matchType;
      card.style.display = show ? '' : 'none';
      if (show) anyVisible = true;
    });

    clearBtn.hidden = !searchEl.value;

    const selected = root.querySelector('[data-slp-card][aria-selected="true"]');
    if (selected && selected.style.display === 'none') {
      selected.removeAttribute('aria-selected');
    }

   // Otomatik seçimi kapattık: ilk açılış Paris merkezli kalsın
// if (!root.querySelector('[data-slp-card][aria-selected="true"]') && anyVisible) {
//   const first = cards.find(c => c.style.display !== 'none');
//   if (first) selectStore(first);
// }
  }

  function selectStore(card) {
    if (!card) return;

    cards.forEach(c => c.removeAttribute('aria-selected'));
    card.setAttribute('aria-selected', 'true');

    const title = card.dataset.name || '';
    const address = card.dataset.address || '';
    const phone = (card.dataset.phone || '').trim();
    const hours = (card.dataset.hours || '').trim();

    const dirHref = directionsHrefFrom(card);

    detailTitle.textContent = title;
    detailAddr.textContent = address;
    detailDir.href = dirHref;

    if (phone) {
      detailCall.href = `tel:${phone.replace(/\s+/g,'')}`;
      detailCall.style.pointerEvents = 'auto';
      detailCall.style.opacity = '1';
    } else {
      detailCall.href = '#';
      detailCall.style.pointerEvents = 'none';
      detailCall.style.opacity = '.5';
    }

    if (hours) {
      detailHours.hidden = false;
      detailHours.textContent = formatHours(hours);
    } else {
      detailHours.hidden = true;
    }

    if (iframe) iframe.src = mapSrcFrom(card);

    // Update each card's "Itinéraire" button href
    const cardDirBtn = card.querySelector('[data-slp-card-directions]');
    if (cardDirBtn) cardDirBtn.href = dirHref;

    // Mobile sheet
    if (!isDesktop()) {
      sheetTitle.textContent = title;
      sheetAddr.textContent = address;
      sheetDir.href = dirHref;
      if (phone) {
        sheetCall.href = `tel:${phone.replace(/\s+/g,'')}`;
        sheetCall.style.pointerEvents = 'auto';
        sheetCall.style.opacity = '1';
      } else {
        sheetCall.href = '#';
        sheetCall.style.pointerEvents = 'none';
        sheetCall.style.opacity = '.5';
      }

      if (hours) {
        sheetHours.hidden = false;
        sheetHours.textContent = formatHours(hours);
      } else {
        sheetHours.hidden = true;
      }
      sheet.hidden = false;
    } else {
      sheet.hidden = true;
    }
  }

  // Listeners
  searchEl.addEventListener('input', applyFilters);
  clearBtn.addEventListener('click', () => { searchEl.value = ''; applyFilters(); searchEl.focus(); });
  citySel.addEventListener('change', applyFilters);
  typeSel.addEventListener('change', applyFilters);

  root.addEventListener('click', (e) => {
    const card = e.target.closest('[data-slp-card]');
    if (card) selectStore(card);

    const hoursBtn = e.target.closest('[data-slp-hours]');
    if (hoursBtn) {
      const parentCard = e.target.closest('[data-slp-card]');
      if (!parentCard) return;
      const panel = parentCard.querySelector('[data-slp-hours-panel]');
      if (panel) panel.hidden = !panel.hidden;
    }
  });

  root.addEventListener('keydown', (e) => {
    if (e.key !== 'Enter' && e.key !== ' ') return;
    const card = e.target.closest('[data-slp-card]');
    if (card) { e.preventDefault(); selectStore(card); }
  });

  detailClose.addEventListener('click', () => {
    cards.forEach(c => c.removeAttribute('aria-selected'));
    detailTitle.textContent = "{{ section.settings.detail_default_title | escape }}";
    detailAddr.textContent = "{{ section.settings.detail_default_meta | escape }}";
    detailDir.href = '#';
    detailCall.href = '#';
    detailHours.hidden = true;
    if (!isDesktop()) sheet.hidden = true;
  });

  sheetClose.addEventListener('click', () => { sheet.hidden = true; });

  window.addEventListener('resize', () => {
    const selected = root.querySelector('[data-slp-card][aria-selected="true"]');
    if (isDesktop()) sheet.hidden = true;
    else if (selected) selectStore(selected);
  });

function setDefaultMap() {
  const lat = (root.dataset.defaultLat || '48.8566').trim();
  const lng = (root.dataset.defaultLng || '2.3522').trim();
  const z = Number(root.dataset.defaultZoom || 11);
  if (iframe) iframe.src = `https://www.google.com/maps?q=${encodeURIComponent(lat)},${encodeURIComponent(lng)}&z=${encodeURIComponent(z)}&output=embed`;
}

// Init (Paris/section ayarlarıyla başla, mağaza otomatik seçme)
setDefaultMap();
applyFilters(); // sadece filtreleri uygula, seçim yapma
})();
</script>

