{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}

{% liquid
  render 'section-spacing', id: section.id

  if section.settings.enable_animation
    assign animate_class = 'animate'
  else
    assign animate_class = ''
  endif

  assign title_style = section.settings.title_style
  if title_style == 'uppercase'
    assign title_style = 'uppercase'
  endif

  assign section_index = section.index
  assign lazy_load = 'lazy'
  assign priority_load = false
  assign fetch_priority = 'low'
  if section_index == 1
    assign lazy_load = 'eager'
    assign priority_load = true
    assign fetch_priority = 'high'
  endif
%}

{% style %}
  {% if section.settings.height_mobile == 'custom-mobile' %}
    @media (max-width: 749px) {
      .section-{{ section.id }} .image-banner .image-banner__inner {
        min-height: {{ section.settings.height_mobile_custom }}px;
      }
    }
  {% endif %}
  {% if section.settings.height == 'custom-desktop' %}
    @media (min-width: 750px) {
      .section-{{ section.id }} .image-banner .image-banner__inner {
        min-height: {{ section.settings.height_custom }}px;
      }
    }
  {% endif %}
{% endstyle %}

<div
  class="
    section-{{ section.id }}
    {% if section.settings.show_border_bottom %}section-border-bottom{% endif %}
  "
>
  {% unless section.settings.full_width %}
    <div class="page-width">
  {% endunless %}
  <div
    class="
      gradient
      color-{{ section.settings.color_scheme }}
      background-transparent
      {{ section.settings.border_radius }}
    "
  >
    <div class="image-banner">
      <div
        class="
          image-banner__image-wrapper
          {% if section.settings.show_gradient %}
            {% if section.settings.content_position contains 'bottom' %}
              image-banner__image-wrapper--gradient-bottom
            {% endif %}
            {% if section.settings.content_position contains 'top' %}
              image-banner__image-wrapper--gradient-top
            {% endif %}
          {% endif %}
          {% if section.settings.image_mobile %}
            image-banner__image-wrapper--desktop
          {% endif %}
        "
      >
        {% if section.settings.video != blank %}
          <div class="image-banner__video">
            {% render 'video-delay-loader',
              video_data: section.settings.video,
              image_size: '600x',
              class_name: 'js-autoplay',
              autoplay: true,
              loop: true,
              muted: true,
              delay_loader: section.settings.delay_loader,
              section_index: section_index
            %}
          </div>
        {% elsif section.settings.image != blank %}
          {% assign image_height = section.settings.image.width
            | divided_by: section.settings.image.aspect_ratio
            | ceil
          %}

          {{
            section.settings.image
            | image_url: width: 3000
            | image_tag:
              loading: lazy_load,
              priority: priority_load,
              fetchpriority: fetch_priority,
              width: section.settings.image.width,
              height: image_height,
              sizes: '100vw',
              widths: '1500, 2000, 2500, 3000',
              class: 'image-banner__image',
              alt: section.settings.image.alt
            | escape
          }}
        {% else %}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
        {% endif %}
      </div>

      {% if section.settings.image_mobile != blank %}
        <div
          class="
            image-banner__image-wrapper
            image-banner__image-wrapper--mobile
            {% if section.settings.show_gradient and section.settings.content_position contains 'bottom' %}
              image-banner__image-wrapper--gradient-bottom
            {% endif %}
          "
        >
          {% assign image_height = section.settings.image_mobile.width
            | divided_by: section.settings.image_mobile.aspect_ratio
            | ceil
          %}

          {{
            section.settings.image_mobile
            | image_url: width: 750
            | image_tag:
              loading: lazy_load,
              priority: priority_load,
              fetchpriority: fetch_priority,
              width: section.settings.image_mobile.width,
              height: image_height,
              sizes: '100vw',
              widths: '400, 500, 750',
              class: 'image-banner__image',
              alt: section.settings.image_mobile.alt
            | escape
          }}
        </div>
      {% endif %}

      <div class="page-width">
        {% liquid
          assign content_position_class = 'image-banner__inner-wrapper--' | append: section.settings.content_position

          assign text_alignment_class = 'image-banner__inner--text-' | append: section.settings.text_alignment
        %}

        <div class="image-banner__inner-wrapper {{ content_position_class }}">
          <div
            class="
              image-banner__inner
              {% if section.settings.full_width %}
                image-banner__inner--full-width
              {% endif %}
              banner-height--{{ section.settings.height_mobile }}
              banner-height--{{ section.settings.height }}
              {{ text_alignment_class }}
            "
          >
            <span
              class="image-banner__inner-background"
            ></span>

            {% if section.settings.heading != blank %}
              <h2
                class="
                  {{ section.settings.header_size }}
                  {{ section.settings.header_size_mobile }}
                  image-banner__inner-heading
                  {{ title_style }}
                  {{ animate_class }}
                "
              >
                {{ section.settings.heading }}
              </h2>
            {% endif %}

            {% if section.settings.subheading != blank %}
              <div
                class="
                  image-banner__inner-text
                  {{ section.settings.subheading_size }}
                  {{ animate_class }}
                "
                data-animate-delay="200"
              >
                {{ section.settings.subheading }}
              </div>
            {% endif %}

            {% if section.settings.link != blank %}
              <a
                href="{{ section.settings.link }}"
                class="
                  link
                  link-with-icon
                  image-banner__inner-link
                  {{ animate_class }}
                  {{ section.settings.button_color_scheme }}
                "
                data-animate-delay="400"
              >
                {{- section.settings.link_text }}
                {% render 'icon-arrow' %}
              </a>
            {% endif %}
          </div>
        </div>

        {% if section.settings.side_text != blank %}
          {% if section.settings.side_text_position == 'right' %}
            {% assign side_text_position = 'image-banner__side-text-wrapper--right' %}
          {% endif %}

          <span class="image-banner__side-text-wrapper {{ side_text_position }}">
            <span
              class="image-banner__side-text-dash"
            ></span>
            <span class="image-banner__side-text p p-m--small">
              {{- section.settings.side_text -}}
            </span>
          </span>
        {% endif %}
      </div>
    </div>
  </div>
  {% unless section.settings.full_width %}
    </div>
  {% endunless %}
</div>

{% schema %}
{
  "name": "t:sections.image-banner.name",
  "tag": "section",
  "settings": [
    {
      "type": "select",
      "id": "height",
      "options": [
        {
          "value": "small",
          "label": "t:sections.image-banner.settings.banner_height.options_1.label"
        },
        {
          "value": "medium",
          "label": "t:sections.image-banner.settings.banner_height.options_2.label"
        },
        {
          "value": "large",
          "label": "t:sections.image-banner.settings.banner_height.options_3.label"
        },
        {
          "value": "custom-desktop",
          "label": "t:sections.image-banner.settings.banner_height.options_4.label"
        }
      ],
      "default": "large",
      "label": "t:sections.image-banner.settings.banner_height.label",
      "info": "t:sections.image-banner.settings.banner_height.info"
    },
    {
      "type": "number",
      "id": "height_custom",
      "default": 820,
      "label": "t:sections.image-banner.settings.banner_height.custom_desktop.label",
      "visible_if": "{{ section.settings.height == 'custom-desktop' }}"
    },
    {
      "type": "select",
      "id": "height_mobile",
      "options": [
        {
          "value": "small-mobile",
          "label": "t:sections.image-banner.settings.banner_height.options_1.label"
        },
        {
          "value": "medium-mobile",
          "label": "t:sections.image-banner.settings.banner_height.options_2.label"
        },
        {
          "value": "large-mobile",
          "label": "t:sections.image-banner.settings.banner_height.options_3.label"
        },
        {
          "value": "custom-mobile",
          "label": "t:sections.image-banner.settings.banner_height.options_4.label"
        }
      ],
      "default": "large-mobile",
      "info": "t:sections.image-banner.settings.banner_height.info",
      "label": "t:sections.image-banner.settings.banner_height.label_mobile"
    },
    {
      "type": "number",
      "id": "height_mobile_custom",
      "default": 760,
      "label": "t:sections.image-banner.settings.banner_height.custom_mobile.label",
      "visible_if": "{{ section.settings.height_mobile == 'custom-mobile' }}"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "background-1"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "t:sections.all.full_width.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_border_bottom",
      "label": "t:sections.all.border.show_border_bottom.label",
      "default": false
    },
    {
      "type": "select",
      "id": "border_radius",
      "options": [
        {
          "value": "image-border-radius--none",
          "label": "t:sections.all.radius.none.label"
        },
        {
          "value": "image-border-radius--rounded-xxs",
          "label": "t:sections.all.radius.xxs.label"
        },
        {
          "value": "image-border-radius--rounded-xs",
          "label": "t:sections.all.radius.xs.label"
        },
        {
          "value": "image-border-radius--rounded-small",
          "label": "t:sections.all.radius.small.label"
        },
        {
          "value": "image-border-radius--rounded",
          "label": "t:sections.all.radius.standard.label"
        }
      ],
      "default": "image-border-radius--none",
      "label": "t:sections.all.radius.label"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.image-banner.settings.image.label",
      "info": "t:sections.all.images_tips.landscape_big.info"
    },
    {
      "type": "video",
      "id": "video",
      "label": "t:sections.all.videos_tips.general.label",
      "info": "t:sections.all.videos_tips.landscape.info"
    },
    {
      "type": "checkbox",
      "id": "delay_loader",
      "label": "t:settings_schema.global.video.delay_loader.label",
      "info": "t:settings_schema.global.video.delay_loader.info",
      "default": false,
      "visible_if": "{{ section.settings.video }}"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "t:sections.image-banner.settings.mobile_image.label",
      "info": "t:sections.all.images_tips.portrait_medium.info"
    },
    {
      "type": "header",
      "content": "t:sections.image-banner.settings.content_header.content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.image-banner.settings.heading.label",
      "default": "Add Image heading"
    },
    {
      "type": "select",
      "id": "title_style",
      "label": "t:sections.all.text.style.label",
      "options": [
        {
          "value": "normal",
          "label": "t:sections.all.text.style.option_1"
        },
        {
          "value": "uppercase",
          "label": "t:sections.all.text.style.option_2"
        }
      ],
      "default": "normal"
    },
    {
      "type": "select",
      "id": "header_size",
      "options": [
        {
          "value": "h3",
          "label": "t:sections.all.heading_size.options_0.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options_1.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options_2.label"
        },
        {
          "value": "d3",
          "label": "t:sections.all.heading_size.options_3.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.all.heading_size.heading.label"
    },
    {
      "type": "select",
      "id": "header_size_mobile",
      "options": [
        {
          "value": "h3-mobile",
          "label": "t:sections.all.heading_size.options_0.label"
        },
        {
          "value": "h2-mobile",
          "label": "t:sections.all.heading_size.options_1.label"
        },
        {
          "value": "h1-mobile",
          "label": "t:sections.all.heading_size.options_2.label"
        },
        {
          "value": "h0-mobile",
          "label": "t:sections.all.heading_size.options_3.label"
        },
        {
          "value": "d3-mobile",
          "label": "t:sections.all.heading_size.options_4.label"
        },
        {
          "value": "d2-mobile",
          "label": "t:sections.all.heading_size.options_5.label"
        }
      ],
      "default": "d3-mobile",
      "label": "t:sections.all.heading_size.heading_mobile.label"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "t:sections.image-banner.settings.subheading.label",
      "default": "<p>Give customers details about the banner image(s) or content on the template.</p>"
    },
    {
      "type": "select",
      "id": "subheading_size",
      "options": [
        {
          "value": "p",
          "label": "t:sections.all.heading_size.options_1.label"
        },
        {
          "value": "p-large",
          "label": "t:sections.all.heading_size.options_2.label"
        }
      ],
      "default": "p",
      "label": "t:sections.all.heading_size.subheading.label"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "options": [
        {
          "value": "left",
          "label": "t:sections.image-banner.settings.text_alignment.option_1"
        },
        {
          "value": "center",
          "label": "t:sections.image-banner.settings.text_alignment.option_2"
        },
        {
          "value": "right",
          "label": "t:sections.image-banner.settings.text_alignment.option_3"
        }
      ],
      "default": "left",
      "label": "t:sections.image-banner.settings.text_alignment.label"
    },
    {
      "type": "select",
      "id": "content_position",
      "options": [
        {
          "value": "top-left",
          "label": "t:sections.image-banner.settings.banner_content_position.option_1"
        },
        {
          "value": "left",
          "label": "t:sections.image-banner.settings.banner_content_position.option_2"
        },
        {
          "value": "bottom-left",
          "label": "t:sections.image-banner.settings.banner_content_position.option_3"
        },
        {
          "value": "top-center",
          "label": "t:sections.image-banner.settings.banner_content_position.option_4"
        },
        {
          "value": "center",
          "label": "t:sections.image-banner.settings.banner_content_position.option_5"
        },
        {
          "value": "bottom-center",
          "label": "t:sections.image-banner.settings.banner_content_position.option_6"
        },
        {
          "value": "top-right",
          "label": "t:sections.image-banner.settings.banner_content_position.option_7"
        },
        {
          "value": "right",
          "label": "t:sections.image-banner.settings.banner_content_position.option_8"
        },
        {
          "value": "bottom-right",
          "label": "t:sections.image-banner.settings.banner_content_position.option_9"
        }
      ],
      "default": "left",
      "label": "t:sections.image-banner.settings.banner_content_position.label"
    },
    {
      "type": "checkbox",
      "id": "show_gradient",
      "label": "t:sections.image-banner.settings.show_gradient.label",
      "default": false,
      "visible_if": "{{ section.settings.content_position contains 'bottom' or section.settings.content_position contains 'top' }}"
    },
    {
      "type": "url",
      "id": "link",
      "label": "t:sections.image-banner.settings.banner_link.label",
      "default": "/"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "t:sections.image-banner.settings.banner_link_text.label",
      "default": "Explore now"
    },
    {
      "type": "select",
      "id": "button_color_scheme",
      "options": [
        {
          "value": "button",
          "label": "t:sections.all.buttons.primary.label"
        },
        {
          "value": "button button--secondary",
          "label": "t:sections.all.buttons.secondary.label"
        },
        {
          "value": "link link-with-icon",
          "label": "t:sections.all.buttons.text_link.label"
        }
      ],
      "default": "button",
      "label": "t:sections.all.buttons.label"
    },
    {
      "type": "text",
      "id": "side_text",
      "label": "t:sections.image-banner.settings.banner_side_text.label"
    },
    {
      "type": "select",
      "id": "side_text_position",
      "options": [
        {
          "value": "left",
          "label": "t:sections.image-banner.settings.banner_side_text_position.option_1"
        },
        {
          "value": "right",
          "label": "t:sections.image-banner.settings.banner_side_text_position.option_2"
        }
      ],
      "default": "left",
      "label": "t:sections.image-banner.settings.banner_side_text_position.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.margin.desktop_margin_header"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.margin.margin_bottom",
      "default": 120
    },
    {
      "type": "header",
      "content": "t:sections.all.margin.mobile_margin_header"
    },
    {
      "type": "range",
      "id": "mobile_margin_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.margin.mobile_margin_bottom",
      "default": 60
    },
    {
      "type": "header",
      "content": "t:sections.all.animations.section_animation.header",
      "visible_if": "{{ settings.enable_global_animations }}"
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "t:sections.all.animations.section_animation.label",
      "default": true,
      "visible_if": "{{ settings.enable_global_animations }}"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "presets": [
    {
      "name": "t:sections.image-banner.presets.name",
      "category": "t:categories.banners"
    }
  ]
}
{% endschema %}
