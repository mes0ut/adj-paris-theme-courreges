{{ 'customer.css' | asset_url | stylesheet_tag }}
{{ 'section-main-account.css' | asset_url | stylesheet_tag }}

<div class="page-width">
  <div class="main-account__intro">
    <h3 class="customer__title h3 main-account__intro-heading">
      {{ section.settings.account_greeting }}
      {{ customer.name }}
    </h3>
    {% if section.settings.account_intro != empty %}
      <h6 class="main-account__intro-text p-large">
        {{ section.settings.account_intro }}
      </h6>
    {% endif %}
  </div>

  <div class="main-account__inner">
    {% render 'side-menu',
      ref: 'standard_links',
      background: settings.account_side_menu_background_color
    %}
    <div class="main-account__main">
      <h5 class="main-account__main-heading">
        {{ section.settings.account_details_heading }}
      </h5>
      <div class="main-account__details">
        {% paginate customer.orders by 10 %}
          <div
            id="orders"
            class="
              main-account__details-order-list
              {% if paginate.current_page != 1 %}show-orders{% endif %}
            "
          >
            {%- if customer.orders.size > 0 -%}
              <table role="table" class="order-history">
                <caption class="visually-hidden">
                  {{ 'customer.orders.title' | t }}
                </caption>
                <thead role="rowgroup">
                  <tr role="row">
                    <th
                      class="p"
                      id="ColumnOrder"
                      scope="col"
                      role="columnheader"
                    >
                      {{ 'customer.orders.order_number' | t }}
                    </th>
                    <th
                      class="p"
                      id="ColumnDate"
                      scope="col"
                      role="columnheader"
                    >
                      {{ 'customer.orders.date' | t }}
                    </th>
                    <th
                      class="p"
                      id="ColumnPayment"
                      scope="col"
                      role="columnheader"
                    >
                      {{ 'customer.orders.payment_status' | t }}
                    </th>
                    <th
                      class="p"
                      id="ColumnFulfillment"
                      scope="col"
                      role="columnheader"
                    >
                      {{ 'customer.orders.fulfillment_status' | t }}
                    </th>
                    <th
                      class="p"
                      id="ColumnTotal"
                      scope="col"
                      role="columnheader"
                    >
                      {{ 'customer.orders.total' | t }}
                    </th>
                  </tr>
                </thead>
                <tbody role="rowgroup">
                  {%- for order in customer.orders -%}
                    <tr role="row">
                      <td
                        class="p"
                        id="RowOrder"
                        role="cell"
                        headers="ColumnOrder"
                        data-label="{{ 'customer.orders.order_number' | t }}"
                      >
                        <a
                          class="link p"
                          href="{{ order.customer_url }}"
                          aria-label="{{ 'customer.orders.order_number_link' | t: number: order.name }}"
                        >
                          {{ order.name }}
                        </a>
                      </td>
                      <td
                        class="p"
                        headers="RowOrder ColumnDate"
                        role="cell"
                        data-label="{{ 'customer.orders.date' | t }}"
                      >
                        {{ order.created_at | time_tag: format: 'date' }}
                      </td>
                      <td
                        class="p"
                        headers="RowOrder ColumnPayment"
                        role="cell"
                        data-label="{{ 'customer.orders.payment_status' | t }}"
                      >
                        {{ order.financial_status_label }}
                      </td>
                      <td
                        class="p"
                        headers="RowOrder ColumnFulfillment"
                        role="cell"
                        data-label="{{ 'customer.orders.fulfillment_status' | t }}"
                      >
                        {{ order.fulfillment_status_label }}
                      </td>
                      <td
                        class="p"
                        headers="RowOrder ColumnTotal"
                        role="cell"
                        data-label="{{ 'customer.orders.total' | t }}"
                      >
                        {{ order.total_price | money_with_currency }}
                      </td>
                    </tr>
                  {%- endfor -%}
                </tbody>
              </table>
            {%- else -%}
              <p>
                {{ 'customer.orders.none' | t }}
              </p>
            {%- endif -%}

            {%- if paginate.pages > 1 -%}
              {% render 'pagination', paginate: paginate, anchor: '#orders' %}
            {%- endif -%}
          </div>
        {% endpaginate %}

        <div class="main-account__details-order" id="last-order">
          <h6 class="main-account__details-order-heading p-large">
            Last Order
          </h6>
          {% if customer.last_order != blank %}
            {% assign last_order = customer.last_order %}
            <div class="main-account__details-order-unit">
              <h6 class="p main-account__details-order-subheading">
                {{ 'customer.orders.order_number' | t }}
              </h6>
              <span class="p">
                {{ last_order.name }}
              </span>
            </div>

            <div class="main-account__details-orders-unit">
              <h6 class="p main-account__details-order-subheading p-large">
                {{ 'customer.orders.date' | t }}
              </h6>
              <span class="p">
                {{ last_order.created_at | date: '%b %d, %y' }}
              </span>
            </div>

            <div class="main-account__details-orders-unit">
              <h6 class="p main-account__details-order-subheading p-large">
                {{ 'customer.orders.payment_status' | t }}
              </h6>
              <span class="p">
                {{ last_order.financial_status | capitalize }}
              </span>
            </div>

            <div class="main-account__details-orders-unit">
              <h6 class="p main-account__details-order-subheading p-large">
                {{ 'customer.orders.fulfillment_status' | t }}
              </h6>
              <span class="p">
                {{ last_order.fulfillment_status | capitalize }}
              </span>
            </div>

            <div class="main-account__details-orders-unit">
              <h6 class="p main-account__details-order-subheading p-large">
                {{ 'customer.orders.total' | t }}
              </h6>
              <span class="p">
                {{ last_order.total_price | money_with_currency }}
              </span>
            </div>

            <a
              class="button button--secondary button-with-icon main-account__details-order-btn"
              href="{{ customer.last_order.customer_url }}"
            >
              {{ 'customer.account.view_order' | t }}
              {% render 'icon-arrow' %}
            </a>
          {%- else -%}
            <p>{{ 'customer.orders.none' | t }}</p>
          {% endif %}
        </div>

        <div class="main-account__details-addresses" id="addresses">
          <h6 class="main-account__details-addresses-heading p-large">
            Address Details
          </h6>
          {% if customer.addresses_count > 0 %}
            <div class="main-account__details-addresses-unit">
              {{ customer.default_address | format_address }}
            </div>

            <a
              class="button button--secondary button-with-icon main-account__details-addresses-btn"
              href="{{ routes.account_addresses_url }}"
            >
              {{ 'customer.account.view_addresses' | t }} (
              {{- customer.addresses_count -}}
              )
              {% render 'icon-arrow' %}
            </a>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-account.name",
  "settings": [
    {
      "type": "text",
      "id": "account_greeting",
      "label": "t:sections.main-account.settings.greeting.label",
      "default": "Hi"
    },
    {
      "type": "textarea",
      "id": "account_intro",
      "label": "t:sections.main-account.settings.introduction.label"
    },
    {
      "type": "text",
      "id": "account_details_heading",
      "label": "t:sections.main-account.settings.details_heading.label",
      "default": "Account Overview"
    }
  ]
}
{% endschema %}
