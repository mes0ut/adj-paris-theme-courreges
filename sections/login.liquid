{{ 'customer.css' | asset_url | stylesheet_tag }}

{%- if section.settings.enable_shop_login_button == false -%}
  {%- assign hide_shop_login_button = true -%}
{%- endif -%}

<div class="customer__wrapper">
  {% if section.settings.image %}
    {% if section.settings.icon_toggle == true %}
      <div class="customer__image-icon">
        {% render 'icon-star-cluster-two' %}
      </div>
    {% endif %}
    <div
      class="
        image-aspect-ratio
        image-aspect-ratio--6-9
        customer__image
        {{ section.settings.image_style }}
      "
    >
      {% assign image_height = section.settings.image.width
        | divided_by: section.settings.image.aspect_ratio
        | ceil
      %}

      {{
        section.settings.image
        | image_url: width: 1280
        | image_tag:
          loading: 'eager',
          width: 640,
          height: image_height,
          sizes: '(min-width: 1200px) calc((1200px - 10rem) / 2), (min-width: 750px) calc((100vw - 11.5rem) / 2), calc(80vw - 4rem)',
          widths: '940, 1100, 1500, 1780, 2000, 2800',
          alt: section.settings.image.alt
        | escape
      }}
    </div>
  {% endif %}

  <div class="customer customer--login">
    {% comment %} Password recovery form {% endcomment %}
    <h1 class="form__heading" id="recover" tabindex="-1">
      {{ 'customer.login_page.forgot_password' | t }}
    </h1>
    <div>
      {%- form 'recover_customer_password', class: 'customer__reset' -%}
        <ul class="alert-list">
          {%- if form.errors -%}
            {%- for field in form.errors -%}
              <li>
                <span id="RecoverEmail-email-error" class="alert">
                  {% render 'icon-error' %}
                  {{ form.errors.messages.form }}
                </span>
              </li>
            {%- endfor -%}
          {%- endif -%}
        </ul>

        {% assign recover_success = form.posted_successfully? %}
        <div class="form__field">
          <label class="form__label" for="RecoverEmail">
            {{ 'customer.login_page.email' | t }}
          </label>
          <input
            type="email"
            class="field__input"
            value=""
            name="email"
            id="RecoverEmail"
            autocorrect="off"
            autocapitalize="off"
            autocomplete="email"
            {% if form.errors %}
              aria-invalid="true"
              aria-describedby="RecoverEmail-email-error"
              autofocus
            {% endif %}
          >
        </div>

        <button class="button button-with-icon">
          {{ 'customer.login_page.forgot_password' | t }}
          {% render 'icon-arrow' %}
        </button>

        <div>
          <a class="customer__form-link link" href="#login">
            {{ 'customer.login_page.login_back' | t }}
          </a>
        </div>
      {%- endform -%}
    </div>

    {% comment %} Login form {% endcomment %}
    <h1 class="form__heading" id="login" tabindex="-1">
      {{ 'customer.login_page.title' | t }}
    </h1>
    <div>
      {%- if recover_success == true -%}
        <h6 class="alert-message p" tabindex="-1" autofocus>
          {% render 'icon-error' %}
          {{ 'customer.recover_password.success' | t }}
        </h6>
      {%- endif -%}
      {%- form 'customer_login', novalidate: 'novalidate' -%}
        {%- if form.errors -%}
          <h6
            class="alert-message p"
            tabindex="-1"
            autofocus
          >
            <span class="visually-hidden">
              {{- 'accessibility.error' | t }}
            </span>
            <svg
              aria-hidden="true"
              focusable="false"
              role="presentation"
              viewBox="0 0 13 13"
            >
              <circle cx="6.5" cy="6.50049" r="5.5" stroke="white" stroke-width="2"/>
              <circle cx="6.5" cy="6.5" r="5.5" fill="{{ settings.colors_error_form }}" stroke="{{ settings.colors_error_form }}" stroke-width="0.7"/>
              <path d="M5.87413 3.52832L5.97439 7.57216H7.02713L7.12739 3.52832H5.87413ZM6.50076 9.66091C6.88091 9.66091 7.18169 9.37267 7.18169 9.00504C7.18169 8.63742 6.88091 8.34917 6.50076 8.34917C6.12061 8.34917 5.81982 8.63742 5.81982 9.00504C5.81982 9.37267 6.12061 9.66091 6.50076 9.66091Z" fill="white"/>
              <path d="M5.87413 3.17832H5.51535L5.52424 3.537L5.6245 7.58083L5.63296 7.92216H5.97439H7.02713H7.36856L7.37702 7.58083L7.47728 3.537L7.48617 3.17832H7.12739H5.87413ZM6.50076 10.0109C7.06121 10.0109 7.5317 9.57872 7.5317 9.00504C7.5317 8.43137 7.06121 7.99918 6.50076 7.99918C5.94031 7.99918 5.46982 8.43137 5.46982 9.00504C5.46982 9.57872 5.94031 10.0109 6.50076 10.0109Z" fill="white" stroke="{{ settings.colors_error_form }}" stroke-width="0.7">
            </svg>
            {{ 'templates.contact.form.error_heading' | t }}
          </h6>
          <ul class="alert-list">
            {%- for field in form.errors -%}
              <li>
                {%- if field == 'form' -%}
                  <span class="alert">
                    {% render 'icon-error' %}
                    <span>
                      {{ form.errors.messages[field] }}
                    </span>
                  </span>
                {%- else -%}
                  <a
                    href="#RegisterForm-{{ field }}"
                    class="alert"
                  >
                    {% render 'icon-error' %}
                    <span>
                      {{ form.errors.translated_fields[field] | capitalize }}
                      {{ form.errors.messages[field] }}
                    </span>
                  </a>
                {%- endif -%}
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- if shop.features.login_with_shop_classic_customer_accounts? -%}
          <section name="sign-in-with-shop-provider">
            {{ shop | login_button: hide_button: hide_shop_login_button }}

            {%- unless hide_shop_login_button -%}
              <p>
                {{ 'customer.login_page.alternate_provider_separator' | t }}
              </p>
            {%- endunless -%}
          </section>
        {%- endif -%}

        <div class="form__field">
          <label class="form__label" for="CustomerEmail">
            {{ 'customer.login_page.email' | t }}
          </label>
          <input
            class="field__input"
            type="email"
            name="customer[email]"
            id="CustomerEmail"
            autocomplete="email"
            autocorrect="off"
            autocapitalize="off"
            {% if form.errors contains 'form' %}
              aria-invalid="true"
            {% endif %}
          >
        </div>

        {%- if form.password_needed -%}
          <div class="form__field">
            <div class="form__label-wrapper">
              <label class="form__label" for="CustomerPassword">
                {{ 'customer.login_page.password' | t }}
              </label>
              <a class="customer__form-link link" href="#recover">
                {{ 'customer.login_page.forgot_password' | t }}
              </a>
            </div>
            <input
              class="field__input"
              type="password"
              value=""
              name="customer[password]"
              id="CustomerPassword"
              autocomplete="current-password"
              {% if form.errors contains 'form' %}
                aria-invalid="true"
              {% endif %}
            >
          </div>

          <button class="button button-with-icon">
            {{ 'customer.login_page.sign_in' | t }}
            {% render 'icon-arrow' %}
          </button>
        {%- endif -%}
      {%- endform -%}

      {%- if shop.features.login_with_shop_classic_customer_accounts? -%}
        <section name="sign-in-with-shop-provider">
          {{ shop | login_button: hide_button: hide_shop_login_button }}

          {%- unless hide_shop_login_button -%}
            <p>
              {{ 'customer.login_page.alternate_provider_separator' | t }}
            </p>
          {%- endunless -%}
        </section>
      {%- endif -%}

      <div class="customer__new-account">
        <h5>{{ 'customer.login_page.create_account_question' | t }}</h5>
        <a
          href="{{ routes.account_register_url }}"
          class="button button--secondary button-with-icon"
        >
          {{ 'customer.login_page.create_account' | t }}
          {% render 'icon-arrow' %}
        </a>
      </div>
      {%- if shop.checkout.guest_login -%}
        <div>
          <hr>
          <h2>{{ 'customer.login_page.guest_title' | t }}</h2>

          {%- form 'guest_login' -%}
            <button>
              {{ 'customer.login_page.guest_continue' | t }}
            </button>
          {%- endform -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.login.name",
  "tag": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_shop_login_button",
      "label": "t:sections.login.settings.shop_login_button.enable",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.login.settings.image.label",
      "info": "t:sections.all.images_tips.portrait_big.info"
    },
    {
      "type": "select",
      "id": "image_style",
      "options": [
        {
          "value": "image-border-radius--none",
          "label": "t:sections.all.radius.none.label"
        },
        {
          "value": "image-border-radius--rounded-xxs",
          "label": "t:sections.all.radius.xxs.label"
        },
        {
          "value": "image-border-radius--rounded-xs",
          "label": "t:sections.all.radius.xs.label"
        },
        {
          "value": "image-border-radius--rounded-small",
          "label": "t:sections.all.radius.small.label"
        },
        {
          "value": "image-border-radius--rounded",
          "label": "t:sections.all.radius.standard.label"
        },
        {
          "value": "image-border-radius--rounded-extra",
          "label": "t:sections.all.radius.extra.label"
        },
        {
          "value": "image-border-radius--curved-top",
          "label": "t:sections.all.radius.curved.label"
        }
      ],
      "default": "image-border-radius--none",
      "label": "t:sections.all.radius.label"
    },
    {
      "type": "checkbox",
      "id": "icon_toggle",
      "label": "t:sections.login.settings.checkbox-1.label"
    }
  ]
}
{% endschema %}
