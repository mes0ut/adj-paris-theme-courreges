{% liquid
  render 'css-delay', css_file: 'section-feed-social.css'
  render 'css-delay', css_file: 'component-marquee.css'
  render 'css-delay', css_file: 'component-social-feed-popup.css', force_delay: true
  render 'section-spacing', id: section.id
%}

{%- style -%}
  {% if request.design_mode %}
    .section-{{ section.id }} .marquee__text {
      animation-name: none !important;
    }

    .section-{{ section.id }} .marquee__align {
      overflow: scroll;
      width: 100%;
      transform: none;
      margin-top: -4rem;
    }

    .section-{{ section.id }} .marquee__text {
      justify-content: flex-start;
      padding-left: 3rem;
      padding-top: 4rem;
    }

    @media screen and (max-width: 750px) {
      .section-{{ section.id }} .marquee__text {
        padding-left: 1.8rem;
      }
    }
  {% endif %}
{%- endstyle -%}

{% liquid
  if section.settings.enable_animation
    assign animate_class = 'animate'
  else
    assign animate_class = ''
  endif

  assign direction = section.settings.direction
  if direction == 'forward'
    assign direction = 'marquee__text--forwards'
  endif

  if request.design_mode
    assign loop_count = 1
  else
    assign loop_count = 3
  endif
%}

{%- capture blocks_markup -%}
  {% if section.blocks.size > 0 %}
    {% for block in section.blocks %}
      {% if block.type == 'post' or block.type == 'review' %}
        {% liquid
          assign username = ''
          assign avatar = ''
          assign handle = ''
        %}
        <modal-opener
          {% if section.settings.layout == 'carousel' %}
            class="social-feed__post-wrapper social-feed__post-wrapper--{{ section.settings.card_size }} embla__slide"
          {% endif %}
          data-modal="#PopupModal-{{ section.id }}"
        >
          <div
            class="
              social-feed__post
              social-feed__post--{{ section.settings.card_size }}
              {% if section.settings.show_card_images == false %}
                social-feed__post--no-popup
              {% else %}
                {{ section.settings.border_radius }}
              {% endif %}
            "
            id="ModalOpenerBtn-{{ block.id }}"
            data-post-id="post-{{ forloop.index0 }}"
            aria-haspopup="dialog"
            {{ block.shopify_attributes }}
          >
            <div class="social-feed__post-media-wrapper">
              {% if section.settings.show_card_images %}
                {% if block.settings.post_image != blank %}
                  {{
                    block.settings.post_image
                    | image_url: width: 600
                    | image_tag:
                      loading: 'lazy',
                      width: block.settings.post_image.width,
                      height: '600 | divided_by: block.settings.post_image.aspect_ratio | ceil',
                      sizes: '(min-width: 1100px) 535px, (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)',
                      widths: '360, 533, 720, 940',
                      class: 'social-feed__post-image',
                      alt: block.settings.post_image.alt
                    | escape
                  }}
                {% elsif block.settings.post_video != blank %}
                  {% render 'video-delay-loader',
                    video_data: block.settings.post_video,
                    image_size: '600x',
                    class_name: 'social-feed__post-video js-autoplay',
                    autoplay: true,
                    loop: true,
                    controls: false,
                    delay_loader: section.settings.delay_loader
                  %}
                  <div class="social-feed__post-video-play">
                    {% render 'icon-play' %}
                  </div>
                {% else %}
                  {{
                    'image'
                    | placeholder_svg_tag: 'social-feed__post-image'
                  }}
                {% endif %}
              {% endif %}

              {% assign avatar = block.settings.post_profile_image %}
              {% if avatar != blank %}
                <div class="social-feed__post-avatar-wrapper">
                  {% assign avatar_class = 'social-feed__post-avatar color-'
                    | append: section.settings.card_color_scheme
                  %}
                  {{
                    avatar
                    | image_url: width: 160
                    | image_tag:
                      loading: 'lazy',
                      width: avatar.width,
                      height: avatar.height,
                      sizes: '160px',
                      widths: '160',
                      class: avatar_class,
                      alt: avatar.alt
                    | escape
                  }}
                </div>
              {% endif %}
            </div>
            <div
              class="
                social-feed__post-content
                color-{{ section.settings.card_color_scheme }}
                {% if section.settings.show_card_images == false %}
                  {{ section.settings.border_radius }}
                {% endif %}
              "
            >
              {% assign username = block.settings.post_profile_username %}
              <h5 class="social-feed__post-content-username {{ section.settings.card_title_style }}">
                {% if username != blank %}
                  {%- liquid
                    if block.settings.cards_username_icon == 'instagram'
                      render 'icon-instagram', color: section.settings.icon_instagram_color
                    elsif block.settings.cards_username_icon == 'twitter'
                      render 'icon-twitter', color: section.settings.icon_twitter_color
                    endif
                  -%}

                  <span>{{- username -}}</span>
                {% endif %}
              </h5>

              {% assign handle = block.settings.post_profile_handle %}
              {% if handle != blank %}
                <p class="social-feed__post-content-handle">
                  {{ handle }}
                </p>
              {% endif %}

              {% if block.settings.post_caption != blank %}
                <div class="social-feed__post-content-caption">
                  {{ block.settings.post_caption }}
                </div>
              {% endif %}

              {% if block.settings.review_rating > 0 %}
                <div class="social-feed__post-content-rating">
                  {%- liquid
                    for i in (1..5)
                      assign star_class = ''
                      if block.settings.review_rating < forloop.index
                        assign star_class = 'icon-star-review--empty'
                      endif
                      render 'icon-star-review', color: section.settings.icon_review_color, class: star_class
                    endfor
                  -%}
                </div>
              {% endif %}
            </div>
          </div>
        </modal-opener>
      {% endif %}
    {% endfor %}
  {% else %}
    {% render 'feed-social-placeholder' %}
  {% endif %}
{%- endcapture -%}

<div
  class="
    social-feed social-feed--{{ section.settings.layout }}
    section-{{ section.id }}
    gradient
    color-{{ section.settings.color_scheme }}
    {% if section.settings.show_border_bottom %}section-border-bottom{% endif %}
  "
>
  {% render 'component-section-header',
    type: 'header',
    animate_class: animate_class,
    profile_image: section.settings.profile_image,
    heading: section.settings.heading,
    title_style: section.settings.title_style,
    subheading: section.settings.subheading,
    show_decorative_icon: section.settings.show_decorative_icon,
    link: section.settings.link,
    link_text: section.settings.link_text,
    button_color_scheme: section.settings.button_color_scheme
  %}

  <div class="social-feed__posts {{ animate_class }}{% if section.settings.layout == 'carousel' %} page-width{% endif %}">
    {%- if section.settings.layout == 'marquee' -%}
      <div class="marquee__align">
        {% for i in (1..loop_count) %}
          <div
            style="animation-duration: {{ 110 | minus: section.settings.speed }}s"
            class="marquee__text {{ direction }}"
          >
            {{ blocks_markup }}
          </div>
        {% endfor %}
      </div>
    {%- else -%}
      <embla-component class="embla-carousel">
        <div
          class="embla"
          data-align="start"
          data-slides-to-scroll="1"
          data-duration="20"
        >
          <div class="embla__viewport">
            <ul class="embla__container">
              {{ blocks_markup }}
            </ul>
            <button
              class="embla__button embla__button--prev"
              disabled=""
              aria-label="{{ 'general.pagination.previous' | t }}"
            >
              {% render 'icon-arrow-left-large' %}
            </button>
            <span class="embla__button-gradient"></span>
            <button
              class="embla__button embla__button--next"
              disabled=""
              aria-label="{{ 'general.pagination.next' | t }}"
            >
              {% render 'icon-arrow-right-large' %}
            </button>
            <span class="embla__button-gradient"></span>
          </div>
        </div>
      </embla-component>
    {%- endif -%}
  </div>

  {% render 'component-section-header',
    type: 'footer',
    animate_class: animate_class,
    link: section.settings.link,
    link_text: section.settings.link_text,
    button_color_scheme: section.settings.button_color_scheme
  %}
</div>

{% if section.settings.show_card_images %}
  <social-feed-popup
    id="PopupModal-{{ section.id }}"
    class="
      modal
      product-popup-modal
      social-feed-popup
      social-feed-popup--{{ section.settings.post_card_media }}
      color-{{ section.settings.modal_color_scheme }}
    "
  >
    <div
      role="dialog"
      class="modal__content sm-feed-popup__card"
      aria-label="{{ section.settings.title }}"
      aria-modal="true"
      tabindex="-1"
    >
      {% for innerblock in section.blocks %}
        {% if innerblock.type == 'post' or innerblock.type == 'review' %}
          {% liquid
            assign username = ''
            assign avatar = ''
            assign handle = ''
            assign products_exist = false

            if innerblock.settings.product_1 != blank or innerblock.settings.product_2 != blank or innerblock.settings.product_3 != blank
              assign products_exist = true
            endif
          %}
          <div
            class="sm-feed-popup__post "
            data-post-id="post-{{ forloop.index0 }}"
            style="display: none"
          >
            <div class="sm-feed-popup__post-media-wrapper">
              {% if innerblock.settings.post_image != blank %}
                {{
                  innerblock.settings.post_image
                  | image_url: width: 800
                  | image_tag:
                    loading: 'lazy',
                    width: innerblock.settings.post_image.width,
                    height: '800 | divided_by: block.settings.post_image.aspect_ratio | ceil',
                    sizes: '(min-width: 1100px) 535px, (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)',
                    widths: '360, 533, 720, 940',
                    class: 'sm-feed-popup__post-image',
                    alt: innerblock.settings.post_image.alt
                  | escape
                }}
              {% elsif innerblock.settings.post_video != blank %}
                {% render 'video-delay-loader',
                  video_data: innerblock.settings.post_video,
                  image_size: '600x',
                  class_name: 'sm-feed-popup__post-video js-autoplay',
                  autoplay: true,
                  loop: true,
                  controls: false,
                  delay_loader: true
                %}
              {% else %}
                {{ 'image' | placeholder_svg_tag: 'sm-feed-popup__post-svg' }}
              {% endif %}
            </div>
            <div class="sm-feed-popup__post-content-outer">
              <div class="sm-feed-popup__post-content-wrapper {% if products_exist %}sm-feed-popup__post-content-wrapper--extra-content{% endif %}">
                <div
                  id="ModalClose-{{ section.id }}-{{ forloop.index0 }}"
                  class="sm-feed-popup__post-content-close"
                >
                  {% render 'icon-close' %}
                </div>
                <div class="sm-feed-popup-content">
                  {% assign avatar = innerblock.settings.post_profile_image %}
                  <div class="sm-feed-popup-header {% if avatar == blank %}sm-feed-popup-header--avatar-empty{% endif %}">
                    {% if forloop.first == false %}
                      <div class="sm-feed-popup__post-content-left-arrow js-sm-feed-popup-left-arrow">
                        {% render 'icon-arrow-left-large' %}
                      </div>
                    {% endif %}
                    {% if forloop.last == false %}
                      <div class="sm-feed-popup__post-content-right-arrow js-sm-feed-popup-right-arrow">
                        {% render 'icon-arrow-right-large' %}
                      </div>
                    {% endif %}
                    {% if avatar != blank %}
                      <div class="sm-feed-popup__post-avatar-wrapper">
                        {{
                          avatar
                          | image_url: width: 160
                          | image_tag:
                            loading: 'lazy',
                            width: avatar.width,
                            height: avatar.height,
                            sizes: '160px',
                            widths: '160',
                            class: 'sm-feed-popup__post-avatar',
                            alt: avatar.alt
                          | escape
                        }}
                      </div>
                    {% endif %}

                    {% assign usernameInner = innerblock.settings.post_profile_username %}
                    {% if usernameInner != blank %}
                      <h5 class="sm-feed-popup__post-content-username">
                        {%- liquid
                          if innerblock.settings.cards_username_icon == 'instagram'
                            render 'icon-instagram', color: section.settings.icon_instagram_color
                          elsif innerblock.settings.cards_username_icon == 'twitter'
                            render 'icon-twitter', color: section.settings.icon_twitter_color
                          endif
                        -%}

                        <span>{{ usernameInner }}</span>
                      </h5>
                    {% endif %}

                    {% assign handleInner = innerblock.settings.post_profile_handle %}
                    {% if handle != blank %}
                      <p class="sm-feed-popup__post-content-handle">
                        {{ handleInner }}
                      </p>
                    {% endif %}
                  </div>

                  {% if innerblock.settings.post_caption != blank %}
                    <div class="p-large sm-feed-popup__post-content-caption">
                      {{ innerblock.settings.post_caption }}
                    </div>
                  {% endif %}

                  {% if innerblock.settings.review_rating > 0 %}
                    <div class="sm-feed-popup__post-content-rating color-{{ section.settings.star_icon_color }}">
                      {%- liquid
                        for i in (1..5)
                          assign star_class = ''
                          if innerblock.settings.review_rating < forloop.index
                            assign star_class = 'icon-star-review--empty'
                          endif
                          render 'icon-star-review', color: section.settings.icon_review_color, class: star_class
                        endfor
                      -%}
                    </div>
                  {% endif %}
                </div>

                {% if products_exist %}
                  {% if innerblock.settings.products_header != blank %}
                    <div class="sm-feed-popup__post-content-heading-wrapper">
                      <h5 class="sm-feed-popup__post-content-heading">
                        {{ innerblock.settings.products_header }}
                      </h5>
                      {% if innerblock.settings.show_products_header_icon %}
                        {% render 'icon-star-cluster-one' %}
                      {% endif %}
                    </div>
                  {% endif %}
                  <div class="sm-feed-popup__products">
                    {% liquid
                      if innerblock.settings.product_link_text != blank
                        assign product_link_text = innerblock.settings.product_link_text
                      endif
                    %}

                    {% for i in (1..3) %}
                      {% liquid
                        assign related_product = 'product_' | append: i
                        assign related_product = innerblock.settings[related_product]
                      %}
                      {% if related_product != blank %}
                        <a
                          href="{{ related_product.url }}"
                          class="sm-feed-popup__product link"
                          id="Related-{{ section.id }}-{{ forloop.index }}"
                        >
                          <div class="sm-feed-popup__product-image-wrapper">
                            {{
                              related_product.featured_image
                              | image_url: width: 300
                              | image_tag:
                                loading: 'lazy',
                                width: related_product.featured_image.width,
                                height: related_product.featured_image.height,
                                sizes: '300px',
                                widths: '300',
                                class: 'sm-feed-popup__product-image',
                                alt: related_product.featured_image
                              | escape
                            }}
                          </div>
                          <div class="sm-feed-popup__product-info-wrapper">
                            <p class="sm-feed-popup__product-info-title">
                              {{ related_product.title }}
                            </p>
                            <p class="sm-feed-popup__product-info-price">
                              {{ related_product.price | money }}
                            </p>
                            {% if product_link_text != blank %}
                              <p class="sm-feed-popup__product-info-link">
                                {{ product_link_text }}
                              </p>
                            {% endif %}
                          </div>
                        </a>
                      {% endif %}
                    {% endfor %}
                  </div>
                {% endif %}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}

      {% render 'feed-social-popup-placeholder' %}
    </div>
  </social-feed-popup>
{% endif %}

{% schema %}
{
  "name": "t:sections.feed-social.name",
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "background-3"
    },
    {
      "type": "checkbox",
      "id": "show_border_bottom",
      "label": "t:sections.all.border.show_border_bottom.label",
      "default": false
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.feed-social.settings.heading.label",
      "default": "Heading"
    },
    {
      "type": "select",
      "id": "title_style",
      "label": "t:sections.all.text.style.label",
      "options": [
        {
          "value": "normal",
          "label": "t:sections.all.text.style.option_1"
        },
        {
          "value": "uppercase",
          "label": "t:sections.all.text.style.option_2"
        }
      ],
      "default": "normal"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:sections.feed-social.settings.subheading.label",
      "default": "Subheading"
    },
    {
      "type": "checkbox",
      "id": "show_decorative_icon",
      "label": "t:sections.feed-social.settings.decorative_icon.label"
    },
    {
      "type": "url",
      "id": "link",
      "label": "t:sections.feed-social.settings.link.label"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "t:sections.feed-social.settings.link_text.label",
      "default": "View more"
    },
    {
      "type": "select",
      "id": "button_color_scheme",
      "options": [
        {
          "value": "button",
          "label": "t:sections.all.buttons.primary.label"
        },
        {
          "value": "button button--secondary",
          "label": "t:sections.all.buttons.secondary.label"
        },
        {
          "value": "link link-with-icon",
          "label": "t:sections.all.buttons.text_link.label"
        }
      ],
      "default": "button",
      "label": "t:sections.all.buttons.label"
    },
    {
      "type": "image_picker",
      "id": "profile_image",
      "label": "t:sections.feed-social.settings.profile_image.label"
    },
    {
      "type": "select",
      "id": "border_radius",
      "options": [
        {
          "value": "image-border-radius--none",
          "label": "t:sections.all.radius.none.label"
        },
        {
          "value": "image-border-radius--rounded-xxs",
          "label": "t:sections.all.radius.xxs.label"
        },
        {
          "value": "image-border-radius--rounded-xs",
          "label": "t:sections.all.radius.xs.label"
        },
        {
          "value": "image-border-radius--rounded-small",
          "label": "t:sections.all.radius.small.label"
        },
        {
          "value": "image-border-radius--rounded",
          "label": "t:sections.all.radius.standard.label"
        }
      ],
      "default": "image-border-radius--rounded-small",
      "label": "t:sections.all.radius.label_two"
    },
    {
      "type": "header",
      "content": "t:sections.feed-social.settings.layout.label"
    },
    {
      "type": "select",
      "id": "layout",
      "options": [
        {
          "value": "marquee",
          "label": "t:sections.feed-social.settings.layout.option_1.label"
        },
        {
          "value": "carousel",
          "label": "t:sections.feed-social.settings.layout.option_2.label"
        }
      ],
      "default": "marquee",
      "label": "t:sections.feed-social.settings.layout.label"
    },
    {
      "type": "paragraph",
      "content": "t:sections.feed-social.settings.info",
      "visible_if": "{{ section.settings.layout == 'marquee' }}"
    },
    {
      "type": "header",
      "content": "t:sections.feed-social.settings.marquee.label",
      "visible_if": "{{ section.settings.layout == 'marquee' }}"
    },
    {
      "type": "range",
      "id": "speed",
      "min": 10,
      "max": 100,
      "step": 10,
      "label": "t:sections.feed-social.settings.speed.label",
      "default": 50,
      "visible_if": "{{ section.settings.layout == 'marquee' }}"
    },
    {
      "type": "select",
      "id": "direction",
      "label": "t:sections.marquee.settings.direction.label",
      "options": [
        {
          "value": "forward",
          "label": "Forward"
        },
        {
          "value": "backwards",
          "label": "Backwards"
        }
      ],
      "default": "backwards",
      "visible_if": "{{ section.settings.layout == 'marquee' }}"
    },
    {
      "type": "header",
      "content": "t:sections.feed-social.settings.card_header.content"
    },
    {
      "type": "color_scheme",
      "id": "card_color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "background-1"
    },
    {
      "type": "checkbox",
      "id": "show_card_images",
      "label": "t:sections.feed-social.settings.card_images.label",
      "info": "t:sections.feed-social.settings.card_images.info",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "delay_loader",
      "label": "t:settings_schema.global.video.delay_loader.label",
      "info": "t:settings_schema.global.video.delay_loader.info",
      "default": false,
      "visible_if": "{{ section.settings.show_card_images }}"
    },
    {
      "type": "select",
      "id": "card_size",
      "label": "t:sections.feed-social.settings.card_size.label",
      "info": "t:sections.feed-social.settings.card_size.info",
      "options": [
        {
          "value": "standard",
          "label": "t:sections.feed-social.settings.card_size.option_1.label"
        },
        {
          "value": "large",
          "label": "t:sections.feed-social.settings.card_size.option_2.label"
        }
      ],
      "default": "standard"
    },
    {
      "type": "header",
      "content": "t:sections.all.modal.content",
      "visible_if": "{{ section.settings.show_card_images }}"
    },
    {
      "type": "color_scheme",
      "id": "modal_color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "background-1",
      "visible_if": "{{ section.settings.show_card_images }}"
    },
    {
      "type": "select",
      "id": "card_title_style",
      "label": "t:sections.all.text.style.label",
      "options": [
        {
          "value": "normal",
          "label": "t:sections.all.text.style.option_1"
        },
        {
          "value": "uppercase",
          "label": "t:sections.all.text.style.option_2"
        }
      ],
      "default": "normal"
    },
    {
      "type": "select",
      "id": "post_card_media",
      "label": "t:sections.feed-social.settings.popup_settings_image.label",
      "options": [
        {
          "value": "cover",
          "label": "t:sections.feed-social.settings.popup_settings_image.option_1.label"
        },
        {
          "value": "contain",
          "label": "t:sections.feed-social.settings.popup_settings_image.option_2.label"
        }
      ],
      "default": "cover",
      "visible_if": "{{ section.settings.show_card_images }}"
    },
    {
      "type": "header",
      "content": "t:settings_schema.global.icon.label"
    },
    {
      "type": "color",
      "id": "icon_instagram_color",
      "label": "t:settings_schema.global.icon.settings.icon_instagram.label",
      "default": "#D1D1D1"
    },
    {
      "type": "color",
      "id": "icon_twitter_color",
      "label": "t:settings_schema.global.icon.settings.icon_twitter.label",
      "default": "#D1D1D1"
    },
    {
      "type": "color",
      "id": "icon_review_color",
      "label": "t:settings_schema.global.icon.settings.icon_review.label",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.desktop_padding_header"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
