{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}
{{ 'section-before-after.css' | asset_url | stylesheet_tag }}

<script src="{{ 'before-after.js' | asset_url }}" defer></script>

{% liquid
  render 'section-spacing', id: section.id

  assign animate_class = ''
  if section.settings.enable_animation
    assign animate_class = 'animate'
  endif

  assign section_index = section.index
  assign lazy_load = 'lazy'
  assign priority_load = false
  assign fetch_priority = 'low'

  if section_index == 1
    assign lazy_load = 'eager'
    assign priority_load = true
    assign fetch_priority = 'high'
  endif
%}

<before-after class="section-{{ section.id }} {% if section.settings.show_border_bottom %}section-border-bottom{% endif %}">
  {% unless section.settings.full_width %}
    <div class="page-width">
  {% endunless %}

  <div class="before-after-container {{ section.settings.border_radius }}">
    {% for block in section.blocks %}
      <div
        {{ block.shopify_attributes }}
        class="gradient color-{{ block.settings.color_scheme }} background-transparent image-banner {% if forloop.index == 1 %}image-banner--before{% else %}image-banner--after{% endif %}"
      >
        <div class="image-banner__image-wrapper {% if block.settings.image_mobile %}image-banner__image-wrapper--desktop{% endif %}">
          {% if block.settings.image != blank %}
            {% assign image_height = block.settings.image.width
              | divided_by: block.settings.image.aspect_ratio
              | ceil
            %}
            {{
              block.settings.image
              | image_url: width: 3000
              | image_tag:
                loading: lazy_load,
                priority: priority_load,
                fetchpriority: fetch_priority,
                width: block.settings.image.width,
                height: image_height,
                sizes: '100vw',
                widths: '1500, 2000, 2500, 3000',
                class: 'image-banner__image',
                alt: block.settings.image.alt
            }}
          {% else %}
            {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
          {% endif %}
        </div>

        {% if block.settings.image_mobile != blank %}
          <div class="image-banner__image-wrapper image-banner__image-wrapper--mobile">
            {% assign image_height = block.settings.image_mobile.width
              | divided_by: block.settings.image_mobile.aspect_ratio
              | ceil
            %}
            {{
              block.settings.image_mobile
              | image_url: width: 533
              | image_tag:
                loading: lazy_load,
                priority: priority_load,
                fetchpriority: fetch_priority,
                width: block.settings.image_mobile.width,
                height: image_height,
                sizes: '100vw',
                widths: '535, 720, 940, 1100',
                class: 'image-banner__image',
                alt: block.settings.image_mobile.alt
            }}
          </div>
        {% endif %}

        <div class="image-banner__text-wrapper">
          <div class="page-width">
            {% liquid
              if forloop.index == 1
                assign text_alignment_class = 'image-banner__inner--text-left'
                assign content_position_class = 'image-banner__inner-wrapper--bottom-left'
              else
                assign text_alignment_class = 'image-banner__inner--text-right'
                assign content_position_class = 'image-banner__inner-wrapper--bottom-right'
              endif
            %}

            <div class="image-banner__inner-wrapper {{ content_position_class }}">
              <div class="image-banner__inner banner-height--{{ section.settings.height }} {{ text_alignment_class }}">
                <span class="image-banner__inner-background"></span>

                {% if block.settings.heading != blank %}
                  <h2 class="{{ block.settings.header_size }} image-banner__inner-heading {{ block.settings.title_style }} {{ animate_class }}">
                    {{ block.settings.heading }}
                  </h2>
                {% endif %}

                {% if block.settings.subheading != blank %}
                  <div
                    class="image-banner__inner-text {{ block.settings.subheading_size }} {{ animate_class }}"
                    data-animate-delay="200"
                  >
                    {{ block.settings.subheading }}
                  </div>
                {% endif %}

                {% if block.settings.link != blank %}
                  <a
                    href="{{ block.settings.link }}"
                    class="link link-with-icon image-banner__inner-link {{ animate_class }} {{ block.settings.button_color_scheme }}"
                    data-animate-delay="400"
                  >
                    {{- block.settings.link_text }}
                    {% render 'icon-arrow' %}
                  </a>
                {% endif %}
              </div>
            </div>
          </div>
        </div>
      </div>
    {% endfor %}

    <div class="before-after-slider">
      <span class="before-after-handle">
        {% render 'icon-before-after' %}
      </span>
    </div>
  </div>

  {% unless section.settings.full_width %}</div>{% endunless %}
</before-after>

{% schema %}
{
  "name": "t:sections.before-after.name",
  "tag": "section",
  "settings": [
    {
      "type": "select",
      "id": "height",
      "options": [
        {
          "value": "small",
          "label": "t:sections.image-banner.settings.banner_height.options_1.label"
        },
        {
          "value": "medium",
          "label": "t:sections.image-banner.settings.banner_height.options_2.label"
        },
        {
          "value": "large",
          "label": "t:sections.image-banner.settings.banner_height.options_3.label"
        }
      ],
      "default": "large",
      "label": "t:sections.image-banner.settings.banner_height.label",
      "info": "t:sections.image-banner.settings.banner_height.info"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "t:sections.all.full_width.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_border_bottom",
      "label": "t:sections.all.border.show_border_bottom.label",
      "default": false
    },
    {
      "type": "select",
      "id": "border_radius",
      "options": [
        {
          "value": "image-border-radius--none",
          "label": "t:sections.all.radius.none.label"
        },
        {
          "value": "image-border-radius--rounded-xs",
          "label": "t:sections.all.radius.xs.label"
        },
        {
          "value": "image-border-radius--rounded-small",
          "label": "t:sections.all.radius.small.label"
        },
        {
          "value": "image-border-radius--rounded",
          "label": "t:sections.all.radius.standard.label"
        }
      ],
      "default": "image-border-radius--none",
      "label": "t:sections.all.radius.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.margin.desktop_margin_header"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.margin.margin_bottom",
      "default": 120
    },
    {
      "type": "header",
      "content": "t:sections.all.margin.mobile_margin_header"
    },
    {
      "type": "range",
      "id": "mobile_margin_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.margin.mobile_margin_bottom",
      "default": 60
    },
    {
      "type": "header",
      "content": "t:sections.all.animations.section_animation.header",
      "visible_if": "{{ settings.enable_global_animations }}"
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "t:sections.all.animations.section_animation.label",
      "info": "t:sections.all.animations.section_animation.info",
      "default": true,
      "visible_if": "{{ settings.enable_global_animations }}"
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    {
      "name": "t:sections.before-after.blocks.banner.name",
      "type": "banner",
      "limit": 2,
      "settings": [
        {
          "type": "color_scheme",
          "id": "color_scheme",
          "label": "t:sections.all.colors.label",
          "default": "background-1"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.image-banner.settings.image.label",
          "info": "t:sections.all.images_tips.landscape_big.info"
        },
        {
          "type": "image_picker",
          "id": "image_mobile",
          "label": "t:sections.image-banner.settings.mobile_image.label",
          "info": "t:sections.all.images_tips.portrait_medium.info"
        },
        {
          "type": "header",
          "content": "t:sections.image-banner.settings.content_header.content"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.image-banner.settings.heading.label",
          "default": "Add Image heading"
        },
        {
          "type": "select",
          "id": "title_style",
          "label": "t:sections.all.text.style.label",
          "options": [
            {
              "value": "normal",
              "label": "t:sections.all.text.style.option_1"
            },
            {
              "value": "uppercase",
              "label": "t:sections.all.text.style.option_2"
            }
          ],
          "default": "normal"
        },
        {
          "type": "select",
          "id": "header_size",
          "options": [
            {
              "value": "h3",
              "label": "t:sections.all.heading_size.options_0.label"
            },
            {
              "value": "h2",
              "label": "t:sections.all.heading_size.options_1.label"
            },
            {
              "value": "h1",
              "label": "t:sections.all.heading_size.options_2.label"
            },
            {
              "value": "d3",
              "label": "t:sections.all.heading_size.options_3.label"
            }
          ],
          "default": "h2",
          "label": "t:sections.all.heading_size.heading.label"
        },
        {
          "type": "richtext",
          "id": "subheading",
          "label": "t:sections.image-banner.settings.subheading.label",
          "default": "<p>Give customers details about the banner image(s) or content on the template.</p>"
        },
        {
          "type": "select",
          "id": "subheading_size",
          "options": [
            {
              "value": "p",
              "label": "t:sections.all.heading_size.options_1.label"
            },
            {
              "value": "p-large",
              "label": "t:sections.all.heading_size.options_2.label"
            }
          ],
          "default": "p",
          "label": "t:sections.all.heading_size.subheading.label"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.image-banner.settings.banner_link.label",
          "default": "/"
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "t:sections.image-banner.settings.banner_link_text.label",
          "default": "Explore now"
        },
        {
          "type": "select",
          "id": "button_color_scheme",
          "options": [
            {
              "value": "button",
              "label": "t:sections.all.buttons.primary.label"
            },
            {
              "value": "button button--secondary",
              "label": "t:sections.all.buttons.secondary.label"
            },
            {
              "value": "link link-with-icon",
              "label": "t:sections.all.buttons.text_link.label"
            }
          ],
          "default": "button",
          "label": "t:sections.all.buttons.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.before-after.name",
      "category": "t:categories.media",
      "blocks": [
        {
          "type": "banner"
        },
        {
          "type": "banner"
        }
      ]
    }
  ]
}
{% endschema %}
