{{ 'component-accordion.css' | asset_url | stylesheet_tag }}

{% liquid
  render 'section-spacing', id: section.id

  if section.settings.enable_animation
    assign animate_class = 'animate'
  else
    assign animate_class = ''
  endif

  assign title_style = section.settings.title_style
  if title_style == 'uppercase'
    assign title_style = 'uppercase'
  endif

  assign layout = section.settings.layout
  assign header_layout = ''
  if layout == 'side-by-side'
    assign header_layout = 'section-title-header--stacked'
  endif
  if section.settings.button_layout == 'stacked'
    assign header_layout = 'section-title-header--stacked'
  endif
%}

{% style %}
  {% if layout == 'stacked' %}
    @media only screen and (min-width: 990px) {
      .section-{{ section.id }} .collapsible-content__inner {
        margin-left: auto;
        margin-right: auto;
        width: {{ section.settings.row_width }}%;
      }
    }
  {% endif %}
{% endstyle %}

<div
  class="
    collapsible-content
    collapsible-content--{{ layout }}
    section-{{ section.id }}
    gradient
    color-{{ section.settings.color_scheme }}
    {% if section.settings.show_border_bottom %}section-border-bottom{% endif %}
  "
>
  <div
    class="
      collapsible-content__inner
      {% if layout == 'side-by-side' %}
        page-width
      {% endif %}
    "
  >
    {% render 'component-section-header',
      type: 'header',
      animate_class: animate_class,
      layout: header_layout,
      heading: section.settings.heading,
      title_style: title_style,
      heading_size: section.settings.heading_size,
      subheading: section.settings.subheading,
      show_decorative_icon: section.settings.show_decorative_icon,
      title_alignment: section.settings.title_alignment,
      link: section.settings.link,
      link_text: section.settings.link_text,
      button_color_scheme: section.settings.button_color_scheme
    %}

    {% if layout == 'stacked' %}
      <div class="page-width">
    {% endif %}
    <div class="accordion-container {{ animate_class }}">
      {% render 'collapsible-content-accordion' %}
    </div>
    {% if layout == 'stacked' %}
      </div>
    {% endif %}

    {% render 'component-section-header',
      type: 'footer',
      animate_class: animate_class,
      link: section.settings.link,
      link_text: section.settings.link_text,
      button_color_scheme: section.settings.button_color_scheme
    %}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.collapsible-content.name",
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "background-3"
    },
    {
      "type": "checkbox",
      "id": "show_border_bottom",
      "label": "t:sections.all.border.show_border_bottom.label",
      "default": false
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "t:sections.collapsible-content.settings.layout.label",
      "options": [
        {
          "value": "stacked",
          "label": "t:sections.collapsible-content.settings.layout.options_1.label"
        },
        {
          "value": "side-by-side",
          "label": "t:sections.collapsible-content.settings.layout.options_2.label"
        }
      ],
      "default": "stacked"
    },
    {
      "type": "range",
      "id": "row_width",
      "min": 70,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "t:sections.collapsible-content.settings.content-width.label",
      "default": 100,
      "visible_if": "{{ section.settings.layout == 'stacked' }}",
      "info": "t:sections.collapsible-content.settings.content-width.info"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "Add your heading here",
      "label": "t:sections.collapsible-content.settings.heading.label"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "t:sections.all.heading_size.heading.label",
      "options": [
        {
          "value": "h3",
          "label": "t:sections.all.heading_size.options_1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options_2.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options_3.label"
        }
      ],
      "default": "h1",
      "visible_if": "{{ section.settings.heading != blank }}"
    },
    {
      "type": "select",
      "id": "title_style",
      "label": "t:sections.all.text.style.label",
      "options": [
        {
          "value": "normal",
          "label": "t:sections.all.text.style.option_1"
        },
        {
          "value": "uppercase",
          "label": "t:sections.all.text.style.option_2"
        }
      ],
      "default": "normal",
      "visible_if": "{{ section.settings.heading != blank }}"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "t:sections.collapsible-content.settings.content.label",
      "default": "Add more details about your store here"
    },
    {
      "type": "url",
      "id": "link",
      "label": "t:sections.all.buttons.button_link.label",
      "default": "/"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "t:sections.all.buttons.button_text.label",
      "info": "t:sections.all.buttons.button_text.info"
    },
    {
      "type": "select",
      "id": "button_color_scheme",
      "options": [
        {
          "value": "button",
          "label": "t:sections.all.buttons.primary.label"
        },
        {
          "value": "button button--secondary",
          "label": "t:sections.all.buttons.secondary.label"
        },
        {
          "value": "link link-with-icon",
          "label": "t:sections.all.buttons.text_link.label"
        }
      ],
      "default": "button button--secondary",
      "label": "t:sections.all.buttons.label"
    },
    {
      "type": "select",
      "id": "button_layout",
      "label": "t:sections.collapsible-content.settings.button_layout.label",
      "info": "t:sections.collapsible-content.settings.button_layout.info",
      "options": [
        {
          "value": "stacked",
          "label": "t:sections.collapsible-content.settings.layout.options_1.label"
        },
        {
          "value": "side-by-side",
          "label": "t:sections.collapsible-content.settings.layout.options_2.label"
        }
      ],
      "default": "side-by-side",
      "visible_if": "{{ section.settings.layout == 'stacked' }}"
    },
    {
      "type": "select",
      "id": "title_alignment",
      "label": "t:sections.all.alignment.content_label",
      "options": [
        {"value": "left", "label": "t:sections.all.alignment.option_1.label"},
        {"value": "center", "label": "t:sections.all.alignment.option_2.label"},
        {"value": "right", "label": "t:sections.all.alignment.option_3.label"}
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "t:sections.collapsible-content.settings.row_font_size.header"
    },
    {
      "type": "select",
      "id": "row_title_style",
      "label": "t:sections.all.text.style.label",
      "options": [
        {
          "value": "normal",
          "label": "t:sections.all.text.style.option_1"
        },
        {
          "value": "uppercase",
          "label": "t:sections.all.text.style.option_2"
        }
      ],
      "default": "normal"
    },
    {
      "type": "select",
      "id": "row_font_size",
      "label": "t:sections.collapsible-content.settings.row_font_size.label",
      "options": [
        {
          "value": "p",
          "label": "t:sections.all.heading_size.options_1.label"
        },
        {
          "value": "h6",
          "label": "t:sections.all.heading_size.options_2.label"
        },
        {
          "value": "h5",
          "label": "t:sections.all.heading_size.options_3.label"
        }
      ],
      "default": "p"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.desktop_padding_header"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 120
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 120
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.mobile_padding_header"
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.mobile_padding_top",
      "default": 44
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.mobile_padding_bottom",
      "default": 44
    },
    {
      "type": "header",
      "content": "t:sections.all.margin.desktop_margin_header"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.margin.margin_bottom",
      "default": 120
    },
    {
      "type": "header",
      "content": "t:sections.all.margin.mobile_margin_header"
    },
    {
      "type": "range",
      "id": "mobile_margin_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.margin.mobile_margin_bottom",
      "default": 60
    },
    {
      "type": "header",
      "content": "t:sections.all.animations.section_animation.header",
      "visible_if": "{{ settings.enable_global_animations }}"
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "t:sections.all.animations.section_animation.label",
      "default": true,
      "visible_if": "{{ settings.enable_global_animations }}"
    }
  ],
  "blocks": [
    {
      "type": "question_answer",
      "name": "t:sections.collapsible-content.blocks.collapsible-row.name",
      "settings": [
        {
          "type": "select",
          "id": "display_type",
          "label": "t:sections.collapsible-content.blocks.collapsible-row.settings.display_type.label",
          "options": [
            {
              "value": "accordion",
              "label": "t:sections.collapsible-content.blocks.collapsible-row.settings.display_type.options_1.label"
            },
            {
              "value": "drawer",
              "label": "t:sections.collapsible-content.blocks.collapsible-row.settings.display_type.options_2.label"
            }
          ],
          "default": "accordion"
        },
        {
          "type": "checkbox",
          "id": "faq_open",
          "label": "t:sections.collapsible-content.blocks.collapsible-row.settings.open_row.label",
          "visible_if": "{{ block.settings.display_type == 'accordion' }}"
        },
        {
          "type": "richtext",
          "id": "faqs_question",
          "label": "t:sections.collapsible-content.blocks.collapsible-row.settings.heading.label",
          "default": "<p>Add your question here</p>"
        },
        {
          "type": "richtext",
          "id": "faqs_answer",
          "label": "t:sections.collapsible-content.blocks.collapsible-row.settings.content.label",
          "default": "<p>Add your content here</p>"
        }
      ]
    },
    {
      "type": "title",
      "name": "t:sections.collapsible-content.blocks.title.name",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.collapsible-content.blocks.title.settings.heading.label"
        },
        {
          "type": "select",
          "id": "title_style",
          "label": "t:sections.all.text.style.label",
          "options": [
            {
              "value": "normal",
              "label": "t:sections.all.text.style.option_1"
            },
            {
              "value": "uppercase",
              "label": "t:sections.all.text.style.option_2"
            }
          ],
          "default": "normal"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "t:sections.collapsible-content.blocks.title.settings.content.label"
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header"]
  },
  "presets": [
    {
      "name": "t:sections.collapsible-content.name",
      "category": "t:categories.brand_trust",
      "blocks": [
        {
          "type": "question_answer"
        }
      ]
    }
  ]
}
{% endschema %}
