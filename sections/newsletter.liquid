{% liquid
  render 'css-delay', css_file: 'component-newsletter.css'
  render 'css-delay', css_file: 'newsletter-section.css'
  render 'section-spacing', id: section.id, type: 'split'

  if section.settings.enable_animation
    assign animate_class = 'animate'
  else
    assign animate_class = ''
  endif
%}

<div
  class="
    newsletter
    center
    {% if section.settings.full_width == false %} newsletter--narrow page-width{% endif %}
    section-{{ section.id }}-margin
  "
>
  <div
    class="
      newsletter__wrapper
      gradient
      color-{{ section.settings.color_scheme }}
      section-{{ section.id }}-padding
      {% if section.settings.show_border_bottom %}section-border-bottom{% endif %}
    "
  >
    <div class="newsletter__container {{ animate_class }}">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when '@app' -%}
            {% render block %}
          {%- when 'heading' -%}
            <h2
              class="
                newsletter__heading
                {{ block.settings.title_style }}
                {{ block.settings.heading_size }}
                js-sign-up-success
              "
              {{ block.shopify_attributes }}
            >
              {{ block.settings.heading | escape }}
            </h2>
          {%- when 'paragraph' -%}
            <div
              class="h4 newsletter__subheading rte js-sign-up-success"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.paragraph }}
            </div>
          {%- when 'email_form' -%}
            {% assign newsletter_form_id = 'NewsletterForm-' | append: section.id %}
            <div {{ block.shopify_attributes }}>
              {% form 'customer', id: newsletter_form_id, class: 'newsletter-form' %}
                {%- if form.posted_successfully? -%}
                  <div class="newsletter-form__success" tabindex="-1" autofocus>
                    <h3>
                      {{- 'newsletter.success' | t }}
                    </h3>
                    <div
                      class="h4 newsletter__subheading rte"
                      {{ block.shopify_attributes }}
                    >
                      {{- 'newsletter.success_message' | t }}
                    </div>
                  </div>
                {%- else -%}
                  <div
                    class="
                      newsletter-form__container
                      newsletter-form__container--{{ block.settings.form_style }}
                    "
                  >
                    <input
                      type="hidden"
                      name="contact[tags]"
                      value="newsletter"
                    >
                    <div class="newsletter-form__field-wrapper">
                      <div class="field">
                        <input
                          id="NewsletterForm--{{ section.id }}"
                          type="email"
                          name="contact[email]"
                          class="field__input newsletter__input"
                          value="{{ form.email }}"
                          aria-required="true"
                          autocorrect="off"
                          autocapitalize="off"
                          autocomplete="email"
                          {% if form.errors %}
                            autofocus
                            aria-invalid="true"
                            aria-describedby="Newsletter-error--{{ section.id }}"
                          {% elsif form.posted_successfully? %}
                            aria-describedby="Newsletter-success--{{ section.id }}"
                          {% endif %}
                          placeholder="{{ 'newsletter.label' | t }}"
                          required
                        >
                        <label
                          class="field__label visually-hidden"
                          for="NewsletterForm--{{ section.id }}"
                        >
                          {{ 'newsletter.label' | t }}
                        </label>
                      </div>
                    </div>
                    <div class="newsletter-form__field-wrapper">
                      <div class="field field--phone">
                        <select
                          id="NewsletterPhoneCountry--{{ section.id }}"
                          class="newsletter-form__phone-code"
                          aria-label="{{ 'newsletter.phone_country' | t }}"
                        >
                        <option value="+33" selected>France (+33)</option>
                        <option value="+27">Afrique du Sud (+27)</option>
                        <option value="+355">Albanie (+355)</option>
                        <option value="+213">Algérie (+213)</option>
                        <option value="+49">Allemagne (+49)</option>
                        <option value="+376">Andorre (+376)</option>
                        <option value="+966">Arabie saoudite (+966)</option>
                        <option value="+54">Argentine (+54)</option>
                        <option value="+374">Arménie (+374)</option>
                        <option value="+61">Australie (+61)</option>
                        <option value="+43">Autriche (+43)</option>
                        <option value="+994">Azerbaïdjan (+994)</option>
                        <option value="+973">Bahreïn (+973)</option>
                        <option value="+880">Bangladesh (+880)</option>
                        <option value="+32">Belgique (+32)</option>
                        <option value="+387">Bosnie-Herzégovine (+387)</option>
                        <option value="+55">Brésil (+55)</option>
                        <option value="+359">Bulgarie (+359)</option>
                        <option value="+237">Cameroun (+237)</option>
                        <option value="+1">Canada (+1)</option>
                        <option value="+56">Chili (+56)</option>
                        <option value="+86">Chine (+86)</option>
                        <option value="+357">Chypre (+357)</option>
                        <option value="+57">Colombie (+57)</option>
                        <option value="+82">Corée du Sud (+82)</option>
                        <option value="+225">Côte d'Ivoire (+225)</option>
                        <option value="+385">Croatie (+385)</option>
                        <option value="+45">Danemark (+45)</option>
                        <option value="+20">Égypte (+20)</option>
                        <option value="+971">Émirats arabes unis (+971)</option>
                        <option value="+34">Espagne (+34)</option>
                        <option value="+372">Estonie (+372)</option>
                        <option value="+1">États-Unis (+1)</option>
                        <option value="+358">Finlande (+358)</option>
                        <option value="+995">Géorgie (+995)</option>
                        <option value="+30">Grèce (+30)</option>
                        <option value="+852">Hong Kong (+852)</option>
                        <option value="+36">Hongrie (+36)</option>
                        <option value="+91">Inde (+91)</option>
                        <option value="+62">Indonésie (+62)</option>
                        <option value="+353">Irlande (+353)</option>
                        <option value="+354">Islande (+354)</option>
                        <option value="+972">Israël (+972)</option>
                        <option value="+39">Italie (+39)</option>
                        <option value="+81">Japon (+81)</option>
                        <option value="+962">Jordanie (+962)</option>
                        <option value="+254">Kenya (+254)</option>
                        <option value="+965">Koweït (+965)</option>
                        <option value="+371">Lettonie (+371)</option>
                        <option value="+961">Liban (+961)</option>
                        <option value="+370">Lituanie (+370)</option>
                        <option value="+352">Luxembourg (+352)</option>
                        <option value="+389">Macédoine du Nord (+389)</option>
                        <option value="+60">Malaisie (+60)</option>
                        <option value="+356">Malte (+356)</option>
                        <option value="+212">Maroc (+212)</option>
                        <option value="+52">Mexique (+52)</option>
