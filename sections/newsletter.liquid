                        <option value="+420">République tchèque (+420)</option>
                        <option value="+40">Roumanie (+40)</option>
                        <option value="+44">Royaume-Uni (+44)</option>
                        <option value="+7">Russie (+7)</option>
                        <option value="+221">Sénégal (+221)</option>
                        <option value="+381">Serbie (+381)</option>
                        <option value="+65">Singapour (+65)</option>
                        <option value="+421">Slovaquie (+421)</option>
                        <option value="+386">Slovénie (+386)</option>
                        <option value="+46">Suède (+46)</option>
                        <option value="+41">Suisse (+41)</option>
                        <option value="+66">Thaïlande (+66)</option>
                        <option value="+216">Tunisie (+216)</option>
                        <option value="+90">Turquie (+90)</option>
                        <option value="+380">Ukraine (+380)</option>
                        <option value="+84">Vietnam (+84)</option>
                        </select>
                        <input
                          id="NewsletterPhoneNumber--{{ section.id }}"
                          type="tel"
                          class="field__input newsletter-form__phone-input"
                          placeholder="{{ 'newsletter.phone_label' | t }}"
                          autocomplete="tel-national"
                          inputmode="tel"
                        >
                        <input
                          type="hidden"
                          name="customer[phone]"
                          id="NewsletterPhoneHidden--{{ section.id }}"
                        >
                        <label
                          class="field__label visually-hidden"
                          for="NewsletterPhoneNumber--{{ section.id }}"
                        >
                          {{ 'newsletter.phone_label' | t }}
                        </label>
                      </div>
                    </div>
                    <button
                      type="submit"
                      name="commit"
                      class="
                        link
                        link-with-icon
                        newsletter__button
                        {{ section.settings.button_color_scheme }}
                      "
                    >
                      {{ 'newsletter.button_label' | t }}
                    </button>
                  </div>

                  {%- if form.errors -%}
                    <small
                      class="alert"
                      id="Newsletter-error--{{ section.id }}"
                    >
                      {%- render 'icon-error' -%}
                      <span>
                        {{- form.errors.translated_fields.email | capitalize }}
                        {{ form.errors.messages.email -}}
                      </span>
                    </small>
                  {%- endif -%}
                {%- endif -%}
              {% endform %}
              <script>
                (function () {
                  var form = document.getElementById('NewsletterForm-{{ section.id }}');
                  if (!form) return;
                  form.addEventListener('submit', function () {
                    var code = document.getElementById('NewsletterPhoneCountry--{{ section.id }}');
                    var num = document.getElementById('NewsletterPhoneNumber--{{ section.id }}');
                    var hidden = document.getElementById('NewsletterPhoneHidden--{{ section.id }}');
                    if (code && num && hidden && num.value.trim() !== '') {
                      hidden.value = code.value + num.value.trim().replace(/^0+/, '');
                    }
                  });
                })();
              </script>
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.newsletter.name",
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "background-5"
    },
    {
      "type": "checkbox",
      "id": "show_border_bottom",
      "label": "t:sections.all.border.show_border_bottom.label",
      "default": false
    },
    {
      "type": "select",
      "id": "button_color_scheme",
      "options": [
        {
          "value": "button",
          "label": "t:sections.all.buttons.primary.label"
        },
        {
          "value": "button button--secondary",
          "label": "t:sections.all.buttons.secondary.label"
        },
        {
          "value": "link link-with-icon",
          "label": "t:sections.all.buttons.text_link.label"
        }
      ],
      "default": "button",
      "label": "t:sections.all.buttons.label"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "default": false,
      "label": "t:sections.newsletter.settings.full_width.label"
    },
    {
      "type": "paragraph",
      "content": "t:sections.newsletter.settings.paragraph.content"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.desktop_padding_header"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 120
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 120
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.mobile_padding_header"
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.mobile_padding_top",
      "default": 80
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.mobile_padding_bottom",
      "default": 80
    },
    {
      "type": "header",
      "content": "t:sections.all.margin.desktop_margin_header"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.margin.margin_bottom",
      "default": 120
    },
    {
      "type": "header",
      "content": "t:sections.all.margin.mobile_margin_header"
    },
    {
      "type": "range",
      "id": "mobile_margin_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.margin.mobile_margin_bottom",
      "default": 60
    },
    {
      "type": "header",
      "content": "t:sections.all.animations.section_animation.header",
      "visible_if": "{{ settings.enable_global_animations }}"
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "t:sections.all.animations.section_animation.label",
      "default": true,
      "visible_if": "{{ settings.enable_global_animations }}"
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "t:sections.newsletter.blocks.heading.name",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "default": "Sign up & Save",
          "label": "t:sections.newsletter.blocks.heading.settings.heading.label"
        },
        {
          "type": "select",
          "id": "title_style",
          "label": "t:sections.all.text.style.label",
          "options": [
            {
              "value": "normal",
              "label": "t:sections.all.text.style.option_1"
            },
            {
              "value": "uppercase",
              "label": "t:sections.all.text.style.option_2"
            }
          ],
          "default": "normal"
        },
        {
          "type": "select",
          "id": "heading_size",
          "options": [
            {
              "value": "h3",
              "label": "t:sections.all.heading_size.options_2.label"
            },
            {
              "value": "h2",
              "label": "t:sections.all.heading_size.options_3.label"
            }
          ],
          "default": "h2",
          "label": "t:sections.all.heading_size.heading.label"
        }
      ]
    },
    {
      "type": "paragraph",
      "name": "t:sections.newsletter.blocks.paragraph.name",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "paragraph",
          "default": "<p>Sign up today and get special product releases and exclusive sales!</p>",
          "label": "t:sections.newsletter.blocks.paragraph.settings.paragraph.label"
        }
      ]
    },
    {
      "type": "email_form",
      "name": "t:sections.newsletter.blocks.email_form.name",
      "limit": 1,
      "settings": [
        {
          "type": "select",
          "id": "form_style",
          "label": "t:sections.newsletter.blocks.email_form.settings.form_style.label",
          "options": [
            {
              "value": "normal",
              "label": "t:sections.newsletter.blocks.email_form.settings.form_style.options_1.label"
            },
            {
              "value": "wrapped",
              "label": "t:sections.newsletter.blocks.email_form.settings.form_style.options_2.label"
            },
            {
              "value": "stacked",
              "label": "t:sections.newsletter.blocks.email_form.settings.form_style.options_3.label"
            }
          ],
          "default": "normal"
        }
      ]
    },
    {
      "type": "@app"
    }
  ],
  "disabled_on": {
    "groups": ["header"]
  },
  "presets": [
    {
      "name": "t:sections.newsletter.name",
      "category": "t:categories.forms",
      "blocks": [
        {
          "type": "heading"
        },
        {
          "type": "paragraph"
        },
        {
          "type": "email_form"
        }
      ]
    }
  ]
}
{% endschema %}
