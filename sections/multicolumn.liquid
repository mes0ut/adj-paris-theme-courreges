{% liquid
  render 'css-delay', css_file: 'section-multicolumn.css'
  render 'section-spacing', id: section.id

  if section.settings.enable_animation
    assign animate_class = 'animate'
  else
    assign animate_class = ''
  endif

  assign image_width = section.settings.image_width | append: 'px'

  assign title_style = section.settings.title_style
  if title_style == 'uppercase'
    assign title_style = 'uppercase'
  endif

  assign heading_size = section.settings.heading_size

  assign column_title_style = section.settings.column_title_style
  if column_title_style == 'uppercase'
    assign column_title_style = 'uppercase'
  endif
%}

<div
  class="
    section-{{ section.id }}
    gradient
    color-{{ section.settings.color_scheme }}
    {% if section.settings.show_border_bottom %}section-border-bottom{% endif %}
  "
>
  <div class="page-width">
    <div class="multicolumn">
      {% if section.settings['decorative-icon'] != blank %}
        <div class="multicolumn__decorative-icon-wrapper">
          {% render 'icon-star-cluster-one' %}
        </div>
      {% endif %}

      {% if section.settings.heading != blank %}
        <{{ heading_size }} class="multicolumn__heading {{ title_style }} {{ animate_class }}">
          {{ section.settings.heading }}
        </{{ heading_size }}>
      {% endif %}

      <embla-component class="multicolumn__carousel">
        <div class="embla">
          <div class="embla__viewport">
            <ul class="embla__container">
              {% for block in section.blocks %}
                <li
                  {{ block.shopify_attributes }}
                  class="embla__slide"
                  data-slide-index="{{ forloop.index0 }}"
                >
                  <div class="multicolumn__column-single">
                    {%- if block.settings.image != blank -%}
                      <div
                        class="
                          image-aspect-ratio
                          multicolumn__image
                          {{ section.settings.primary_image_style }}
                          {{ animate_class }}
                        "
                        style="max-width: {{ image_width }}"
                      >
                        {% liquid
                          assign image_src = block.settings.image
                          assign image_height = 'auto'
                          assign widths = '320'
                          assign class = 'multicolumn__column-image'
                          assign fetch_priority = 'auto'
                          if section.index == 1
                            assign fetch_priority = 'high'
                          endif
                        %}

                        {{
                          image_src
                          | image_url: width: 800
                          | image_tag:
                            width: image_src.width,
                            height: image_height,
                            fetch_priority: fetch_priority,
                            widths: widths,
                            class: class,
                            alt: image_src.alt
                          | escape
                        }}
                      </div>
                    {%- endif -%}
                    <h3
                      class="
                        multicolumn__column-heading h5
                        {{ column_title_style }}
                        {{ animate_class }}
                      "
                    >
                      {{ block.settings.column_heading }}
                    </h3>
                    <p class="multicolumn__column-text {{ animate_class }}">
                      {{ block.settings.column_text }}
                    </p>
                  </div>
                </li>
              {% endfor %}
            </ul>
          </div>
        </div>
        {% if section.blocks.size > 1 %}
          <div class="embla__dots"></div>
        {% endif %}
      </embla-component>

      {% if section.settings.link != blank %}
        <a
          class="
            link
            link-with-icon
            multicolumn__main-link
            {{ animate_class }}
            {{ section.settings.button_color_scheme }}
          "
          href="{{ section.settings.link }}"
        >
          <span>{{ section.settings.link_text }}</span>
          {% render 'icon-arrow' %}
        </a>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.multicolumn.name",
  "tag": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "background-1"
    },
    {
      "type": "checkbox",
      "id": "show_border_bottom",
      "label": "t:sections.all.border.show_border_bottom.label",
      "default": false
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.multicolumn.settings.heading.label",
      "default": "Add benefits or unique selling points of your store"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h3",
          "label": "t:sections.all.heading_size.options_1.label"
        },
        {
          "value": "h2",
          "label": "t:sections.all.heading_size.options_2.label"
        },
        {
          "value": "h1",
          "label": "t:sections.all.heading_size.options_3.label"
        }
      ],
      "default": "h2",
      "label": "t:sections.all.heading_size.heading.label"
    },
    {
      "type": "select",
      "id": "title_style",
      "label": "t:sections.all.text.style.label",
      "options": [
        {
          "value": "normal",
          "label": "t:sections.all.text.style.option_1"
        },
        {
          "value": "uppercase",
          "label": "t:sections.all.text.style.option_2"
        }
      ],
      "default": "normal"
    },
    {
      "type": "checkbox",
      "id": "decorative-icon",
      "label": "t:sections.multicolumn.settings.icon.label",
      "default": false
    },
    {
      "type": "url",
      "id": "link",
      "label": "t:sections.multicolumn.settings.link.label"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "t:sections.multicolumn.settings.link-text.label",
      "default": "Learn more"
    },
    {
      "type": "select",
      "id": "button_color_scheme",
      "options": [
        {
          "value": "button",
          "label": "t:sections.all.buttons.primary.label"
        },
        {
          "value": "button button--secondary",
          "label": "t:sections.all.buttons.secondary.label"
        },
        {
          "value": "link link-with-icon",
          "label": "t:sections.all.buttons.text_link.label"
        }
      ],
      "default": "button",
      "label": "t:sections.all.buttons.label"
    },
    {
      "type": "header",
      "content": "t:sections.multicolumn.settings.column_settings.header"
    },
    {
      "type": "range",
      "id": "image_width",
      "label": "t:sections.multicolumn.settings.image_width.label",
      "default": 100,
      "min": 20,
      "max": 200,
      "step": 10
    },
    {
      "type": "select",
      "id": "primary_image_style",
      "options": [
        {
          "value": "image-border-radius--none",
          "label": "t:sections.all.radius.none.label"
        },
        {
          "value": "image-border-radius--rounded-xxs",
          "label": "t:sections.all.radius.xxs.label"
        },
        {
          "value": "image-border-radius--rounded-xs",
          "label": "t:sections.all.radius.xs.label"
        },
        {
          "value": "image-border-radius--rounded-small",
          "label": "t:sections.all.radius.small.label"
        },
        {
          "value": "image-border-radius--rounded",
          "label": "t:sections.all.radius.standard.label"
        },
        {
          "value": "image-border-radius--rounded-extra",
          "label": "t:sections.all.radius.extra.label"
        },
        {
          "value": "image-border-radius--curved-top",
          "label": "t:sections.all.radius.curved.label"
        },
        {
          "value": "image-border-radius--circle",
          "label": "t:sections.all.radius.circle.label"
        }
      ],
      "default": "image-border-radius--none",
      "label": "t:sections.all.radius.label"
    },
    {
      "type": "select",
      "id": "column_title_style",
      "label": "t:sections.all.text.style.label",
      "options": [
        {
          "value": "normal",
          "label": "t:sections.all.text.style.option_1"
        },
        {
          "value": "uppercase",
          "label": "t:sections.all.text.style.option_2"
        }
      ],
      "default": "normal"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.desktop_padding_header"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 120
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 120
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.mobile_padding_header"
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.mobile_padding_top",
      "default": 96
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.mobile_padding_bottom",
      "default": 96
    },
    {
      "type": "header",
      "content": "t:sections.all.margin.desktop_margin_header"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.margin.margin_bottom",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:sections.all.margin.mobile_margin_header"
    },
    {
      "type": "range",
      "id": "mobile_margin_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.margin.mobile_margin_bottom",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:sections.all.animations.section_animation.header",
      "visible_if": "{{ settings.enable_global_animations }}"
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "t:sections.all.animations.section_animation.label",
      "default": true,
      "visible_if": "{{ settings.enable_global_animations }}"
    }
  ],
  "blocks": [
    {
      "name": "t:sections.multicolumn.settings.column.label",
      "type": "column",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:sections.multicolumn.settings.column-heading.label"
        },
        {
          "type": "text",
          "id": "column_heading",
          "label": "t:sections.multicolumn.settings.column-heading.label",
          "default": "This is a benefit heading"
        },
        {
          "type": "text",
          "id": "column_text",
          "label": "t:sections.multicolumn.settings.column-text.label",
          "default": "Short description explaining how customers can benefit from this benefit"
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "presets": [
    {
      "name": "t:sections.multicolumn.name",
      "category": "t:categories.storytelling",
      "blocks": [
        {
          "type": "column"
        },
        {
          "type": "column"
        },
        {
          "type": "column"
        }
      ]
    }
  ]
}
{% endschema %}
