{% comment %}
ADJ PARIS — OpenStreetMap Store Locator (vFinal+Phone)
Tüm mağaza bilgileri: Görsel + Şehir + Adres + Telefon
{% endcomment %}

<section id="stores-map-osm-{{ section.id }}" class="stores-map-osm" data-section-id="{{ section.id }}">
  <!-- Leaflet CSS -->
  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
    integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
    crossorigin=""
  />

  <style>
    #stores-map-osm-{{ section.id }} {
      --bg: var(--color-background, #fff);
      --fg: var(--color-foreground, #111);
      --border: var(--color-border, #e5e5e5);
      --muted: color-mix(in srgb, var(--fg) 60%, transparent);
      --shadow: 0 2px 12px rgba(0,0,0,.06);
      background: var(--bg);
      color: var(--fg);
      padding: 36px 0 48px;
    }

    #stores-map-osm-{{ section.id }} h2 {
      font-weight: 700;
      font-size: clamp(22px, 1.4vw + 16px, 30px);
      text-align: left;
      margin: 0 auto 20px;
      max-width: 1280px;
      padding: 0 20px;
    }

    .grid {
      display: grid;
      grid-template-columns: 380px 1fr;
      gap: 22px;
      align-items: stretch;
      min-height: 72vh;
      max-width: 1280px;
      margin: 0 auto;
      padding: 0 20px;
      box-sizing: border-box;
    }

    .osm-list {
      border: 1px solid var(--border);
      border-radius: 16px;
      box-shadow: var(--shadow);
      overflow: auto;
      background: var(--bg);
    }

    .osm-item {
      display: grid;
      grid-template-columns: 88px 1fr;
      gap: 12px;
      padding: 12px 14px;
      border-bottom: 1px solid var(--border);
      cursor: pointer;
      transition: background .2s ease;
      align-items: center;
    }

    .osm-item:last-child { border-bottom: 0; }
    .osm-item:hover { background: color-mix(in srgb, var(--fg) 4%, var(--bg)); }
    .osm-item.active { background: color-mix(in srgb, var(--fg) 7%, var(--bg)); }

    .osm-thumb {
      width: 88px;
      height: 88px;
      border-radius: 12px;
      overflow: hidden;
      background: #f6f6f6;
    }

    .osm-thumb img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
    }

    .osm-title { font-weight: 700; font-size: 16px; line-height: 1.25; }
    .osm-sub { color: var(--muted); font-size: 13px; line-height: 1.4; }

    .osm-mapwrap {
      border: 1px solid var(--border);
      border-radius: 16px;
      box-shadow: var(--shadow);
      overflow: hidden;
      background: var(--bg);
      display: flex;
      flex-direction: column;
    }

    .osm-map { flex: 1; min-height: 520px; }
    .leaflet-container { font-family: inherit; }

    .adj-lightbox {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,.86);
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      pointer-events: none;
      transition: opacity .25s ease;
      z-index: 9999;
    }

    .adj-lightbox.active { opacity: 1; pointer-events: auto; }
    .adj-lightbox img {
      max-width: 92%;
      max-height: 92%;
      border-radius: 12px;
      box-shadow: 0 0 30px rgba(255,255,255,.25);
      cursor: zoom-out;
    }

    @media (max-width: 990px) {
      .grid { grid-template-columns: 1fr; padding: 0 14px; }
      .osm-map { min-height: 420px; }
    }
  </style>

  {% if section.settings.title != blank %}
    <h2>{{ section.settings.title }}</h2>
  {% endif %}

  <div class="grid">
    <!-- Sol: Mağaza listesi -->
    <div class="osm-list" id="osm-list-{{ section.id }}">
      {% for block in section.blocks %}
        <article
          class="osm-item{% if forloop.first %} active{% endif %}"
          data-idx="{{ forloop.index0 }}"
          data-lat="{{ block.settings.latitude }}"
          data-lng="{{ block.settings.longitude }}"
          data-phone="{{ block.settings.phone | escape }}"
        >
          <div class="osm-thumb">
            {% if block.settings.image %}
              <img src="{{ block.settings.image | img_url: '300x300' }}" alt="{{ block.settings.name | escape }}">
            {% else %}
              <img src="//cdn.shopify.com/s/images/admin/no-image-compact.gif" alt="No image">
            {% endif %}
          </div>
          <div>
            <div class="osm-title">{{ block.settings.name }}</div>
            {% if block.settings.city != blank %}
              <div class="osm-sub">{{ block.settings.city }}</div>
            {% endif %}
            {% if block.settings.address != blank %}
              <div class="osm-sub">{{ block.settings.address }}</div>
            {% endif %}
            {% if block.settings.phone != blank %}
              <div class="osm-sub">
                📞 <a href="tel:{{ block.settings.phone | replace: ' ', '' }}" style="color:inherit;text-decoration:none;">
                  {{ block.settings.phone }}
                </a>
              </div>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </div>

    <!-- Sağ: Harita -->
    <div class="osm-mapwrap">
      <div id="osm-map-{{ section.id }}" class="osm-map"></div>
    </div>
  </div>

  <!-- Lightbox -->
  <div class="adj-lightbox" id="osm-lightbox-{{ section.id }}"><img alt="Store photo"></div>

  <!-- Leaflet JS -->
  <script
    src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
    integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
    crossorigin="">
  </script>

  <script>
    (function(){
      const mapId  = 'osm-map-{{ section.id }}';
      const listId = 'osm-list-{{ section.id }}';
      const mapEl = document.getElementById(mapId);
      if(!mapEl || !window.L) return;

      const map = L.map(mapId, { scrollWheelZoom: true, zoomControl: true });
      L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        maxZoom: 19, attribution: '&copy; OpenStreetMap'
      }).addTo(map);

      {% if section.settings.marker_icon != blank %}
        const adjIcon = L.icon({
          iconUrl: "{{ section.settings.marker_icon | image_url: width:64 }}",
          iconSize: [36, 36],
          iconAnchor: [18, 36],
          popupAnchor: [0, -28]
        });
      {% else %}
        const adjIcon = L.icon({
          iconUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-icon.png',
          iconSize: [25, 41],
          iconAnchor: [12, 41],
          popupAnchor: [1, -34],
          shadowUrl: 'https://unpkg.com/leaflet@1.9.4/dist/images/marker-shadow.png',
          shadowSize: [41, 41]
        });
      {% endif %}

      const items = Array.from(document.querySelectorAll('#'+listId+' .osm-item'));
      const markers = [];
      const bounds  = L.latLngBounds();

      items.forEach((item, idx) => {
        const lat = parseFloat(item.dataset.lat);
        const lng = parseFloat(item.dataset.lng);
        if (isNaN(lat) || isNaN(lng)) return;

        const name = item.querySelector('.osm-title')?.textContent || 'Store';
        const imgEl = item.querySelector('img');
        const imgSrc = imgEl ? imgEl.src : null;
        const phone = item.dataset.phone || '';

        const popupHtml = `
          <div style="min-width:180px">
            <div style="font-weight:700;margin-bottom:6px">${name}</div>
            {% if section.settings.popup_show_image %}
              ${imgSrc ? `<img src="${imgSrc}" style="width:100%;height:110px;object-fit:cover;border-radius:8px;margin-bottom:6px" />` : ``}
            {% endif %}
            ${phone ? `<div style="font-size:13px;color:#444;">📞 <a href="tel:${phone}" style="color:inherit;text-decoration:none;">${phone}</a></div>` : ``}
          </div>
        `;

        const m = L.marker([lat, lng], { icon: adjIcon }).addTo(map).bindPopup(popupHtml);
        m._listIndex = idx;
        m.on('click', () => activateIndex(idx, true));
        markers.push(m);
        bounds.extend([lat, lng]);
      });

      if (!bounds.isValid()) map.setView([46.8, 2.2], 5);
      else map.fitBounds(bounds.pad(0.2));

      function activateIndex(idx, fromMarker=false){
        items.forEach((el, i) => el.classList.toggle('active', i===idx));
        const marker = markers[idx];
        if (marker) {
          map.setView(marker.getLatLng(), Math.max(map.getZoom(), 8), { animate: true });
          marker.openPopup();
        }
        items[idx].scrollIntoView({behavior:'smooth', block:'nearest'});
      }

      items.forEach((el, idx) => el.addEventListener('click', () => activateIndex(idx, false)));

      const lb = document.getElementById('osm-lightbox-{{ section.id }}');
      const lbImg = lb.querySelector('img');
      document.getElementById(listId).addEventListener('click', (e)=>{
        const img = e.target.closest('.osm-thumb img');
        if (img) { lbImg.src = img.src; lb.classList.add('active'); e.stopPropagation(); }
      });
      lb.addEventListener('click', ()=>{ lb.classList.remove('active'); lbImg.src=''; });

      const firstActive = items.findIndex(i => i.classList.contains('active'));
      if (firstActive >= 0) activateIndex(firstActive, true);
    })();
  </script>
</section>

{% schema %}
{
  "name": "Stores Map OSM",
  "settings": [
    { "type": "text", "id": "title", "label": "Başlık", "default": "Boutiques" },
    { "type": "checkbox", "id": "popup_show_image", "label": "Popup'ta küçük görsel göster", "default": true },
    { "type": "image_picker", "id": "marker_icon", "label": "Özel Pin İkonu (opsiyonel 36×36 px)" }
  ],
  "blocks": [
    {
      "type": "store",
      "name": "Store",
      "settings": [
        { "type": "text", "id": "name", "label": "Mağaza Adı" },
        { "type": "text", "id": "city", "label": "Şehir" },
        { "type": "text", "id": "address", "label": "Adres" },
        { "type": "text", "id": "phone", "label": "Telefon" },
        { "type": "image_picker", "id": "image", "label": "Mağaza Görseli" },
        { "type": "text", "id": "latitude", "label": "Enlem (lat)" },
        { "type": "text", "id": "longitude", "label": "Boylam (lng)" }
      ]
    }
  ],
  "max_blocks": 50,
  "presets": [{ "name": "Stores Map OSM" }]
}
{% endschema %}
