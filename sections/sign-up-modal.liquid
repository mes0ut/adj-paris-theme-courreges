{% if section.settings.enabled %}
  {% liquid
    assign title_style = section.settings.title_style
    assign has_media = false

    if section.settings.image != blank or section.settings.video != blank
      assign has_media = true
    endif

    render 'css-delay', css_file: 'component-signup-modal.css', force_delay: true
  %}

  <script src="{{ 'signup-modal.js' | asset_url }}" defer></script>

  <signup-modal
    id="SignupModal-{{ section.id }}"
    class="modal modal--signup{% if has_media %} modal--has-media{% endif %}"
    data-delay="{{ section.settings.timeout }}"
  >
    <div
      class="modal__content gradient color-{{ section.settings.color_scheme }}"
      role="dialog"
      aria-modal="true"
      tabindex="-1"
    >
      <button
        id="ModalClose-{{ section.id }}"
        type="button"
        class="modal__close"
        aria-label="{{ 'accessibility.close' | t }}"
      >
        {% render 'icon-close' %}
      </button>
      <div class="modal__content-inner">
        {% if has_media %}
          <div class="modal__image">
            {% liquid
              assign primary_video = section.settings.video
              assign main_image = section.settings.image
            %}

            {% if primary_video != blank %}
              {{
                primary_video
                | video_tag:
                  image_size: '600x',
                  autoplay: true,
                  loop: true,
                  muted: true,
                  class: 'js-autoplay'
              }}
            {% elsif main_image != blank %}
              {{
                main_image
                | image_url: width: 900
                | image_tag:
                  loading: 'lazy',
                  width: main_image.width,
                  height: main_image.height,
                  sizes: '(min-width: 1100px) 535px, (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)',
                  widths: '535, 720, 940',
                  alt: main_image.alt
                | escape
              }}
            {%- endif -%}
          </div>
        {% endif %}

        <div class="modal__content-container">
          {% if section.settings.heading %}
            <h3 class="modal__title {{ title_style }}">
              {{ section.settings.heading }}
            </h3>
          {% endif %}

          {% if section.settings.content %}
            <div class="modal__text">
              <p>
                {{ section.settings.content }}
              </p>
            </div>
          {% endif %}

          {% form 'customer', class: 'newsletter-form' %}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="newsletter-form__field-wrapper">
              <div class="field">
                <input
                  id="NewsletterForm--{{ section.id }}"
                  type="email"
                  name="contact[email]"
                  class="field__input"
                  value="{{ form.email }}"
                  aria-required="true"
                  autocorrect="off"
                  autocapitalize="off"
                  autocomplete="email"
                  {% if form.errors %}
                    autofocus
                    aria-invalid="true"
                    aria-describedby="Newsletter-error--{{ section.id }}"
                  {% elsif form.posted_successfully? %}
                    aria-describedby="Newsletter-success--{{ section.id }}"
                  {% endif %}
                  placeholder="{{ 'newsletter.label' | t }}"
                  required
                >
                <label
                  class="field__label visually-hidden"
                  for="NewsletterForm--{{ section.id }}"
                >
                  {{ 'newsletter.label' | t }}
                </label>
              </div>
              {%- if form.errors -%}
                <small
                  class="newsletter-form__message form__message"
                  id="Newsletter-error--{{ section.id }}"
                >
                  {%- render 'icon-error' -%}
                  {{- form.errors.translated_fields.email | capitalize }}
                  {{ form.errors.messages.email -}}
                </small>
              {%- endif -%}
            </div>
            <button
              type="submit"
              name="commit"
              class="
                newsletter__button
                {{ section.settings.button_color_scheme }}
              "
            >
              {{ 'newsletter.button_label' | t }}
            </button>
            {%- if form.posted_successfully? -%}
              <h3
                class="newsletter-form__message newsletter-form__message--success form__message"
                id="Newsletter-success--{{ section.id }}"
                tabindex="-1"
                autofocus
              >
                {% render 'icon-success' -%}
                {{- 'newsletter.success' | t }}
              </h3>
            {%- endif -%}
          {% endform %}

          {% if section.settings.no_thanks_text %}
            <div
              id="ModalCloseNoThanks-{{ section.id }}"
              aria-label="{{ 'accessibility.close' | t }}"
              class="no-thanks-button rte"
            >
              <p>
                {{ section.settings.no_thanks_text }}
              </p>
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </signup-modal>
{% endif %}

{% schema %}
{
  "name": "t:sections.signup.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "enabled",
      "label": "t:sections.signup.settings.enable.label",
      "default": true,
      "info": "t:sections.signup.settings.enable.info"
    },
    {
      "type": "text",
      "id": "heading",
      "default": "Sign up & Save",
      "label": "t:sections.signup.settings.heading.label"
    },
    {
      "type": "select",
      "id": "title_style",
      "label": "t:sections.all.text.style.label",
      "options": [
        {
          "value": "uppercase",
          "label": "Uppercase"
        },
        {
          "value": "normal",
          "label": "Normal"
        }
      ],
      "default": "normal"
    },
    {
      "type": "text",
      "id": "content",
      "default": "Sign up today and get special product releases and exclusive sales!",
      "label": "t:sections.signup.settings.content.label"
    },
    {
      "type": "text",
      "id": "no_thanks_text",
      "label": "t:sections.signup.settings.no_thanks_text.label",
      "default": "No Thanks"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.signup.settings.image.label",
      "info": "t:sections.all.images_tips.portrait_medium.info"
    },
    {
      "type": "video",
      "id": "video",
      "label": "t:sections.all.videos_tips.general.label",
      "info": "t:sections.all.videos_tips.portrait.info"
    },
    {
      "type": "range",
      "id": "timeout",
      "min": 0,
      "max": 9900,
      "step": 100,
      "label": "t:sections.signup.settings.delay.label",
      "info": "t:sections.signup.settings.delay.info",
      "default": 5000
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "background-1"
    },
    {
      "type": "select",
      "id": "button_color_scheme",
      "options": [
        {
          "value": "button",
          "label": "t:sections.all.buttons.primary.label"
        },
        {
          "value": "button button--secondary",
          "label": "t:sections.all.buttons.secondary.label"
        },
        {
          "value": "link link-with-icon",
          "label": "t:sections.all.buttons.text_link.label"
        }
      ],
      "default": "button",
      "label": "t:sections.all.buttons.label"
    }
  ]
}
{% endschema %}
