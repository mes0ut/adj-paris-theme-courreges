{% liquid
  render 'css-delay', css_file: 'section-main-product-description.css'
  render 'section-spacing', id: section.id

  assign title_style = section.settings.title_style
  if title_style == 'uppercase'
    assign title_style = 'uppercase'
  endif
%}

<div
  class="
    product-description
    gradient
    color-{{ section.settings.color_scheme }}
    section-{{ section.id }}
    {% if section.settings.show_border_bottom %}
      section-border-bottom
    {% endif %}
  "
  id="description"
>
  <div class="page-width">
    <div class="product-description__container">
      {% if section.settings.decorative_icon %}
        <div class="product-description__container-icon">
          {% render 'icon-star-cluster-two' %}
        </div>
      {% endif %}
      {% if section.settings.product_description_heading != blank %}
        <h3 class="product-description__heading h5 {{ title_style }}">
          {{ section.settings.product_description_heading }}
        </h3>
      {% endif %}
      <div class="product-description__inner">
        <div class="product-description__description">
          {% for block in section.blocks %}
            {%- case block.type -%}
              {%- when '@app' -%}
                {% render block %}
              {%- when 'description' -%}
                {%- if product.description != blank -%}
                  <div
                    class="product-description__description-content rte"
                    {{ block.shopify_attributes }}
                  >
                    {{ product.description }}
                  </div>
                {%- endif -%}
              {%- when 'text' -%}
                <p
                  class="product-description__description-content rte"
                  {{ block.shopify_attributes }}
                >
                  {{- block.settings.text -}}
                </p>
            {%- endcase -%}
          {% endfor %}
        </div>

        <div class="product-description__tabs">
          {% for block in section.blocks %}
            {% if block.type == 'collapsible_tab' %}
              {% if block.settings.content != blank
                or block.settings.page.content != blank
              %}
                {% liquid
                  assign title_style = 'normal'
                  if block.settings.title_style == 'uppercase'
                    assign title_style = 'uppercase'
                  endif
                %}
                <div class="product-description__tab">
                  <accordion-item
                    class="product__accordion accordion"
                    {{ block.shopify_attributes }}
                  >
                    <details id="Details-{{ block.id }}-{{ section.id }}">
                      <summary>
                        <div class="summary__title p">
                          <h4 class="h6 accordion__title {{ title_style }}">
                            {{
                              block.settings.heading
                              | default: block.settings.page.title
                            }}
                          </h4>
                        </div>
                        {% render 'icon-caret' %}
                      </summary>
                      <div
                        class="accordion__content rte"
                        id="ProductAccordion-{{ block.id }}-{{ section.id }}"
                      >
                        {{ block.settings.content }}
                        {{ block.settings.page.content }}
                      </div>
                    </details>
                  </accordion-item>
                </div>
              {% endif %}
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "t:sections.main-product-description.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "background-3"
    },
    {
      "type": "checkbox",
      "id": "show_border_bottom",
      "label": "t:sections.all.border.show_border_bottom.label",
      "default": false
    },
    {
      "type": "text",
      "id": "product_description_heading",
      "label": "t:sections.main-product-description.settings.heading.label"
    },
    {
      "type": "select",
      "id": "title_style",
      "options": [
        {
          "value": "normal",
          "label": "t:sections.all.text.style.option_1"
        },
        {
          "value": "uppercase",
          "label": "t:sections.all.text.style.option_2"
        }
      ],
      "default": "normal",
      "label": "t:sections.all.text.style.label"
    },
    {
      "type": "checkbox",
      "id": "decorative_icon",
      "label": "t:sections.main-product-description.settings.decorative_icon.label",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.desktop_padding_header"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 96
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.mobile_padding_header"
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.mobile_padding_top",
      "default": 64
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.mobile_padding_bottom",
      "default": 64
    },
    {
      "type": "header",
      "content": "t:sections.all.margin.desktop_margin_header"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.margin.margin_bottom",
      "default": 120
    },
    {
      "type": "header",
      "content": "t:sections.all.margin.mobile_margin_header"
    },
    {
      "type": "range",
      "id": "mobile_margin_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.margin.mobile_margin_bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "description",
      "name": "t:sections.main-product-description.blocks.description.name",
      "limit": 1,
      "settings": [
        {
          "type": "paragraph",
          "content": "t:sections.main-product-description.blocks.description.settings.paragraph.content"
        }
      ]
    },
    {
      "type": "text",
      "name": "t:sections.main-product-description.blocks.text.name",
      "settings": [
        {
          "type": "paragraph",
          "content": "t:sections.main-product-description.blocks.text.settings.paragraph.content"
        },
        {
          "type": "text",
          "id": "text",
          "default": "Text block",
          "label": "t:sections.main-product-description.blocks.text.settings.text.label"
        }
      ]
    },
    {
      "type": "collapsible_tab",
      "name": "t:sections.main-product-description.blocks.collapsible_tab.name",
      "settings": [
        {
          "type": "paragraph",
          "content": "t:sections.main-product-description.blocks.collapsible_tab.settings.paragraph.content"
        },
        {
          "type": "text",
          "id": "heading",
          "default": "Collapsible row",
          "info": "t:sections.main-product-description.blocks.collapsible_tab.settings.heading.info",
          "label": "t:sections.main-product-description.blocks.collapsible_tab.settings.heading.label"
        },
        {
          "type": "select",
          "id": "title_style",
          "label": "t:sections.all.text.style.label",
          "options": [
            {
              "value": "normal",
              "label": "t:sections.all.text.style.option_1"
            },
            {
              "value": "uppercase",
              "label": "t:sections.all.text.style.option_2"
            }
          ],
          "default": "normal"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "t:sections.main-product-description.blocks.collapsible_tab.settings.content.label"
        },
        {
          "type": "page",
          "id": "page",
          "label": "t:sections.main-product-description.blocks.collapsible_tab.settings.page.label"
        }
      ]
    }
  ]
}
{% endschema %}
