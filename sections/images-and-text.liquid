{{ 'section-images-and-text.css' | asset_url | stylesheet_tag }}

{% liquid
  render 'section-spacing', id: section.id

  assign secondary_image = false
  assign side_text = false
  assign content = false
  if section.settings.enable_animation
    assign animate_class = 'animate'
  else
    assign animate_class = ''
  endif

  assign section_layout = ''
  if section.settings.section_layout == 'text_first'
    assign section_layout = 'image-text--reverse'
  endif
%}

{% capture large_image %}
  <div
    class="
      image-text__left
      {% if section.settings.secondary_image == blank and section.settings.secondary_video == blank %}
        no-secondary-image
      {% endif %}
    "
  >
    <div class="image-text__image-wrapper image-text__image-wrapper--primary">
      <div
        class="
          media
          media--transparent
          media--{{ section.settings.aspect_ratio }}
          media--hover-effect
          media--overflow-visible
          image-text__image-primary
          {{ section.settings.primary_image_style }}
          {{ animate_class }}
        "
      >
        {% if section.settings.primary_video != blank %}
          <div class="image-text__video">
            {% render 'video-delay-loader',
              video_data: section.settings.primary_video,
              image_size: '600x',
              class_name: 'js-autoplay',
              autoplay: true,
              loop: true,
              muted: true,
              loading: 'lazy',
              delay_loader: section.settings.delay_loader
            %}
          </div>
        {%- elsif section.settings.primary_image != blank -%}
          {% liquid
            assign image_src = section.settings.primary_image
            assign image_height = image_src.width | divided_by: image_src.aspect_ratio
            assign sizes = '(min-width: 1100px) 600px, (min-width: 750px) 40vw, 60vw'
            assign widths = '375, 550, 720, 1100, 1200'
            assign class = ''
            if image_src.aspect_ratio > 1.2
              assign sizes = '(min-width: 1100px) 1000px, (min-width: 750px) 40vw, 100vw'
              assign widths = '375, 550, 720, 1100, 1200'
            endif
            assign fetch_priority = 'auto'
            if section.index == 1
              assign fetch_priority = 'high'
            endif
          %}

          {{
            image_src
            | image_url: width: 1900
            | image_tag:
              width: image_src.width,
              height: image_height,
              fetch_priority: fetch_priority,
              sizes: sizes,
              widths: widths,
              class: class,
              alt: image_src.alt
            | escape
          }}
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>
      {% if section.settings.image_icon != blank %}
        <div class="image-text__image-primary-svg">
          {% render 'icon-star-cluster-three' %}
        </div>
      {% endif %}
    </div>
  </div>
{% endcapture %}

{% if section.blocks.size > 0 %}
  {% for block in section.blocks %}
    {% case block.type %}
      {% when 'image' %}
        {% capture secondary_image %}
          <div class="image-text__image-wrapper image-text__image-wrapper--secondary" {{ block.shopify_attributes }}>
            <div
              class="
                image-text__image-secondary
                media
                media--transparent
                media--{{ block.settings.aspect_ratio }}
                media--hover-effect
                media--overflow-visible
                {{ block.settings.secondary_image_style }}
                {{ animate_class }}
              "
            >
              {%- if block.settings.secondary_video != blank -%}
                <div class="image-text__video">
                  {% render 'video-delay-loader',
                    video_data: block.settings.secondary_video,
                    image_size: '600x',
                    autoplay: true,
                    loop: true,
                    muted: true,
                    class_name: 'js-autoplay',
                    loading: 'lazy',
                    delay_loader: block.settings.delay_loader
                  %}
                </div>
              {%- elsif block.settings.secondary_image != blank -%}
                {% liquid
                  assign image_src = block.settings.secondary_image
                  assign image_height = image_src.width | divided_by: image_src.aspect_ratio
                  assign sizes = '(min-width: 1100px) 600px, (min-width: 750px) 40vw, 60vw'
                  assign widths = '375, 550, 720, 1100, 1200'
                  assign class = 'image-text__image image-text__image--secondary'
                  if image_src.aspect_ratio > 1.2
                    assign sizes = '(min-width: 1100px) 1000px, (min-width: 750px) 40vw, 100vw'
                    assign widths = '375, 550, 720, 1100, 1200'
                  endif
                  assign fetch_priority = 'auto'
                  if block.index == 1
                    assign fetch_priority = 'high'
                  endif
                %}

                {{
                  image_src
                  | image_url: width: 1900
                  | image_tag:
                    width: image_src.width,
                    height: image_height,
                    fetch_priority: fetch_priority,
                    sizes: sizes,
                    widths: widths,
                    class: class,
                    alt: image_src.alt
                  | escape
                }}
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>
          </div>
        {% endcapture %}

        {% if block.settings.side_text != blank %}
          {% capture side_text %}
            <span class="image-text__right-side-text-wrapper">
              <div class="vertical-title">
                <span class="vertical-title__dash"></span>
                {{ block.settings.side_text }}
              </div>
            </span>
          {% endcapture %}
        {% endif %}
      {% when 'content' %}
        {% capture content %}
          {% assign title_style = block.settings.title_style %}
          {% if title_style == 'uppercase' %}
            {% assign title_style = 'uppercase' %}
          {% endif %}
          <div {{ block.shopify_attributes }}>
            {% if block.settings.heading != blank %}
              <{{ block.settings.heading_size }}
                class="
                  image-text__heading
                  {{ title_style }}
                  {{ animate_class }}
                "
              >
                {% if block.settings.heading_icon != blank %}
                  {% render 'icon-star-cluster-two' %}
                {% endif %}
                {{ block.settings.heading }}
              </{{ block.settings.heading_size }}>
            {% endif %}

            {% if block.settings.paragraph != blank %}
              <div class="p-large image-text__paragraph {{ animate_class }}">
                {{ block.settings.paragraph }}
              </div>
            {% endif %}

            {% if block.settings.link != blank %}
              <a
                href="{{ block.settings.link }}"
                class="
                  image-text__link
                  link
                  link-with-icon
                  {{ animate_class }}
                  {{ block.settings.button_color_scheme }}
                "
              >
                <span>{{ block.settings.link_text }}</span>
                {% render 'icon-arrow' %}
              </a>
            {% endif %}
          </div>
        {% endcapture %}
    {% endcase %}
  {% endfor %}
{% endif %}

{% capture image_and_text %}
  <div
    class="
      image-text__right
      {% if secondary_image == false %}
        no-secondary-image
      {% endif %}
    "
  >
    <div class="image-text__right-content">
      {% if content != false %}
        {{ content }}
      {% endif %}
    </div>

    {% if secondary_image != false %}
      {{ secondary_image }}
    {% endif %}
  </div>
{% endcapture %}

<div
  class="
    section-{{ section.id }}
    gradient
    color-{{ section.settings.color_scheme }}
    {% if section.settings.show_border_bottom %}section-border-bottom{% endif %}
  "
>
  <div class="page-width image-text {{ section_layout }}">
    {{ large_image }}

    {{ image_and_text }}

    {% if side_text != false %}
      {{ side_text }}
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.image-text.name",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "primary_image",
      "label": "t:sections.image-text.settings.first-image.label",
      "info": "t:sections.all.images_tips.portrait_big.info"
    },
    {
      "type": "video",
      "id": "primary_video",
      "label": "t:sections.all.videos_tips.general.label",
      "info": "t:sections.all.videos_tips.portrait.info"
    },
    {
      "type": "checkbox",
      "id": "delay_loader",
      "label": "t:settings_schema.global.video.delay_loader.label",
      "info": "t:settings_schema.global.video.delay_loader.info",
      "default": false,
      "visible_if": "{{ section.settings.primary_video }}"
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "t:sections.all.image-ratios.label",
      "options": [
        {
          "value": "portrait",
          "label": "t:sections.all.image-ratios.options_2.label"
        },
        {
          "value": "square",
          "label": "t:sections.all.image-ratios.options_3.label"
        }
      ],
      "default": "portrait"
    },
    {
      "type": "select",
      "id": "primary_image_style",
      "options": [
        {
          "value": "image-border-radius--none",
          "label": "t:sections.all.radius.none.label"
        },
        {
          "value": "image-border-radius--rounded-xxs",
          "label": "t:sections.all.radius.xxs.label"
        },
        {
          "value": "image-border-radius--rounded-xs",
          "label": "t:sections.all.radius.xs.label"
        },
        {
          "value": "image-border-radius--rounded-small",
          "label": "t:sections.all.radius.small.label"
        },
        {
          "value": "image-border-radius--rounded",
          "label": "t:sections.all.radius.standard.label"
        },
        {
          "value": "image-border-radius--rounded-extra",
          "label": "t:sections.all.radius.extra.label"
        },
        {
          "value": "image-border-radius--curved-top",
          "label": "t:sections.all.radius.curved.label"
        }
      ],
      "default": "image-border-radius--none",
      "label": "t:sections.all.radius.label"
    },
    {
      "type": "checkbox",
      "id": "image_icon",
      "default": false,
      "label": "t:sections.image-text.settings.first-image-icon.label"
    },
    {
      "type": "header",
      "content": "t:sections.image-text.settings.content_header.content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "background-1"
    },
    {
      "type": "checkbox",
      "id": "show_border_bottom",
      "label": "t:sections.all.border.show_border_bottom.label",
      "default": false
    },
    {
      "type": "select",
      "id": "section_layout",
      "options": [
        {
          "value": "image_first",
          "label": "t:sections.image-text.settings.layout.option_1.label"
        },
        {
          "value": "text_first",
          "label": "t:sections.image-text.settings.layout.option_2.label"
        }
      ],
      "default": "text_first",
      "label": "t:sections.image-text.settings.layout.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.desktop_padding_header"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.mobile_padding_header"
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.mobile_padding_top",
      "default": 0
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.mobile_padding_bottom",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:sections.all.margin.desktop_margin_header"
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.margin.margin_bottom",
      "default": 120
    },
    {
      "type": "header",
      "content": "t:sections.all.margin.mobile_margin_header"
    },
    {
      "type": "range",
      "id": "mobile_margin_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.margin.mobile_margin_bottom",
      "default": 60
    },
    {
      "type": "header",
      "content": "t:sections.all.animations.section_animation.header",
      "visible_if": "{{ settings.enable_global_animations }}"
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "t:sections.all.animations.section_animation.label",
      "default": true,
      "visible_if": "{{ settings.enable_global_animations }}"
    }
  ],
  "blocks": [
    {
      "name": "t:sections.image-text.blocks.content.name",
      "type": "content",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.image-text.settings.heading.label",
          "default": "Add Heading"
        },
        {
          "type": "checkbox",
          "id": "heading_icon",
          "default": false,
          "label": "t:sections.image-text.settings.heading-icon.label"
        },
        {
          "type": "select",
          "id": "title_style",
          "label": "t:sections.all.text.style.label",
          "options": [
            {
              "value": "normal",
              "label": "t:sections.all.text.style.option_1"
            },
            {
              "value": "uppercase",
              "label": "t:sections.all.text.style.option_2"
            }
          ],
          "default": "normal"
        },
        {
          "type": "select",
          "id": "heading_size",
          "options": [
            {
              "value": "h3",
              "label": "t:sections.all.heading_size.options_2.label"
            },
            {
              "value": "h2",
              "label": "t:sections.all.heading_size.options_3.label"
            }
          ],
          "default": "h2",
          "label": "t:sections.all.heading_size.heading.label"
        },
        {
          "type": "richtext",
          "id": "paragraph",
          "label": "t:sections.image-text.settings.paragraph.label",
          "default": "<p>Provide customers more information about your store.</p>"
        },
        {
          "type": "url",
          "id": "link",
          "label": "t:sections.image-text.settings.link.label",
          "default": "/"
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "t:sections.image-text.settings.link-text.label",
          "default": "Explore now"
        },
        {
          "type": "select",
          "id": "button_color_scheme",
          "options": [
            {
              "value": "button",
              "label": "t:sections.all.buttons.primary.label"
            },
            {
              "value": "button button--secondary",
              "label": "t:sections.all.buttons.secondary.label"
            },
            {
              "value": "link link-with-icon",
              "label": "t:sections.all.buttons.text_link.label"
            }
          ],
          "default": "button",
          "label": "t:sections.all.buttons.label"
        }
      ]
    },
    {
      "name": "t:sections.image-text.blocks.secondary_image.name",
      "type": "image",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "secondary_image",
          "label": "t:sections.image-text.settings.secondary-image.label",
          "info": "t:sections.all.images_tips.portrait_big.info"
        },
        {
          "type": "video",
          "id": "secondary_video",
          "label": "t:sections.all.videos_tips.general.label",
          "info": "t:sections.all.videos_tips.portrait.info"
        },
        {
          "type": "checkbox",
          "id": "delay_loader",
          "label": "t:settings_schema.global.video.delay_loader.label",
          "info": "t:settings_schema.global.video.delay_loader.info",
          "default": false,
          "visible_if": "{{ block.settings.secondary_video }}"
        },
        {
          "type": "select",
          "id": "aspect_ratio",
          "label": "t:sections.all.image-ratios.label",
          "options": [
            {
              "value": "portrait",
              "label": "t:sections.all.image-ratios.options_2.label"
            },
            {
              "value": "square",
              "label": "t:sections.all.image-ratios.options_3.label"
            }
          ],
          "default": "portrait"
        },
        {
          "type": "select",
          "id": "secondary_image_style",
          "options": [
            {
              "value": "image-border-radius--none",
              "label": "t:sections.all.radius.none.label"
            },
            {
              "value": "image-border-radius--rounded-small",
              "label": "t:sections.all.radius.small.label"
            },
            {
              "value": "image-border-radius--rounded",
              "label": "t:sections.all.radius.standard.label"
            },
            {
              "value": "image-border-radius--rounded-extra",
              "label": "t:sections.all.radius.extra.label"
            },
            {
              "value": "image-border-radius--curved-top",
              "label": "t:sections.all.radius.curved.label"
            }
          ],
          "default": "image-border-radius--curved-top",
          "label": "t:sections.all.radius.label"
        },
        {
          "type": "text",
          "id": "side_text",
          "label": "t:sections.image-text.settings.side-text.label",
          "default": "Provide more details here"
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "presets": [
    {
      "name": "t:sections.image-text.presets.name",
      "category": "t:categories.media",
      "blocks": [
        {
          "type": "content"
        }
      ]
    }
  ]
}
{% endschema %}
