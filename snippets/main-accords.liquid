{%- assign accords_raw = product.metafields.custom.main_accords -%}

{% if accords_raw != blank %}
  <style>
    .main-accords{margin:16px 0 18px; max-width:680px;}
    .main-accords__title{
      font-size:12px;
      letter-spacing:.18em;
      text-transform:uppercase;
      opacity:.7;
      margin-bottom:12px;
    }
    .main-accords__list{display:grid; gap:8px}

    .main-accords__bar{
      position:relative;
      height:34px;
      border-radius:14px;
      background:#f3f2f1;
      overflow:hidden;
      transition:transform .16s ease, filter .16s ease;
    }

    /* Fill layer (animated) */
    .main-accords__bar::before{
      content:"";
      position:absolute;
      inset:0;
      width:0; /* start empty */
      background:var(--c,#B8743A);
      border-radius:14px;
    }

    /* subtle gloss */
    .main-accords__bar::after{
      content:"";
      position:absolute;
      inset:0;
      background:linear-gradient(to bottom, rgba(255,255,255,.18), rgba(255,255,255,0));
      pointer-events:none;
      z-index:2;
    }

    .main-accords__label{
      position:relative;
      z-index:3;
      display:flex;
      align-items:center;
      height:100%;
      padding:0 12px;
      font-size:14px;
      font-weight:500;
      letter-spacing:.02em;
      text-transform:none;
      color:rgba(255,255,255,.95);
    }

    @media (hover:hover){
      .main-accords__bar:hover{
        transform:translateY(-1px);
        filter:saturate(1.03);
      }
    }

    @media(max-width:749px){
      .main-accords__bar{height:32px}
      .main-accords__label{font-size:13px}
    }

    /* Animation */
    @keyframes accordsFill {
      from { width: 0; }
      to { width: var(--w); }
    }

    .main-accords--animate .main-accords__bar::before{
      animation: accordsFill 1.2s cubic-bezier(.22,.61,.36,1) forwards;
    }

    /* Slow stagger – layered opening */
    .main-accords--animate .main-accords__bar:nth-child(1)::before{ animation-delay: .12s; }
    .main-accords--animate .main-accords__bar:nth-child(2)::before{ animation-delay: .22s; }
    .main-accords--animate .main-accords__bar:nth-child(3)::before{ animation-delay: .32s; }
    .main-accords--animate .main-accords__bar:nth-child(4)::before{ animation-delay: .42s; }
    .main-accords--animate .main-accords__bar:nth-child(5)::before{ animation-delay: .52s; }
    .main-accords--animate .main-accords__bar:nth-child(6)::before{ animation-delay: .62s; }
    .main-accords--animate .main-accords__bar:nth-child(7)::before{ animation-delay: .72s; }
    .main-accords--animate .main-accords__bar:nth-child(8)::before{ animation-delay: .82s; }

    /* Accessibility */
    @media (prefers-reduced-motion: reduce){
      .main-accords__bar::before{ width: var(--w); animation:none !important; }
      .main-accords__bar{ transition:none !important; }
    }
  </style>

  <div class="main-accords" data-accords>
    <div class="main-accords__title">
      {% if request.locale.iso_code == 'fr' %}
        PYRAMIDE OLFACTIVE
      {% else %}
        OLFACTIVE PYRAMID
      {% endif %}
    </div>

    {% assign rows = accords_raw | newline_to_br | split: '<br />' %}
    <div class="main-accords__list">
      {% for row in rows %}
        {% assign row_clean = row | strip %}
        {% if row_clean != blank %}
          {% assign p = row_clean | split: '|' %}
          {% if p.size >= 3 %}
            {% assign label = p[0] | strip %}
            {% assign percent = p[1] | strip | plus: 0 %}
            {% assign color = p[2] | strip %}

            {% if percent < 0 %}{% assign percent = 0 %}{% endif %}
            {% if percent > 100 %}{% assign percent = 100 %}{% endif %}

            <div class="main-accords__bar" style="--w: {{ percent }}%; --c: {{ color }};">
              <span class="main-accords__label">{{ label }}</span>
            </div>
          {% endif %}
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <script>
    (function(){
      var root = document.currentScript && document.currentScript.previousElementSibling;
      if(!root || !root.matches('[data-accords]')) return;
      requestAnimationFrame(function(){
        root.classList.add('main-accords--animate');
      });
    })();
  </script>
{% endif %}
