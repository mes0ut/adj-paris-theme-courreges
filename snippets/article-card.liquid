{% comment %}
  Renders an article card for a given blog with settings to either show the image or not.

  Accepts:
  - blog: {Object} Blog object
  - article: {Object} Article object

  Usage:
  {% render 'article-card' blog: blog, article: article %}
{% endcomment %}

<article
  class="article-card{% if article.image == blank or show_image == false %} article-card--no-image{% endif %}"
  aria-labelledby="Article-{{ article.id }}"
>
  {% if article.tags.size != 0 %}
    <ul class="article-card__tags">
      {% for tag in article.tags %}
        <li>
          <a href="{{ blog.url }}/tagged/{{ tag | handle }}" class="tag">
            {{- tag -}}
          </a>
        </li>
      {% endfor %}
    </ul>
  {% endif %}
  <a href="{{ article.url }}" class="article-content motion-reduce">
    {%- if settings.show_comment_badge
      and article.comments_count > 0
      and blog.comments_enabled?
    -%}
      <span
        class="
          article-card__comment-count
          badge p-tiny
          color-{{ settings.comment_badge_color_scheme }}
          {% if settings.rounded_tags %}badge--rounded{% endif %}
          {% if settings.comment_badge_clear %}badge--clear{% endif %}
        "
      >
        {{- 'blogs.article.comments' | t: count: article.comments_count -}}
      </span>
    {%- endif -%}
    {%- if article.image -%}
      <div class="article-card__image-wrapper">
        <div class="article-card__image">
          {{
            article.image
            | image_url: width: 720
            | image_tag:
              loading: 'lazy',
              width: article.image.width,
              height: article.image.height,
              sizes: '(min-width: 1100px) 535px, (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)',
              widths: '360, 533, 720, 940, 1066',
              class: 'motion-reduce',
              alt: article.image.alt
            | escape
          }}
        </div>
      </div>
    {%- endif -%}

    <div class="article-card__info">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'title' -%}
            {% liquid
              assign title_style = block.settings.title_style
              if title_style == 'uppercase'
                assign title_style = 'uppercase'
              endif
            %}
            <header class="article-card__header" {{ block.shopify_attributes }}>
              {%- if block.settings.show_date or block.settings.show_author -%}
                <span class="article-card__details">
                  {%- if block.settings.show_date -%}
                    <span class="caption-with-letter-spacing">
                      {{- article.published_at | time_tag: '%B %d, %Y' -}}
                    </span>
                  {%- endif -%}
                </span>
                {%- if block.settings.show_author -%}
                  <span class="caption-with-letter-spacing">
                    {%- if block.settings.show_date -%}
                      &nbsp; &middot; &nbsp;
                    {%- endif -%}
                    {{- article.author -}}
                  </span>
                {%- endif -%}
              {%- endif -%}
              <h2
                class="article-card__title h5 {{ title_style }}"
                id="Article-{{ article.id }}"
              >
                {{ article.title | escape }}
              </h2>
            </header>
          {%- when 'summary' -%}
            {%- if article.excerpt_or_content -%}
              <p
                class="article-card__excerpt p-m--small rte-width"
                {{ block.shopify_attributes }}
              >
                {%- if article.excerpt_or_content -%}
                  {{
                    article.excerpt_or_content
                    | strip_html
                    | truncatewords: 18
                  }}
                {%- endif -%}
              </p>
            {%- endif -%}
          {%- when 'link' -%}
            <div
              class="article-card__footer p p-m--small"
              {{ block.shopify_attributes }}
            >
              <span
                class="{{ block.settings.button_color_scheme }}"
                aria-label="{{ 'blogs.article.read_more_title' | t: title: article.title | escape }}"
              >
                {{ 'blogs.article.read_more' | t }}
              </span>
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </a>
</article>
