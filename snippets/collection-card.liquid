{% comment %}
  Renders a collection card

  Accepts:
  - _collection: {Object} collection object

  Usage:
  {% render 'collection-card',
    card_collection: collection
    image_style: section.settings.image_style
    media_size: section.settings.image_ratio
  %}
{% endcomment %}

{% liquid
  if card_collection.image == null
    for product in card_collection.products
      if product.featured_image != blank
        assign collection_img_fallback = product.featured_image
        break
      endif
    endfor
  endif

  assign title_style = title_style | default: 'normal'
  if title_style == 'uppercase'
    assign title_style = 'uppercase'
  endif
%}

<div class="card-wrapper">
  <a href="{{ card_collection.url | default: '#' }}" class="full-unstyled-link">
    <div
      class="card card--product{% if card_collection.image == nil and collection_img_fallback == nil %} card--text-only card--soft{% endif %} {{ image_style }}"
      tabindex="-1"
      id="{{ card_collection.id }}"
    >
      <div class="card__inner">
        {%- if card_collection.image -%}
          <div
            class="collection-image-wrapper media media--transparent media--{{ media_size }} media--hover-effect media--overflow-visible"
            {% if media_size == 'adapt' %}
              style="padding-bottom: {{ 1 | divided_by: card_collection.image.aspect_ratio | times: 100 }}%;"
            {% endif %}
          >
            {{
              card_collection.image
              | image_url: width: 720
              | image_tag:
                loading: 'lazy',
                width: card_collection.image.width,
                height: card_collection.image.height,
                sizes: '(min-width: 1100px) 535px, (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)',
                widths: '360, 535, 720, 940',
                alt: card_collection.title
              | escape
            }}
          </div>
        {%- elsif collection_img_fallback != blank -%}
          <div
            class="collection-image-wrapper media media--transparent media--{{ media_size }} media--hover-effect media--overflow-visible"
            {% if media_size == 'adapt' %}
              style="padding-bottom: {{ 1 | divided_by: collection_img_fallback.aspect_ratio | times: 100 }}%;"
            {% endif %}
          >
            {{
              collection_img_fallback
              | image_url: width: 720
              | image_tag:
                loading: 'lazy',
                width: collection_img_fallback.width,
                height: collection_img_fallback.height,
                sizes: '(min-width: 1100px) 535px, (min-width: 750px) calc((100vw - 130px) / 2), calc((100vw - 50px) / 2)',
                widths: '360, 535, 720, 940',
                alt: collection_img_fallback.alt
              | escape
            }}
          </div>
        {% else %}
          <div class="card__content">
            <h2 class="card__text h3 {{ title_style }}">
              {{ card_collection.title }}
            </h2>
          </div>
        {%- endif -%}
      </div>
    </div>

    <div class="card-information">
      <div class="card-information__wrapper">
        {%- if card_collection.title != blank -%}
          <h5 class="card-information__text h6 {{ title_style }}">
            {{ card_collection.title | escape }}
          </h5>
        {%- else -%}
          <h5 class="card-information__text h6 {{ title_style }}">
            {{ 'onboarding.collection_title' | t }}
          </h5>
        {%- endif -%}

        {% if card_collection.description %}
          <p class="card-information__description light">
            {{ card_collection.description | strip_html | truncatewords: 20 }}
          </p>
        {% endif %}
      </div>
    </div>
  </a>
</div>
