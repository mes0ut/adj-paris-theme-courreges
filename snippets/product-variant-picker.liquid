{% comment %}
  Renders product variant-picker

  Accepts:
  - product: {Object} product object.
  - block: {Object} passing the block information.
  - product_form_id: {String} Id of the product form to which the variant picker is associated.
  - form_type: {String} Type of form to render.
  - blocks: {Array} List of blocks in the section.
  Usage:
  {% render 'product-variant-picker', product: product, block: block, product_form_id: product_form_id, form_type: form_type %}
{% endcomment %}

{% liquid
  assign picker_type = block.settings.picker_type
  assign form_type = form_type | default: 'main'

  if block == null
    if settings.picker_type == 'button'
      assign picker_type = 'button'
    else
      assign picker_type = 'swatch'
    endif
  elsif form_type == 'fixed-cart'
    assign picker_type = 'dropdown'
  endif
%}

{%- unless product.has_only_default_variant -%}
  <variant-selects
    id="variant-selects-{{ section.id }}"
    data-section="{{ section.id }}"
    data-form-type="{{ form_type }}"
    {{ block.shopify_attributes }}
    {% if form_type == 'fixed-cart' %}
      data-option-length="{{ product.options_with_values.size }}"
    {% endif %}
  >
    {%- for option in product.options_with_values -%}
      {%- liquid
        if form_type == 'fixed-cart' or block.settings.picker_type == 'dropdown'
          assign picker_type = 'dropdown'
        else
          assign picker_type = 'button'
          assign swatch_count = 0
          assign swatch_count = option.values | map: 'swatch' | compact | size

          if swatch_count > 0
            if block.settings.picker_type == 'dropdown'
              assign picker_type = 'swatch_dropdown'
            else
              assign picker_type = 'swatch'
            endif
          endif
        endif

        assign size_chart_block = null

        for section_block in blocks
          if section_block.type == 'size_chart' and section_block.settings.position == 'next-to-option' and section_block.settings.option_name == option.name
            assign size_chart_block = section_block

            break
          endif
        endfor
      -%}

      {%- capture size_chart_markup -%}
        {%- render 'product-size-chart', size_chart_block: size_chart_block, product: product, section: section -%}
      {%- endcapture -%}

      {%- if picker_type == 'swatch' -%}
        <fieldset class="js product-form__input product-form__input--swatch">
          <div class="product-form__legend-wrapper">
            <legend class="form__label">
              {{ option.name }}:
              <span data-selected-value>
                {{- option.selected_value -}}
              </span>
            </legend>

            {{- size_chart_markup -}}
          </div>
          <div class="product-form__input-wrapper">
            {% render 'product-variant-options',
              product: product,
              option: option,
              block: block,
              picker_type: picker_type,
              enable_media_group: enable_media_group,
              media_group_name: media_group_name
            %}
          </div>
        </fieldset>
      {%- elsif picker_type == 'button' -%}
        <fieldset class="js product-form__input product-form__input--pill">
          <div class="product-form__legend-wrapper">
            <legend class="form__label">
              {{ option.name }}:
              <span data-selected-value>
                {{- option.selected_value -}}
              </span>
            </legend>

            {{- size_chart_markup -}}
          </div>
          <div class="product-form__input-wrapper">
            {% render 'product-variant-options',
              product: product,
              option: option,
              block: block,
              picker_type: picker_type,
              enable_media_group: enable_media_group,
              media_group_name: media_group_name
            %}
          </div>
        </fieldset>
      {%- else -%}
        <div class="product-form__input product-form__input--dropdown">
          <div class="product-form__legend-wrapper">
            <label
              class="form__label"
              for="Option-{{ section.id }}-{{ forloop.index0 }}"
            >
              {{ option.name }}:
              <span class="form__label-variant">
                {{ option.selected_value }}
              </span>
            </label>

            {{- size_chart_markup -}}
          </div>
          <div class="select">
            <select
              id="Option-{{ section.id }}-{{ forloop.index0 }}"
              class="select__select"
              name="options[{{ option.name | escape }}]"
              form="{{ product_form_id }}"
            >
              {% render 'product-variant-options',
                product: product,
                option: option,
                block: block,
                picker_type: picker_type,
                enable_media_group: enable_media_group,
                media_group_name: media_group_name
              %}
            </select>
            {% render 'icon-caret' %}
          </div>
        </div>
      {%- endif -%}
    {%- endfor -%}

    <script type="application/json" data-selected-variant>
      {{ product.selected_or_first_available_variant | json }}
    </script>
  </variant-selects>
{%- endunless -%}
