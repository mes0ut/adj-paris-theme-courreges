<div class="article-template__comment-wrapper">
  <div
    id="comments"
    class="page-width page-width--extra-narrow"
  >
    {%- if article.comments_count > 0 -%}
      {%- assign anchorId = '#Comments-' | append: article.id -%}

      <h2 id="Comments-{{ article.id }}" class="h4 center">
        {{ 'blogs.article.comments' | t: count: article.comments_count }}
      </h2>
      {% paginate article.comments by 5 %}
        <div class="article-template__comments">
          {%- if comment.status == 'pending' and comment.content -%}
            <article
              id="{{ comment.id }}"
              class="article-template__comments-comment"
            >
              {{ comment.content }}
              <footer>
                <p>
                  <strong>{{ comment.author }}</strong>
                </p>
              </footer>
            </article>
          {%- endif -%}

          {%- for comment in article.comments -%}
            <article
              id="{{ comment.id }}"
              class="article-template__comments-comment color-{{ background }}"
            >
              {{ comment.content }}
              <footer>
                <p>
                  <strong>
                    <span>{{ comment.author }}, </span
                    ><span>
                      {{- comment.created_at | time_tag: '%B %d, %Y' -}}
                    </span>
                  </strong>
                </p>
              </footer>
            </article>
          {%- endfor -%}

          {% render 'pagination', paginate: paginate, anchor: anchorId %}
        </div>
      {% endpaginate %}
    {%- endif -%}

    {% form 'new_comment', article %}
      {%- liquid
        assign post_message = 'blogs.article.success'

        if blog.moderated? and comment.status == 'unapproved'
          assign post_message = 'blogs.article.success_moderated'
        endif
      -%}

      <h2 class="h5">{{ 'blogs.article.comment_form_title' | t }}</h2>

      {%- if form.errors -%}
        <div class="form__message" role="alert">
          <h3 class="form-status caption-large" tabindex="-1" autofocus>
            {% render 'icon-error' %}
            {{ 'templates.contact.form.error_heading' | t }}
          </h3>
        </div>
        <ul class="form-status-list caption-large">
          {%- for field in form.errors -%}
            <li>
              <a href="#CommentForm-{{ field }}" class="link">
                {%- if form.errors.translated_fields[field] contains 'author'
                -%}
                  {{ 'blogs.article.name' | t }}
                {%- elsif form.errors.translated_fields[field] contains 'body'
                -%}
                  {{ 'blogs.article.message' | t }}
                {%- else -%}
                  {{ form.errors.translated_fields[field] }}
                {%- endif -%}
                {{ form.errors.messages[field] }}
              </a>
            </li>
          {%- endfor -%}
        </ul>
      {%- elsif form.posted_successfully? -%}
        <div
          role="status"
        >
          <div
            class="form-status-list p"
            tabindex="-1"
            autofocus
          >
            {% render 'icon-success' %}
            {{ post_message | t }}
          </div>
        </div>
      {%- endif -%}

      <div
        {% if blog.moderated? == false %}
          class="article-template__comments-fields"
        {% endif %}
      >
        <div class="article-template__comment-fields">
          <div class="field {%- if form.errors contains 'author' -%}field-with-error{%- endif -%}">
            <input
              type="text"
              name="comment[author]"
              id="CommentForm-author"
              class="field__input"
              autocomplete="name"
              value="{{ form.author }}"
              aria-required="true"
              {% if form.errors contains 'author' %}
                aria-invalid="true"
                aria-describedby="CommentForm-author-error"
              {% endif %}
              placeholder="{{ 'blogs.article.name' | t }} *"
              required
            >
            <label
              class="field__label visually-hidden"
              for="CommentForm-author"
            >
              {{- 'blogs.article.name' | t }}
              <span aria-hidden="true">*</span></label
            >

            {%- if form.errors contains 'author' -%}
              <h6
                id="CommentForm-author-error"
                class="p-large form__message form__message--large"
              >
                {% render 'icon-error' %}
                {{- 'blogs.article.name' | t }}
                {{ form.errors.messages.author -}}
              </h6>
            {%- endif -%}
          </div>

          <div class="field {%- if form.errors contains 'email' -%}field-with-error{%- endif -%}">
            <input
              type="email"
              name="comment[email]"
              id="CommentForm-email"
              autocomplete="email"
              class="field__input"
              value="{{ form.email }}"
              autocorrect="off"
              autocapitalize="off"
              aria-required="true"
              {% if form.errors contains 'email' %}
                aria-invalid="true"
                aria-describedby="CommentForm-email-error"
              {% endif %}
              placeholder="{{ 'blogs.article.email' | t }} *"
              required
            >
            <label class="field__label visually-hidden" for="CommentForm-email">
              {{- 'blogs.article.email' | t }}
              <span aria-hidden="true">*</span></label
            >

            {%- if form.errors contains 'email' -%}
              <h6
                id="CommentForm-email-error"
                class="p-large form__message form__message--large"
              >
                {% render 'icon-error' %}
                {{- 'blogs.article.email' | t }}
                {{ form.errors.messages.email }}
              </h6>
            {%- endif -%}
          </div>
        </div>

        <div class="field {%- if form.errors contains 'body' -%}field-with-error{%- endif -%}">
          <textarea
            rows="5"
            name="comment[body]"
            id="CommentForm-body"
            class="text-area field__input"
            aria-required="true"
            {% if form.errors contains 'body' %}
              aria-invalid="true"
              aria-describedby="CommentForm-body-error"
            {% endif %}
            placeholder="{{ 'blogs.article.message' | t }} *"
            required
          ></textarea>
          <label
            class="form__label field__label visually-hidden"
            for="CommentForm-body"
          >
            {{- 'blogs.article.message' | t }}
            <span aria-hidden="true">*</span></label
          >

          {%- if form.errors contains 'body' -%}
            <h6
              id="CommentForm-body-error"
              class="p-large form__message form__message--large"
            >
              {% render 'icon-error' %}
              {{- 'blogs.article.message' | t }}
              {{ form.errors.messages.body }}
            </h6>
          {%- endif -%}
        </div>
      </div>

      {%- if blog.moderated? -%}
        <p class="article-template__comment-warning caption">
          {{ 'blogs.article.moderated' | t }}
        </p>
      {%- endif -%}
      <button type="submit" class="button button-with-icon">
        {{ 'blogs.article.post' | t }}
        {% render 'icon-arrow' %}
      </button>
    {% endform %}
  </div>
</div>
